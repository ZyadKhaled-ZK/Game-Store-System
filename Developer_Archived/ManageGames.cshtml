@page
@model GameStore.PL.Pages.Developer.ManageGamesModel
@{
    ViewData["Title"] = "Manage Games";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Manage Games — Dev Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <style>
        :root { --bg:#1b2838; --bg2:#16202d; --bg3:#1e2a39; --accent:#66c0f4; --border:rgba(102,192,244,0.15); --text:#c6d4df; --text2:#8f98a0; --bright:#fff; }
        * { box-sizing:border-box; }
        body { background:var(--bg); color:var(--text); font-family:Arial,sans-serif; margin:0; }
        .dev-nav { background:#171a21; border-bottom:1px solid rgba(0,0,0,0.5); padding:0 24px; height:52px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; }
        .dev-nav-brand { font-weight:700; color:var(--bright); font-size:1rem; text-decoration:none; }
        .dev-nav-brand span { color:var(--accent); }
        .nav-links { display:flex; gap:6px; align-items:center; }
        .nav-btn { color:var(--text2); text-decoration:none; padding:5px 12px; border-radius:3px; font-size:0.85rem; transition:all 0.15s; }
        .nav-btn:hover { color:var(--bright); background:rgba(255,255,255,0.06); }
        .nav-btn.primary { background:linear-gradient(135deg,#4a90d9,#2d6aa0); color:white; }
        .nav-btn.danger { color:#fc8181; }
        .page-wrap { max-width:1200px; margin:0 auto; padding:32px 24px 60px; }
        .page-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:12px; }
        .page-top h1 { font-size:1.4rem; font-weight:700; color:var(--bright); margin:0; }
        .top-controls { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
        .gs-search { background:var(--bg2); border:1px solid rgba(255,255,255,0.1); color:var(--text); border-radius:3px; padding:6px 12px 6px 32px; font-size:0.85rem; width:200px; }
        .gs-search:focus { outline:none; border-color:var(--accent); }
        .search-wrap { position:relative; }
        .search-icon { position:absolute; left:10px; top:50%; transform:translateY(-50%); font-size:0.8rem; color:var(--text2); pointer-events:none; }
        .gs-filter { background:var(--bg2); border:1px solid rgba(255,255,255,0.1); color:var(--text); border-radius:3px; padding:6px 10px; font-size:0.82rem; cursor:pointer; }
        .games-table { width:100%; border-collapse:separate; border-spacing:0 4px; }
        .games-table th { font-size:0.7rem; text-transform:uppercase; letter-spacing:1px; color:var(--text2); padding:6px 12px; font-weight:600; text-align:left; }
        .games-table td { background:var(--bg3); padding:11px 12px; font-size:0.87rem; vertical-align:middle; }
        .games-table tr.game-row td:first-child { border-radius:4px 0 0 4px; }
        .games-table tr.game-row td:last-child { border-radius:0 4px 4px 0; }
        .games-table tr.game-row:hover td { background:var(--bg2); }
        .game-thumb { width:64px; height:44px; object-fit:cover; border-radius:3px; background:var(--bg2); display:block; }
        .game-thumb-ph { width:64px; height:44px; background:var(--bg2); border-radius:3px; display:flex; align-items:center; justify-content:center; font-size:1.3rem; }
        .price-tag { background:#4c6b22; color:#a4d007; border-radius:2px; padding:2px 8px; font-weight:700; font-size:0.78rem; }
        .price-free { color:#a4d007; font-weight:700; font-size:0.78rem; }
        .cat-tag { background:rgba(102,192,244,0.1); color:var(--accent); border-radius:2px; padding:1px 6px; font-size:0.72rem; margin-right:3px; }
        .file-badge { font-size:0.7rem; background:rgba(102,192,244,0.08); color:var(--accent); border:1px solid rgba(102,192,244,0.2); border-radius:2px; padding:1px 6px; white-space:nowrap; }
        .tbl-btn { font-size:0.78rem; padding:4px 12px; border-radius:2px; text-decoration:none; border:1px solid; transition:all 0.15s; display:inline-block; }
        .tbl-btn-edit { color:var(--accent); border-color:rgba(102,192,244,0.35); }
        .tbl-btn-edit:hover { background:rgba(102,192,244,0.1); color:var(--accent); }
        .tbl-btn-del { color:#fc8181; border-color:rgba(239,68,68,0.35); }
        .tbl-btn-del:hover { background:rgba(239,68,68,0.1); color:#fc8181; }
        .count-label { color:var(--text2); font-size:0.82rem; }
        .alert-ok { background:rgba(164,208,7,0.1); border:1px solid rgba(164,208,7,0.3); color:#a4d007; border-radius:3px; padding:10px 16px; margin-bottom:16px; font-size:0.88rem; }
        .empty-row td { text-align:center; padding:48px; color:var(--text2); border-radius:4px; }
    </style>
</head>
<body>
<nav class="dev-nav">
    <a href="/Developer/Dashboard" class="dev-nav-brand">Game<span>Store</span> <span style="color:var(--text2);font-size:0.8rem;font-weight:400;">Dev Portal</span></a>
    <div class="nav-links">
        <a href="/Developer/AddGame" class="nav-btn primary">+ Add Game</a>
        <a href="/Developer/Dashboard" class="nav-btn">Dashboard</a>
        <a href="/Auth/Logout" class="nav-btn danger">Logout</a>
    </div>
</nav>

<div class="page-wrap">
    @if (TempData["StatusMessage"] != null)
    { <div class="alert-ok">✓ @TempData["StatusMessage"]</div> }

    <div class="page-top">
        <div>
            <h1><i class="bi bi-folder"></i> Manage Games</h1>
            <div class="count-label">@Model.Games.Count game(s) total</div>
        </div>
        <div class="top-controls">
            <div class="search-wrap">
                <span class="search-icon"><i class="bi bi-search"></i></span>
                <input type="text" class="gs-search" placeholder="Search…" oninput="filterRows(this.value)"/>
            </div>
            <select class="gs-filter" onchange="filterFile(this.value)">
                <option value="">All</option>
                <option value="file">Has File</option>
                <option value="nofile">No File</option>
                <option value="free">Free</option>
                <option value="paid">Paid</option>
            </select>
        </div>
    </div>

    <table class="games-table" id="gamesTable">
        <thead>
            <tr>
                <th></th>
                <th>Title</th>
                <th>Developer</th>
                <th>Price</th>
                <th>Categories</th>
                <th>File</th>
                <th>Release</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="gamesBody">
            @if (!Model.Games.Any())
            {
                <tr class="empty-row">
                    <td colspan="8">No games yet. <a href="/Developer/AddGame" style="color:var(--accent);">Publish your first →</a></td>
                </tr>
            }
            else
            {
                @foreach (var game in Model.Games)
                {
                    var thumbSrc = game.CoverImageUrl ?? game.ScreenshotUrls.FirstOrDefault();
                    <tr class="game-row"
                        data-title="@game.Title.ToLower()"
                        data-price="@game.Price"
                        data-hasfile="@(game.GameFileUrl != null ? "1" : "0")">
                        <td>
                            @if (thumbSrc != null)
                            { <img src="@thumbSrc" class="game-thumb" alt=""/> }
                            else
                            { <div class="game-thumb-ph"><i class="bi bi-controller"></i></div> }
                        </td>
                        <td style="font-weight:600;color:var(--bright);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@game.Title</td>
                        <td style="color:var(--text2);font-size:0.82rem;">@(game.Developer ?? "—")</td>
                        <td>
                            @if (game.Price == 0) { <span class="price-free">Free</span> }
                            else { <span class="price-tag">$@game.Price.ToString("F2")</span> }
                        </td>
                        <td style="max-width:160px;">
                            @foreach (var gc in game.GameCategories.Take(3))
                            { <span class="cat-tag">@gc.Category.Name</span> }
                        </td>
                        <td>
                            @if (game.GameFileUrl != null)
                            {
                                var fn = game.GameFileName ?? "file";
                                <span class="file-badge" title="@fn"><i class="bi bi-box-seam"></i> @(fn.Length > 14 ? fn[..11] + "…" : fn)</span>
                            }
                            else
                            { <span style="color:var(--text2);font-size:0.8rem;">—</span> }
                        </td>
                        <td style="color:var(--text2);font-size:0.8rem;white-space:nowrap;">@game.ReleaseDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            <div style="display:flex;gap:6px;flex-wrap:nowrap;">
                                <a href="/Developer/EditGame?id=@game.Id" class="tbl-btn tbl-btn-edit">Edit</a>
                                <a href="/Developer/DeleteGame?id=@game.Id" class="tbl-btn tbl-btn-del">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<script>
    function filterRows(q) {
        q = q.toLowerCase();
        document.querySelectorAll('.game-row').forEach(r => {
            r.style.display = r.dataset.title.includes(q) ? '' : 'none';
        });
    }
    function filterFile(v) {
        document.querySelectorAll('.game-row').forEach(r => {
            let show = true;
            if (v === 'file') show = r.dataset.hasfile === '1';
            else if (v === 'nofile') show = r.dataset.hasfile === '0';
            else if (v === 'free') show = parseFloat(r.dataset.price) === 0;
            else if (v === 'paid') show = parseFloat(r.dataset.price) > 0;
            r.style.display = show ? '' : 'none';
        });
    }
</script>
</body>
</html>
