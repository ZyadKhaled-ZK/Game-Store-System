@page
@model GameStore.PL.Pages.Developer.DeleteGameModel
@{
    ViewData["Title"] = "Delete Game";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Delete Game — Dev Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <style>
        :root { --bg:#1b2838; --bg3:#1e2a39; --accent:#66c0f4; --border:rgba(102,192,244,0.15); --text:#c6d4df; --text2:#8f98a0; --bright:#fff; }
        body { background:var(--bg); color:var(--text); font-family:Arial,sans-serif; margin:0; min-height:100vh; display:flex; align-items:center; justify-content:center; }
        .confirm-card { background:var(--bg3); border:1px solid rgba(239,68,68,0.3); border-radius:4px; max-width:460px; width:90%; padding:0; overflow:hidden; }
        .confirm-img { width:100%; height:180px; object-fit:cover; display:block; }
        .confirm-img-ph { width:100%; height:180px; background:linear-gradient(135deg,#1b2838,#2a475e); display:flex; align-items:center; justify-content:center; font-size:4rem; }
        .confirm-body { padding:28px 28px 24px; text-align:center; }
        h3 { color:#fc8181; font-size:1.3rem; margin-bottom:8px; }
        p { color:var(--text2); font-size:0.9rem; line-height:1.6; }
        strong { color:var(--bright); }
        .btn-cancel { background:var(--bg3); border:1px solid rgba(255,255,255,0.1); color:var(--text2); border-radius:3px; padding:8px 20px; text-decoration:none; font-size:0.88rem; transition:all 0.15s; }
        .btn-cancel:hover { border-color:var(--accent); color:var(--text); }
        .btn-del { background:linear-gradient(135deg,#7f1d1d,#991b1b); border:none; color:#fca5a5; border-radius:3px; padding:8px 20px; font-size:0.88rem; font-weight:600; cursor:pointer; transition:opacity 0.15s; }
        .btn-del:hover { opacity:0.85; }
    </style>
</head>
<body>
<div class="confirm-card">
    @{
        var thumbSrc = Model.GameCoverUrl ?? Model.GameScreenshot;
    }
    @if (thumbSrc != null)
    { <img src="@thumbSrc" class="confirm-img" alt=""/> }
    else
    { <div class="confirm-img-ph"><i class="bi bi-controller"></i></div> }

    <div class="confirm-body">
        <h3>Delete Game?</h3>
        <p>You're about to permanently delete <strong>@Model.GameTitle</strong>. This will remove all screenshots and the game file. This cannot be undone.</p>
        <div style="display:flex;gap:10px;justify-content:center;margin-top:20px;">
            <a href="/Developer/ManageGames" class="btn-cancel">Cancel</a>
            <form method="post" asp-route-id="@Model.GameId" style="margin:0;">
                <button type="submit" class="btn-del"><i class="bi bi-trash3"></i> Delete Forever</button>
            </form>
        </div>
    </div>
</div>
</body>
</html>
