@page
@model GameStore.PL.Pages.Developer.AddGameModel
@{
    ViewData["Title"] = "Add Game";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Add Game — Dev Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <style>
        :root { --bg:#1b2838; --bg2:#16202d; --bg3:#1e2a39; --accent:#66c0f4; --border:rgba(102,192,244,0.15); --text:#c6d4df; --text2:#8f98a0; --bright:#fff; }
        body { background:var(--bg); color:var(--text); font-family:Arial,sans-serif; margin:0; }
        .dev-nav { background:#171a21; border-bottom:1px solid rgba(0,0,0,0.5); padding:0 24px; height:52px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; }
        .dev-nav-brand { font-weight:700; color:var(--bright); font-size:1rem; text-decoration:none; }
        .dev-nav-brand span { color:var(--accent); }
        .nav-links { display:flex; gap:6px; align-items:center; }
        .nav-btn { color:var(--text2); text-decoration:none; padding:5px 12px; border-radius:3px; font-size:0.85rem; transition:all 0.15s; border:1px solid transparent; }
        .nav-btn:hover { color:var(--bright); background:rgba(255,255,255,0.06); }
        .nav-btn.primary { background:linear-gradient(135deg,#4a90d9,#2d6aa0); color:white; border:none; }
        .page-wrap { max-width:960px; margin:32px auto; padding:0 24px 60px; }
        .page-header { margin-bottom:28px; }
        .page-header h1 { font-size:1.5rem; font-weight:700; color:var(--bright); margin-bottom:4px; }
        .page-header p { color:var(--text2); font-size:0.88rem; }
        .card-section { background:var(--bg3); border:1px solid var(--border); border-radius:4px; padding:24px 28px; margin-bottom:16px; }
        .section-label { font-size:0.72rem; text-transform:uppercase; letter-spacing:2px; color:var(--accent); margin-bottom:20px; font-weight:600; }
        label.form-label { color:var(--text); font-size:0.88rem; font-weight:600; margin-bottom:5px; }
        .form-control, .form-select { background:var(--bg2); border:1px solid rgba(255,255,255,0.1); color:var(--text); border-radius:3px; font-size:0.88rem; }
        .form-control:focus, .form-select:focus { background:var(--bg2); border-color:var(--accent); color:var(--bright); box-shadow:0 0 0 2px rgba(102,192,244,0.2); }
        .form-control::placeholder { color:var(--text2); }
        .input-group-text { background:var(--bg2); border:1px solid rgba(255,255,255,0.1); color:var(--text2); border-radius:3px 0 0 3px; }
        .hint { color:var(--text2); font-size:0.78rem; margin-top:4px; }
        .cat-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(140px,1fr)); gap:8px; }
        .cat-item { background:var(--bg2); border:1px solid rgba(255,255,255,0.1); border-radius:3px; padding:8px 12px; display:flex; align-items:center; gap:8px; cursor:pointer; transition:all 0.15s; }
        .cat-item:hover { border-color:var(--accent); }
        .cat-item input[type=checkbox] { accent-color:var(--accent); width:15px; height:15px; }
        .cat-item input:checked + span { color:var(--accent); font-weight:600; }
        .cat-item span { font-size:0.85rem; }
        .drop-zone { border:1px dashed rgba(102,192,244,0.35); border-radius:4px; background:rgba(102,192,244,0.03); padding:20px; text-align:center; transition:all 0.15s; position:relative; }
        .drop-zone:hover { border-color:var(--accent); background:rgba(102,192,244,0.06); }
        .drop-zone input[type=file] { position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%; }
        .drop-icon { font-size:1.8rem; margin-bottom:6px; }
        .drop-label { color:var(--text); font-size:0.88rem; font-weight:600; }
        .drop-hint { color:var(--text2); font-size:0.78rem; margin-top:3px; }
        .drop-selected { color:var(--accent); font-size:0.82rem; margin-top:6px; font-weight:600; }
        .file-drop-zone { border:2px dashed rgba(102,192,244,0.4); border-radius:4px; background:rgba(102,192,244,0.04); padding:28px 20px; text-align:center; position:relative; transition:all 0.15s; }
        .file-drop-zone:hover { border-color:var(--accent); background:rgba(102,192,244,0.08); }
        .file-drop-zone input[type=file] { position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%; }
        .file-drop-icon { font-size:2.5rem; margin-bottom:8px; }
        .file-drop-label { color:var(--bright); font-size:0.95rem; font-weight:600; margin-bottom:4px; }
        .file-drop-hint { color:var(--text2); font-size:0.82rem; }
        .file-selected-info { display:none; background:rgba(102,192,244,0.08); border:1px solid rgba(102,192,244,0.25); border-radius:4px; padding:12px 16px; margin-top:12px; }
        .file-selected-info.show { display:flex; align-items:center; gap:12px; }
        .btn-publish { background:linear-gradient(135deg,#4c6b22,#5a7a28); color:#a4d007; border:none; font-weight:700; padding:10px 28px; font-size:0.95rem; border-radius:3px; cursor:pointer; transition:opacity 0.15s; }
        .btn-publish:hover { opacity:0.88; }
        .btn-publish:disabled { opacity:0.4; cursor:not-allowed; }
        .alert-gs-err { background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); color:#fca5a5; border-radius:3px; padding:10px 16px; margin-bottom:16px; font-size:0.88rem; }
        .alert-gs-ok { background:rgba(164,208,7,0.1); border:1px solid rgba(164,208,7,0.3); color:#a4d007; border-radius:3px; padding:10px 16px; margin-bottom:16px; font-size:0.88rem; }
    </style>
</head>
<body>
<nav class="dev-nav">
    <a href="/Developer/Dashboard" class="dev-nav-brand">Game<span>Store</span> <span style="color:var(--text2);font-size:0.8rem;font-weight:400;">Dev Portal</span></a>
    <div class="nav-links">
        <a href="/Developer/ManageGames" class="nav-btn">Manage Games</a>
        <a href="/Developer/Dashboard" class="nav-btn">Dashboard</a>
        <a href="/Auth/Logout" class="nav-btn" style="color:#fc8181;">Logout</a>
    </div>
</nav>

<div class="page-wrap">
    <div class="page-header">
        <h1><i class="bi bi-plus-circle"></i> Publish New Game</h1>
        <p>Fill in all details and upload your game files. All fields marked * are required.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert-gs-err">⚠ @Model.ErrorMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert-gs-ok">✓ @Model.StatusMessage</div>
    }

    <form method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="alert-gs-err" style="display:none;"></div>

        <!-- CORE DETAILS -->
        <div class="card-section">
            <div class="section-label"><i class="bi bi-clipboard"></i> Core Details</div>
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Input.Title" class="form-label">Game Title *</label>
                    <input asp-for="Input.Title" class="form-control" placeholder="e.g. Shadow Realm Chronicles" autocomplete="off"/>
                    <span asp-validation-for="Input.Title" class="text-danger" style="font-size:0.78rem;"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.Developer" class="form-label">Developer / Studio *</label>
                    <input asp-for="Input.Developer" class="form-control" placeholder="e.g. Dark Pixel Studios" autocomplete="off"/>
                    <span asp-validation-for="Input.Developer" class="text-danger" style="font-size:0.78rem;"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Price *</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Input.Price" type="number" step="0.01" min="0" class="form-control" placeholder="0.00"/>
                    </div>
                    <div class="hint">Use 0 for free games</div>
                    <span asp-validation-for="Input.Price" class="text-danger" style="font-size:0.78rem;"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.ReleaseDate" class="form-label">Release Date *</label>
                    <input asp-for="Input.ReleaseDate" type="date" class="form-control"/>
                    <span asp-validation-for="Input.ReleaseDate" class="text-danger" style="font-size:0.78rem;"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.TrailerUrl" class="form-label">YouTube Trailer URL</label>
                    <input asp-for="Input.TrailerUrl" class="form-control" placeholder="https://youtu.be/..."/>
                    <span asp-validation-for="Input.TrailerUrl" class="text-danger" style="font-size:0.78rem;"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Input.Description" class="form-label">Description *</label>
                    <textarea asp-for="Input.Description" class="form-control" rows="5" placeholder="Describe your game — story, gameplay, features…"></textarea>
                    <span asp-validation-for="Input.Description" class="text-danger" style="font-size:0.78rem;"></span>
                </div>
            </div>
        </div>

        <!-- CATEGORIES -->
        <div class="card-section">
            <div class="section-label"><i class="bi bi-tags"></i> Categories *</div>
            @if (Model.AvailableCategories.Any())
            {
                <div class="cat-grid">
                    @foreach (var cat in Model.AvailableCategories)
                    {
                        <label class="cat-item">
                            <input type="checkbox" name="Input.SelectedCategoryIds" value="@cat.Id"/>
                            <span>@cat.Name</span>
                        </label>
                    }
                </div>
                <span asp-validation-for="Input.SelectedCategoryIds" class="text-danger" style="font-size:0.78rem;display:block;margin-top:8px;"></span>
            }
            else
            {
                <div style="color:#fc8181;font-size:0.85rem;">No categories found. Add them via database seeder.</div>
            }
        </div>

        <!-- GAME FILE -->
        <div class="card-section">
            <div class="section-label"><i class="bi bi-box-seam"></i> Game File (Executable / Archive)</div>
            <div class="file-drop-zone" id="fileDropZone">
                <input asp-for="Input.GameFile" type="file" accept=".exe,.zip,.rar,.7z,.msi,.apk,.tar.gz" id="gameFileInput" onchange="onGameFileChange(this)"/>
                <div class="file-drop-icon"><i class="bi bi-box-seam"></i></div>
                <div class="file-drop-label">Drop your game file here or click to browse</div>
                <div class="file-drop-hint">.exe · .zip · .rar · .7z · .msi · .apk — max 2 GB</div>
            </div>
            <div class="file-selected-info" id="fileInfo">
                <span style="font-size:1.8rem;"><i class="bi bi-box-seam"></i></span>
                <div>
                    <div id="fileInfoName" style="font-weight:600;color:var(--bright);"></div>
                    <div id="fileInfoSize" style="font-size:0.78rem;color:var(--text2);"></div>
                </div>
            </div>
        </div>

        <!-- MEDIA -->
        <div class="card-section">
            <div class="section-label"><i class="bi bi-image"></i> Media</div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Cover Image (Hero Thumbnail)</label>
                    <div class="drop-zone" id="coverZone">
                        <input asp-for="Input.CoverImage" type="file" accept="image/*" id="coverInput" onchange="onCoverChange(this)"/>
                        <div class="drop-icon"><i class="bi bi-image"></i></div>
                        <div class="drop-label">Cover / hero image</div>
                        <div class="drop-hint">PNG, JPG, WebP — shown on store card</div>
                        <div class="drop-selected" id="coverSelected"></div>
                    </div>
                    <div id="coverPreviewWrap" style="display:none;margin-top:10px;">
                        <img id="coverPreview" style="max-width:100%;border-radius:4px;border:1px solid var(--border);max-height:160px;object-fit:cover;"/>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Screenshots (multiple)</label>
                    <div class="drop-zone">
                        <input asp-for="Input.Images" type="file" multiple accept="image/*" id="screenshotsInput" onchange="onScreenshotsChange(this)"/>
                        <div class="drop-icon"><i class="bi bi-camera"></i></div>
                        <div class="drop-label">Upload screenshots</div>
                        <div class="drop-hint">PNG, JPG, WebP — multiple allowed</div>
                        <div class="drop-selected" id="screenshotsSelected"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center">
            <div class="hint">All required fields (*) must be filled before publishing.</div>
            <button type="submit" class="btn-publish" @(Model.AvailableCategories.Any() ? "" : "disabled")>
                <i class="bi bi-rocket-takeoff"></i> Publish Game
            </button>
        </div>
    </form>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script>
    function fmtSize(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + ' KB';
        if (bytes < 1024*1024*1024) return (bytes/(1024*1024)).toFixed(1) + ' MB';
        return (bytes/(1024*1024*1024)).toFixed(2) + ' GB';
    }

    function onGameFileChange(input) {
        if (input.files.length > 0) {
            const f = input.files[0];
            document.getElementById('fileInfoName').textContent = f.name;
            document.getElementById('fileInfoSize').textContent = fmtSize(f.size);
            document.getElementById('fileInfo').classList.add('show');
            document.querySelector('#fileDropZone .file-drop-label').textContent = 'File selected ✓';
        }
    }

    function onCoverChange(input) {
        if (input.files.length > 0) {
            const f = input.files[0];
            document.getElementById('coverSelected').textContent = f.name;
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('coverPreview').src = e.target.result;
                document.getElementById('coverPreviewWrap').style.display = '';
            };
            reader.readAsDataURL(f);
        }
    }

    function onScreenshotsChange(input) {
        const count = input.files.length;
        document.getElementById('screenshotsSelected').textContent = count > 0 ? `${count} file(s) selected` : '';
    }
</script>
</body>
</html>
