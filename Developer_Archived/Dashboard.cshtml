@page
@model GameStore.PL.Pages.Developer.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Developer Dashboard — GameStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <style>
        :root { --bg:#1b2838; --bg2:#16202d; --bg3:#1e2a39; --accent:#66c0f4; --border:rgba(102,192,244,0.15); --text:#c6d4df; --text2:#8f98a0; --bright:#fff; }
        * { box-sizing:border-box; }
        body { background:var(--bg); color:var(--text); font-family:Arial,sans-serif; margin:0; min-height:100vh; }
        .dev-nav { background:#171a21; border-bottom:1px solid rgba(0,0,0,0.5); padding:0 24px; height:52px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; }
        .dev-nav-brand { font-weight:700; color:var(--bright); font-size:1rem; text-decoration:none; }
        .dev-nav-brand span { color:var(--accent); }
        .nav-links { display:flex; gap:6px; align-items:center; }
        .nav-btn { color:var(--text2); text-decoration:none; padding:5px 12px; border-radius:3px; font-size:0.85rem; transition:all 0.15s; }
        .nav-btn:hover { color:var(--bright); background:rgba(255,255,255,0.06); }
        .nav-btn.danger { color:#fc8181; }
        .nav-btn.danger:hover { background:rgba(239,68,68,0.1); }
        .page-wrap { max-width:1200px; margin:0 auto; padding:32px 24px 60px; }
        .welcome { margin-bottom:28px; }
        .welcome h1 { font-size:1.6rem; font-weight:700; color:var(--bright); margin-bottom:4px; }
        .welcome p { color:var(--text2); font-size:0.88rem; }
        /* STATS */
        .stats-row { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:12px; margin-bottom:28px; }
        .stat-card { background:var(--bg3); border:1px solid var(--border); border-radius:4px; padding:20px; text-align:center; }
        .stat-num { font-size:2.2rem; font-weight:700; color:var(--accent); line-height:1; margin-bottom:4px; }
        .stat-num.green { color:#a4d007; }
        .stat-num.orange { color:#e8a838; }
        .stat-label { font-size:0.78rem; color:var(--text2); text-transform:uppercase; letter-spacing:1px; }
        /* ACTIONS */
        .section-title { font-size:0.72rem; text-transform:uppercase; letter-spacing:2px; color:var(--text2); margin-bottom:12px; font-weight:600; }
        .actions-row { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:10px; margin-bottom:28px; }
        .action-card { background:var(--bg3); border:1px solid var(--border); border-radius:4px; padding:16px 20px; display:flex; align-items:center; gap:14px; text-decoration:none; color:var(--text); transition:all 0.15s; }
        .action-card:hover { border-color:var(--accent); color:var(--bright); background:var(--bg2); transform:translateY(-1px); }
        .action-icon { font-size:1.6rem; flex-shrink:0; }
        .action-title { font-weight:600; font-size:0.9rem; color:var(--bright); }
        .action-desc { font-size:0.78rem; color:var(--text2); }
        /* RECENT GAMES TABLE */
        .games-table { width:100%; border-collapse:separate; border-spacing:0 4px; }
        .games-table th { font-size:0.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--text2); padding:6px 12px; font-weight:600; text-align:left; }
        .games-table td { background:var(--bg3); padding:12px; font-size:0.88rem; vertical-align:middle; }
        .games-table tr td:first-child { border-radius:4px 0 0 4px; }
        .games-table tr td:last-child { border-radius:0 4px 4px 0; }
        .game-thumb { width:52px; height:38px; object-fit:cover; border-radius:3px; background:var(--bg2); display:block; }
        .game-thumb-placeholder { width:52px; height:38px; background:var(--bg2); border-radius:3px; display:flex; align-items:center; justify-content:center; font-size:1.2rem; }
        .price-tag { background:#4c6b22; color:#a4d007; border-radius:2px; padding:1px 8px; font-weight:700; font-size:0.8rem; display:inline-block; }
        .price-free { color:#a4d007; font-weight:700; font-size:0.8rem; }
        .tbl-btn { font-size:0.78rem; padding:3px 10px; border-radius:2px; text-decoration:none; border:1px solid; transition:all 0.15s; }
        .tbl-btn-edit { color:var(--accent); border-color:rgba(102,192,244,0.35); }
        .tbl-btn-edit:hover { background:rgba(102,192,244,0.1); color:var(--accent); }
        .tbl-btn-del { color:#fc8181; border-color:rgba(239,68,68,0.35); }
        .tbl-btn-del:hover { background:rgba(239,68,68,0.1); color:#fc8181; }
        .file-badge { font-size:0.72rem; background:rgba(102,192,244,0.1); color:var(--accent); border:1px solid rgba(102,192,244,0.2); border-radius:2px; padding:1px 6px; }
        .empty-row td { background:var(--bg3); text-align:center; padding:32px; color:var(--text2); border-radius:4px; }
        .alert-ok { background:rgba(164,208,7,0.1); border:1px solid rgba(164,208,7,0.3); color:#a4d007; border-radius:3px; padding:10px 16px; margin-bottom:20px; font-size:0.88rem; }
    </style>
</head>
<body>
<nav class="dev-nav">
    <a href="/Developer/Dashboard" class="dev-nav-brand">Game<span>Store</span> <span style="color:var(--text2);font-size:0.8rem;font-weight:400;">Dev Portal</span></a>
    <div class="nav-links">
        <span style="color:var(--text2);font-size:0.82rem;"><i class="bi bi-person"></i> @Model.Username</span>
        <a href="/" class="nav-btn"><i class="bi bi-globe"></i> Store</a>
        <a href="/Auth/Logout" class="nav-btn danger">Logout</a>
    </div>
</nav>

<div class="page-wrap">
    @if (TempData["StatusMessage"] != null)
    {
        <div class="alert-ok">✓ @TempData["StatusMessage"]</div>
    }

    <div class="welcome">
        <h1>Welcome back, @Model.Username</h1>
        <p>Manage your game store from here — add, edit, or remove games anytime.</p>
    </div>

    <!-- STATS -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-num">@Model.TotalGames</div>
            <div class="stat-label">Total Games</div>
        </div>
        <div class="stat-card">
            <div class="stat-num green">@Model.FreeGames</div>
            <div class="stat-label">Free Games</div>
        </div>
        <div class="stat-card">
            <div class="stat-num orange">@Model.GamesWithFiles</div>
            <div class="stat-label">With Downloads</div>
        </div>
        <div class="stat-card">
            <div class="stat-num">@Model.TotalCategories</div>
            <div class="stat-label">Categories</div>
        </div>
    </div>

    <!-- QUICK ACTIONS -->
    <div class="section-title">Quick Actions</div>
    <div class="actions-row">
        <a href="/Developer/AddGame" class="action-card">
            <div class="action-icon"><i class="bi bi-plus-circle"></i></div>
            <div>
                <div class="action-title">Add New Game</div>
                <div class="action-desc">Publish a game to the store</div>
            </div>
        </a>
        <a href="/Developer/ManageGames" class="action-card">
            <div class="action-icon"><i class="bi bi-folder"></i></div>
            <div>
                <div class="action-title">Manage Games</div>
                <div class="action-desc">Edit or remove existing games</div>
            </div>
        </a>
        <a href="/" class="action-card" target="_blank">
            <div class="action-icon"><i class="bi bi-globe"></i></div>
            <div>
                <div class="action-title">View Storefront</div>
                <div class="action-desc">See the public-facing store</div>
            </div>
        </a>
    </div>

    <!-- RECENT GAMES -->
    <div class="section-title">Recently Added</div>
    <table class="games-table">
        <thead>
            <tr>
                <th></th>
                <th>Title</th>
                <th>Developer</th>
                <th>Price</th>
                <th>File</th>
                <th>Release</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.RecentGames.Any())
            {
                <tr class="empty-row">
                    <td colspan="7">No games yet. <a href="/Developer/AddGame" style="color:var(--accent);">Add your first →</a></td>
                </tr>
            }
            else
            {
                @foreach (var game in Model.RecentGames)
                {
                    <tr>
                        <td>
                            @{
                                var thumbSrc = game.CoverImageUrl ?? game.ScreenshotUrls.FirstOrDefault();
                            }
                            @if (thumbSrc != null)
                            {
                                <img src="@thumbSrc" class="game-thumb" alt=""/>
                            }
                            else
                            {
                                <div class="game-thumb-placeholder"><i class="bi bi-controller"></i></div>
                            }
                        </td>
                        <td style="font-weight:600;color:var(--bright);">@game.Title</td>
                        <td style="color:var(--text2);">@(game.Developer ?? "—")</td>
                        <td>
                            @if (game.Price == 0)
                            { <span class="price-free">Free</span> }
                            else
                            { <span class="price-tag">$@game.Price.ToString("F2")</span> }
                        </td>
                        <td>
                            @if (game.GameFileUrl != null)
                            { <span class="file-badge"><i class="bi bi-box-seam"></i> @(game.GameFileName != null && game.GameFileName.Length > 16 ? game.GameFileName[..13]+"…" : game.GameFileName)</span> }
                            else
                            { <span style="color:var(--text2);font-size:0.8rem;">—</span> }
                        </td>
                        <td style="color:var(--text2);font-size:0.82rem;">@game.ReleaseDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            <div style="display:flex;gap:6px;">
                                <a href="/Developer/EditGame?id=@game.Id" class="tbl-btn tbl-btn-edit">Edit</a>
                                <a href="/Developer/DeleteGame?id=@game.Id" class="tbl-btn tbl-btn-del">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    @if (Model.TotalGames > 5)
    {
        <div style="text-align:center;margin-top:14px;">
            <a href="/Developer/ManageGames" style="color:var(--accent);font-size:0.88rem;text-decoration:none;">View all @Model.TotalGames games →</a>
        </div>
    }
</div>
</body>
</html>
