@model ManageGamesViewModel
@{
    ViewData["Title"] = "Game Database";
}

<style>
  .page-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 16px; margin-bottom: 32px; }
  .filter-bar { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 24px; }
  .gs-search-input {
    background: var(--bg2); border: 1px solid var(--border-red); color: var(--text);
    padding: 10px 16px; font-family: var(--font-mono); font-size: 12px; width: 300px; outline: none;
  }
  .gs-search-input:hover { border-color: var(--red-dim); }
  .gs-search-input:focus { border-color: var(--red); box-shadow: var(--glow-red); }
  .gs-search-input::placeholder { color: var(--text-dim); }

  .game-row { transition: background 0.2s; }
  .game-row:hover td { color: white; }
  .game-row td { transition: color 0.2s; }

  .cover-thumb {
    width: 60px; height: 40px; object-fit: cover; border: 1px solid var(--border-red);
    display: block; background: var(--bg3);
  }
  .cover-placeholder {
    width: 60px; height: 40px; background: var(--bg3); border: 1px solid var(--border-red);
    display: flex; align-items: center; justify-content: center; color: var(--red); font-size: 18px;
  }

  .categories-list { display: flex; flex-wrap: wrap; gap: 4px; }
  .cat-tag {
    font-family: var(--font-mono); font-size: 10px; padding: 2px 8px;
    background: rgba(230,57,70,0.1); border: 1px solid var(--border-red); color: var(--red);
    text-transform: uppercase; letter-spacing: 1px;
  }
  .price-val { font-family: var(--font-display); font-weight: 700; color: var(--gold); }
  .price-free { color: var(--text-dim); font-style: italic; }

  .modal-overlay {
    display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85);
    z-index: 5000; align-items: center; justify-content: center; padding: 20px;
  }
  .modal-overlay.active { display: flex; }
  .modal-box {
    background: var(--bg2); border: 1px solid var(--border-red); padding: 40px;
    width: 100%; max-width: 600px; max-height: 90vh; overflow-y: auto;
    box-shadow: var(--glow-red); position: relative;
  }
  .modal-title { font-family: var(--font-display); font-size: 1.4rem; font-weight: 900; color: white; margin-bottom: 8px; letter-spacing: 2px; }
  .modal-tag { font-family: var(--font-mono); font-size: 11px; color: var(--red); letter-spacing: 2px; margin-bottom: 28px; }
  .modal-close {
    position: absolute; top: 16px; right: 20px; background: none; border: none;
    color: var(--text-dim); font-size: 22px; cursor: pointer; line-height: 1;
    transition: color 0.2s;
  }
  .modal-close:hover { color: var(--red); }

  .form-group { margin-bottom: 18px; }
  .form-label { font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); letter-spacing: 1px; margin-bottom: 6px; display: block; text-transform: uppercase; }
  .form-input, .form-textarea, .form-select-field {
    width: 100%; background: var(--bg3); border: 1px solid var(--border-red);
    color: var(--text); padding: 10px 14px; font-family: var(--font-ui); font-size: 14px;
    outline: none; transition: all 0.2s;
  }
  .form-input:hover, .form-textarea:hover, .form-select-field:hover { border-color: var(--red-dim); }
  .form-input:focus, .form-textarea:focus, .form-select-field:focus { border-color: var(--red); box-shadow: var(--glow-red); }
  .form-textarea { resize: vertical; min-height: 90px; }
  .form-select-field option { background: var(--bg2); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .checkbox-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .checkbox-item { display: flex; align-items: center; gap: 8px; }
  .checkbox-item input[type="checkbox"] { accent-color: var(--red); width: 14px; height: 14px; cursor: pointer; }
  .checkbox-item label { font-family: var(--font-mono); font-size: 12px; color: var(--text); cursor: pointer; }
  @@media (max-width: 768px) {
    .page-header { flex-direction: column; align-items: stretch !important; }
    .page-header .btn { width: 100%; text-align: center; }
    .filter-bar { flex-direction: column; }
    .filter-bar select, .filter-bar .btn { width: 100%; }
    .gs-search-input { width: 100%; }
    .form-row { grid-template-columns: 1fr; }
    .modal-box { padding: 24px; }
    .cover-thumb, .cover-placeholder { width: 40px; height: 28px; font-size: 14px; }
  }
  @@media (max-width: 576px) {
    .modal-box { padding: 16px; }
    .gs-search-input { font-size: 11px; padding: 8px 12px; }
    .cat-tag { font-size: 8px; padding: 1px 6px; }
  }
</style>

@{
    var createUrl = Url.Action("Create", "Games", new { area = "Admin" });
    var editUrl = Url.Action("Edit", "Games", new { area = "Admin" });
}

<div class="page-header">
  <div>
    <div class="section-tag">Content Control</div>
    <h2 class="section-title glitch">GAME DATABASE</h2>
  </div>
  <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Dashboard</a>
    <button class="btn btn-primary" onclick="openModal()">+ ADD GAME</button>
  </div>
</div>

<div class="filter-bar">
  <input type="text" id="searchInput" class="gs-search-input" placeholder="Search games by title or developer..."/>
  <span style="font-family:var(--font-mono); font-size:12px; color:var(--text-dim);">
    [ <span id="gameCount">@Model.Games.Count</span> RECORDS ]
  </span>
</div>

@{ if (!string.IsNullOrEmpty(Model.Message)) { TempData["Message"] = Model.Message; TempData["IsError"] = Model.IsError; } }
<partial name="_Alert" />

<div class="table-responsive">
<table class="cyber-table" id="gamesTable">
  <thead>
    <tr>
      <th>Cover</th>
      <th>Title</th>
      <th>Developer</th>
      <th>Categories</th>
      <th>Price</th>
      <th>Release</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    @{ int gameIdx = 0; }
    @foreach (var game in Model.Games)
    {
      <tr class="game-row" data-search="@game.Title.ToLower() @(game.Developer ?? "").ToLower()">
        <td>
          @if (!string.IsNullOrEmpty(game.CoverImageUrl))
          {
            <img src="@game.CoverImageUrl" alt="@game.Title" class="cover-thumb" loading="lazy" width="60" height="40"/>
          }
          else
          {
            <div class="cover-placeholder"><i class="bi bi-play-fill"></i></div>
          }
        </td>
        <td style="font-family: var(--font-display); font-size: 13px; font-weight: 700; color: white; max-width: 200px;">
          @game.Title
        </td>
        <td style="color: var(--text-dim); font-size: 13px;">@(game.Developer ?? "—")</td>
        <td>
          <div class="categories-list">
            @foreach (var gc in game.GameCategories.Take(3))
            {
              <span class="cat-tag">@gc.Category?.Name</span>
            }
            @if (game.GameCategories.Count > 3)
            {
              <span class="cat-tag" style="color: var(--text-dim);">+@(game.GameCategories.Count - 3)</span>
            }
          </div>
        </td>
        <td>
          @if (game.Price == 0)
          {
            <span class="price-free">FREE</span>
          }
          else
          {
            <span class="price-val">$@game.Price.ToString("N2")</span>
          }
        </td>
        <td style="font-family: var(--font-mono); font-size: 12px; color: var(--text-dim);">@game.ReleaseDate.ToString("yyyy-MM-dd")</td>
        <td>
          <button class="btn btn-secondary ripple" style="padding:6px 12px; font-size:11px;"
            data-game-index="@(gameIdx++)" onclick="openEditModal(+this.dataset.gameIndex)">EDIT</button>
          <form method="post" asp-action="Delete" asp-route-id="@game.Id" style="display:inline;"
            data-game-title="@game.Title" onsubmit="event.preventDefault(); showConfirmModal('TERMINATE game record: ' + this.dataset.gameTitle + '?', this)">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary ripple" style="padding:6px 12px; font-size:11px;">DELETE</button>
          </form>
        </td>
      </tr>
    }
  </tbody>
</table>
</div>

@if (!Model.Games.Any())
{
  <div style="text-align:center; padding:80px; font-family:var(--font-mono); color:var(--text-dim);">
    [ NO GAMES IN DATABASE ]
  </div>
}

<!-- ADD/EDIT MODAL -->
<div class="modal-overlay" id="gameModal">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal()">&times;</button>
    <div class="modal-title" id="modalTitle">ADD GAME</div>
    <div class="modal-tag" id="modalTag">> NEW RECORD INJECTION</div>

    <form method="post" id="gameForm" enctype="multipart/form-data">
      @Html.AntiForgeryToken()
      <input type="hidden" name="GameId" id="gameId"/>

      <div class="form-group">
        <label class="form-label">Game Title //</label>
        <input type="text" name="Title" id="fTitle" class="form-input" placeholder="Enter game title" required maxlength="200"/>
      </div>
      <div class="form-group">
        <label class="form-label">Description //</label>
        <textarea name="Description" id="fDescription" class="form-textarea" placeholder="Game description..." maxlength="4000"></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Price (USD) //</label>
          <input type="number" step="0.01" min="0" name="Price" id="fPrice" class="form-input" placeholder="0.00" required/>
        </div>
        <div class="form-group">
          <label class="form-label">Release Date //</label>
          <input type="date" name="ReleaseDate" id="fReleaseDate" class="form-input" required/>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Developer //</label>
        <select name="DeveloperId" id="fDeveloperId" class="form-input" onchange="toggleDeveloperCustom()">
          <option value="">— Custom / Other —</option>
          @foreach (var dev in Model.Developers)
          {
            <option value="@dev.Id">@dev.Name</option>
          }
        </select>
        <input type="text" name="Developer" id="fDeveloper" class="form-input" placeholder="Or type a name..." maxlength="200" style="margin-top:8px;"/>
      </div>
      <div class="form-group">
        <label class="form-label">Cover Image URL //</label>
        <input type="url" name="CoverImageUrl" id="fCoverImageUrl" class="form-input" placeholder="https://..." maxlength="500"/>
        <input type="file" name="CoverImageFile" id="fCoverImageFile" class="form-input" style="padding:8px 14px; margin-top:8px;" accept="image/*"/>
      </div>
      <div class="form-group">
        <label class="form-label">Game File (ZIP/RAR/EXE) //</label>
        <input type="file" name="GameFile" id="fGameFile" class="form-input" style="padding:8px 14px;" accept=".zip,.rar,.7z,.exe,.msi,.apk"/>
        <div id="currentFileInfo" style="display:none; margin-top:8px; font-family:var(--font-mono); font-size:12px; color:var(--text-dim); padding:8px 12px; background:var(--bg3); border:1px solid var(--border-red);">
          <span style="color:var(--gold);">CURRENT FILE:</span>
          <span id="currentFileName"></span>
          <span id="currentFileSize" style="margin-left:12px;"></span>
          <label style="margin-left:16px; cursor:pointer; color:var(--red);">
            <input type="checkbox" name="RemoveGameFile" value="true" id="fRemoveGameFile" style="accent-color:var(--red);"/>
            REMOVE FILE
          </label>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Trailer URL //</label>
        <input type="url" name="TrailerUrl" id="fTrailerUrl" class="form-input" placeholder="https://youtube.com/..." maxlength="500"/>
      </div>

      <!-- SYSTEM REQUIREMENTS ACCORDION -->
      <div style="border:1px solid var(--border-red); margin-bottom:18px;">
        <button type="button" onclick="toggleReqs(this)" style="width:100%; background:var(--bg3); border:none; color:var(--text-dim); font-family:var(--font-mono); font-size:11px; letter-spacing:2px; padding:10px 16px; cursor:pointer; text-align:left; display:flex; justify-content:space-between; align-items:center;">
          <span>SYSTEM REQUIREMENTS</span>
          <span id="reqsToggle">▶</span>
        </button>
        <div id="reqsSection" style="display:none; padding:16px; border-top:1px solid var(--border-red);">
          <div id="reqsStatus" style="font-family:var(--font-mono);font-size:10px;color:var(--text-dim);margin-bottom:8px;"></div>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
            <div>
              <div class="form-label" style="color:var(--red);">MINIMUM</div>
              <input class="form-input req-field" style="margin-bottom:6px;font-size:12px;" placeholder="OS" data-req-type="min" data-req-field="os"/>
              <input class="form-input req-field" style="margin-bottom:6px;font-size:12px;" placeholder="Processor" data-req-type="min" data-req-field="processor"/>
              <input class="form-input req-field" style="margin-bottom:6px;font-size:12px;" placeholder="Memory" data-req-type="min" data-req-field="memory"/>
              <input class="form-input req-field" style="margin-bottom:6px;font-size:12px;" placeholder="Graphics" data-req-type="min" data-req-field="graphics"/>
              <input class="form-input req-field" style="margin-bottom:6px;font-size:12px;" placeholder="DirectX" data-req-type="min" data-req-field="directX"/>
              <input class="form-input req-field" style="margin-bottom:6px;font-size:12px;" placeholder="Storage" data-req-type="min" data-req-field="storage"/>
            </div>
            <div>
              <div class="form-label" style="color:var(--gold);">RECOMMENDED</div>
              <input class="form-input req-field" style="margin-bottom:6px;font-size:12px;" placeholder="OS" data-req-type="rec" data-req-field="os"/>
              <input class="form-input req-field" style="margin-bottom:6px;font-size:12px;" placeholder="Processor" data-req-type="rec" data-req-field="processor"/>
              <input class="form-input req-field" style="margin-bottom:6px;font-size:12px;" placeholder="Memory" data-req-type="rec" data-req-field="memory"/>
              <input class="form-input req-field" style="margin-bottom:6px;font-size:12px;" placeholder="Graphics" data-req-type="rec" data-req-field="graphics"/>
              <input class="form-input req-field" style="margin-bottom:6px;font-size:12px;" placeholder="DirectX" data-req-type="rec" data-req-field="directX"/>
              <input class="form-input req-field" style="margin-bottom:6px;font-size:12px;" placeholder="Storage" data-req-type="rec" data-req-field="storage"/>
            </div>
          </div>
          <button type="button" class="btn btn-secondary" style="margin-top:12px;padding:6px 16px;font-size:11px;" onclick="saveRequirements()">💾 SAVE REQUIREMENTS</button>
        </div>
      </div>

      <!-- VERSION MANAGEMENT ACCORDION -->
      <div style="border:1px solid var(--border-red); margin-bottom:18px;">
        <button type="button" onclick="toggleVersions(this)" style="width:100%; background:var(--bg3); border:none; color:var(--text-dim); font-family:var(--font-mono); font-size:11px; letter-spacing:2px; padding:10px 16px; cursor:pointer; text-align:left; display:flex; justify-content:space-between; align-items:center;">
          <span>VERSIONS</span>
          <span id="versionsToggle">▶</span>
        </button>
        <div id="versionsSection" style="display:none; padding:16px; border-top:1px solid var(--border-red);">
          <div id="versionsStatus" style="font-family:var(--font-mono);font-size:10px;color:var(--text-dim);margin-bottom:8px;"></div>
          <div id="versionsList" style="margin-bottom:12px;"></div>
          <div style="border-top:1px solid rgba(230,57,70,0.15);padding-top:12px;">
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--text-dim);margin-bottom:8px;">UPLOAD NEW VERSION</div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
              <input type="text" id="newVersionLabel" class="form-input" placeholder="e.g. 1.0.0" style="width:120px;font-size:12px;" />
              <input type="file" id="newVersionFile" class="form-input" style="font-size:12px;padding:6px;flex:1;" />
            </div>
            <textarea id="newVersionChangelog" class="form-input" placeholder="Changelog (optional)" style="margin-top:8px;font-size:12px;resize:vertical;min-height:50px;"></textarea>
            <button type="button" class="btn btn-secondary" style="margin-top:8px;padding:6px 16px;font-size:11px;" onclick="uploadVersion()">⬆ UPLOAD VERSION</button>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Categories //</label>
        <div class="checkbox-grid">
          @foreach (var cat in Model.Categories)
          {
            <div class="checkbox-item">
              <input type="checkbox" name="CategoryIds" value="@cat.Id" id="cat_@cat.Id" class="cat-checkbox"/>
              <label for="cat_@cat.Id">@cat.Name</label>
            </div>
          }
        </div>
      </div>

      <div style="display:flex; gap:12px; justify-content:flex-end; margin-top:28px;">
        <button type="button" class="btn btn-secondary" onclick="closeModal()">ABORT</button>
        <button type="submit" id="submitBtn" class="btn btn-primary">INJECT RECORD</button>
      </div>
    </form>
  </div>
</div>

<script>
  const gamesData = @Html.Raw(Model.GameDataJson);

  function fmtSize(bytes) {
    if (!bytes || bytes === 0) return '';
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + ' KB';
    if (bytes < 1024*1024*1024) return (bytes/(1024*1024)).toFixed(1) + ' MB';
    return (bytes/(1024*1024*1024)).toFixed(2) + ' GB';
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');
  }

  function openModal() {
    document.getElementById('modalTitle').textContent = 'ADD GAME';
    document.getElementById('modalTag').textContent = '> NEW RECORD INJECTION';
    document.getElementById('submitBtn').textContent = 'INJECT RECORD';
    document.getElementById('gameForm').action = '@createUrl';
    document.getElementById('gameId').value = '';
    document.getElementById('gameForm').reset();
    document.getElementById('fDeveloperId').value = '';
    document.getElementById('fDeveloper').value = '';
    document.getElementById('fDeveloper').style.display = 'block';
    document.getElementById('currentFileInfo').style.display = 'none';
    document.getElementById('fRemoveGameFile').checked = false;
    document.getElementById('gameModal').classList.add('active');
  }

  function toggleDeveloperCustom() {
    var sel = document.getElementById('fDeveloperId');
    var txt = document.getElementById('fDeveloper');
    txt.style.display = sel.value === '' ? 'block' : 'none';
    if (sel.value !== '') txt.value = '';
  }

  function openEditModal(index) {
    const data = gamesData[index];
    document.getElementById('modalTitle').textContent = 'EDIT GAME';
    document.getElementById('modalTag').textContent = '> MODIFY RECORD: ' + data.id.slice(-8).toUpperCase();
    document.getElementById('submitBtn').textContent = 'UPDATE RECORD';
    document.getElementById('gameForm').action = '@editUrl';
    document.getElementById('gameId').value = data.id;
    document.getElementById('fTitle').value = data.title;
    document.getElementById('fDescription').value = data.description;
    document.getElementById('fPrice').value = data.price;
    document.getElementById('fDeveloperId').value = data.developerId || '';
    document.getElementById('fDeveloper').value = data.developer || '';
    toggleDeveloperCustom();
    document.getElementById('fTrailerUrl').value = data.trailerUrl;
    document.getElementById('fCoverImageUrl').value = data.coverImageUrl;
    document.getElementById('fReleaseDate').value = data.releaseDate;
    document.getElementById('fGameFile').value = '';
    document.getElementById('fCoverImageFile').value = '';

    if (data.hasFile) {
      document.getElementById('currentFileInfo').style.display = 'block';
      document.getElementById('currentFileName').textContent = data.fileName || 'GAME FILE';
      document.getElementById('currentFileSize').textContent = fmtSize(data.fileSizeBytes) + ' OK';
    } else {
      document.getElementById('currentFileInfo').style.display = 'none';
    }
    document.getElementById('fRemoveGameFile').checked = false;

    const catIds = new Set(data.categoryIds);
    document.querySelectorAll('.cat-checkbox').forEach(cb => {
      cb.checked = catIds.has(cb.value);
    });

    loadRequirements(data.id);
    loadVersions(data.id);

    document.getElementById('gameModal').classList.add('active');
  }

  function toggleReqs(btn) {
    var section = document.getElementById('reqsSection');
    var toggle = document.getElementById('reqsToggle');
    var isOpen = section.style.display !== 'none';
    section.style.display = isOpen ? 'none' : 'block';
    toggle.textContent = isOpen ? '▶' : '▼';
  }

  function loadRequirements(gameId) {
    document.querySelectorAll('.req-field').forEach(el => el.value = '');
    document.getElementById('reqsStatus').textContent = 'LOADING...';
    var url = '/Admin/Games/GetRequirements/' + gameId;
    fetch(url)
      .then(function(r) {
        if (!r.ok) { throw new Error('HTTP ' + r.status + ' for ' + url); }
        return r.json();
      })
      .then(function(data) {
        if (!data) { document.getElementById('reqsStatus').textContent = '—'; return; }
        document.querySelectorAll('.req-field').forEach(function(el) {
          var type = el.dataset.reqType;
          var field = el.dataset.reqField;
          var section = type === 'min' ? data.minimum : data.recommended;
          if (section) {
            var val = section[field];
            if (val) el.value = val;
          }
        });
        document.getElementById('reqsStatus').textContent = 'REQUIREMENTS LOADED';
      })
      .catch(function(e) { document.getElementById('reqsStatus').textContent = 'ERROR LOADING — ' + e.message; });
  }

  function saveRequirements() {
    var gameId = document.getElementById('gameId').value;
    if (!gameId) return;
    var model = { minimum: {}, recommended: {} };
    document.querySelectorAll('.req-field').forEach(el => {
      var type = el.dataset.reqType;
      var field = el.dataset.reqField;
      var section = type === 'min' ? model.minimum : model.recommended;
      section[field] = el.value || null;
    });
    fetch('/Admin/Games/SaveRequirements', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value },
      body: JSON.stringify({ gameId: gameId, model: model })
    })
    .then(r => r.json())
    .then(d => {
      document.getElementById('reqsStatus').textContent = d.success ? 'SAVED' : 'ERROR: ' + d.message;
    })
    .catch(() => document.getElementById('reqsStatus').textContent = 'SAVE FAILED');
  }

  function toggleVersions(btn) {
    var section = document.getElementById('versionsSection');
    var toggle = document.getElementById('versionsToggle');
    var isOpen = section.style.display !== 'none';
    section.style.display = isOpen ? 'none' : 'block';
    toggle.textContent = isOpen ? '▶' : '▼';
  }

  function loadVersions(gameId) {
    document.getElementById('versionsList').innerHTML = '';
    document.getElementById('versionsStatus').textContent = 'LOADING...';
    var url = '/Admin/Games/GetVersions/' + gameId;
    fetch(url)
      .then(function(r) {
        if (!r.ok) { throw new Error('HTTP ' + r.status + ' for ' + url); }
        return r.json();
      })
      .then(function(data) {
        if (!data || data.length === 0) {
          document.getElementById('versionsStatus').textContent = 'NO VERSIONS';
          return;
        }
        var html = '<div style="font-family:var(--font-mono);font-size:10px;color:var(--text-dim);margin-bottom:6px;">' + data.length + ' version(s) on file</div>';
        data.forEach(function(v) {
          var isCurrent = v.isCurrent;
          html += '<div style="display:flex;align-items:center;justify-content:space-between;padding:8px 10px;margin-bottom:4px;border:1px solid ' + (isCurrent ? 'rgba(74,222,128,0.2)' : 'rgba(230,57,70,0.08)') + ';background:' + (isCurrent ? 'rgba(74,222,128,0.03)' : '') + ';">';
          html += '<div><div style="font-family:var(--font-display);color:' + (isCurrent ? '#4ade80' : 'white') + ';font-size:13px;">' + escapeHtml(v.versionLabel) + (isCurrent ? ' <span style="font-size:10px;color:#4ade80;border:1px solid rgba(74,222,128,0.3);padding:2px 6px;">CURRENT</span>' : '') + '</div>';
          html += '<div style="font-size:11px;color:var(--text-dim);margin-top:2px;">' + fmtSize(v.fileSizeBytes) + ' &middot; ' + v.fileName + '</div>';
          if (v.changelog) html += '<div style="font-size:10px;color:var(--text-dim);margin-top:2px;">' + escapeHtml(v.changelog) + '</div>';
          html += '<div style="font-size:10px;color:var(--text-dim);margin-top:2px;">' + v.uploadedAt + '</div></div><div>';
          if (!isCurrent) {
            html += '<button class="btn btn-secondary" style="padding:4px 8px;font-size:10px;margin-right:4px;" onclick="setCurrentVersion(\'' + gameId + '\',\'' + v.id + '\')">SET CURRENT</button>';
          }
          html += '<button class="btn btn-secondary" style="padding:4px 8px;font-size:10px;" onclick="deleteVersion(\'' + gameId + '\',\'' + v.id + '\')">DELETE</button>';
          html += '</div></div>';
        });
        document.getElementById('versionsList').innerHTML = html;
        document.getElementById('versionsStatus').textContent = '';
      })
      .catch(function(e) { document.getElementById('versionsStatus').textContent = 'ERROR LOADING — ' + e.message; });
  }

  function uploadVersion() {
    var gameId = document.getElementById('gameId').value;
    var label = document.getElementById('newVersionLabel').value.trim();
    var file = document.getElementById('newVersionFile').files[0];
    var changelog = document.getElementById('newVersionChangelog').value.trim();
    if (!gameId || !label || !file) { alert('Version label and file are required.'); return; }
    var formData = new FormData();
    formData.append('gameId', gameId);
    formData.append('versionLabel', label);
    formData.append('changelog', changelog);
    formData.append('file', file);
    document.getElementById('versionsStatus').textContent = 'UPLOADING...';
    fetch('/Admin/Games/UploadVersion', {
      method: 'POST',
      headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value },
      body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      document.getElementById('versionsStatus').textContent = d.success ? 'UPLOADED' : 'ERROR: ' + d.message;
      if (d.success) {
        document.getElementById('newVersionLabel').value = '';
        document.getElementById('newVersionFile').value = '';
        document.getElementById('newVersionChangelog').value = '';
        loadVersions(gameId);
      }
    })
    .catch(function() { document.getElementById('versionsStatus').textContent = 'UPLOAD FAILED'; });
  }

  function deleteVersion(gameId, versionId) {
    if (!confirm('Delete this version?')) return;
    document.getElementById('versionsStatus').textContent = 'DELETING...';
    var formData = new FormData();
    formData.append('gameId', gameId);
    formData.append('versionId', versionId);
    fetch('/Admin/Games/DeleteVersion', {
      method: 'POST',
      headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value },
      body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      document.getElementById('versionsStatus').textContent = d.success ? 'DELETED' : 'ERROR: ' + d.message;
      if (d.success) loadVersions(gameId);
    })
    .catch(function() { document.getElementById('versionsStatus').textContent = 'DELETE FAILED'; });
  }

  function setCurrentVersion(gameId, versionId) {
    var formData = new FormData();
    formData.append('gameId', gameId);
    formData.append('versionId', versionId);
    fetch('/Admin/Games/SetCurrentVersion', {
      method: 'POST',
      headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value },
      body: formData
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      document.getElementById('versionsStatus').textContent = d.success ? 'UPDATED' : 'ERROR: ' + d.message;
      if (d.success) loadVersions(gameId);
    })
    .catch(function() { document.getElementById('versionsStatus').textContent = 'UPDATE FAILED'; });
  }

  function closeModal() {
    document.getElementById('gameModal').classList.remove('active');
  }

  document.getElementById('gameModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  const searchInput = document.getElementById('searchInput');
  let searchTimer;
  searchInput.addEventListener('input', function() {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => {
      const q = this.value.toLowerCase();
      const rows = document.querySelectorAll('.game-row');
      let visible = 0;
      rows.forEach(row => {
        const match = !q || row.dataset.search.includes(q);
        row.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      document.getElementById('gameCount').textContent = visible;
    }, 150);
  });
</script>
