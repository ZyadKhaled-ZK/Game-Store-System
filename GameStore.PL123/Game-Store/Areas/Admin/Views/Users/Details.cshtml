@model UserDetailsViewModel
@{
    ViewData["Title"] = "User Profile";
}

<style>
  .profile-header {
    background: var(--bg2);
    border: 1px solid var(--border-red);
    padding: 36px 40px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .profile-avatar {
    width: 72px; height: 72px;
    border: 2px solid var(--border-red);
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; color: var(--red);
    background: rgba(230,57,70,0.06);
    flex-shrink: 0;
  }
  .profile-info { flex: 1; }
  .profile-name {
    font-family: var(--font-display);
    font-size: 1.8rem; font-weight: 900; color: white;
    display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
  }
  .profile-email {
    font-family: var(--font-mono); font-size: 13px;
    color: var(--text-dim); margin-top: 4px;
  }
  .profile-bio {
    font-family: var(--font-ui); font-size: 14px;
    color: var(--text); margin-top: 12px; padding: 12px 16px;
    background: var(--bg3); border: 1px solid rgba(230,57,70,0.08);
    max-width: 500px;
  }
  .profile-actions { display: flex; gap: 10px; flex-shrink: 0; }

  .summary-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--border-red);
    margin-bottom: 40px;
  }
  .summary-item {
    background: var(--bg2);
    padding: 20px;
    text-align: center;
  }
  .summary-num {
    font-family: var(--font-display);
    font-size: 28px; font-weight: 900;
    color: var(--red);
  }
  .summary-label {
    font-family: var(--font-mono);
    font-size: 11px; color: var(--text-dim);
    letter-spacing: 1px; text-transform: uppercase;
    margin-top: 4px;
  }

  .section-block {
    background: var(--bg2);
    border: 1px solid var(--border-red);
    padding: 28px 32px;
    margin-bottom: 24px;
  }
  .section-block-title {
    font-family: var(--font-mono);
    font-size: 12px; color: var(--red);
    letter-spacing: 2px; text-transform: uppercase;
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border-red);
  }
  .section-block-title::before {
    content: ''; width: 20px; height: 2px; background: var(--red);
  }

  .lg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 2px;
    background: var(--border-red);
  }
  .lg-card {
    background: var(--bg2); padding: 16px;
    text-align: center;
    transition: background 0.2s;
  }
  .lg-card:hover { background: rgba(230,57,70,0.04); }
  .lg-cover {
    width: 100%; height: 80px;
    object-fit: cover; border: 1px solid var(--border-red);
    margin-bottom: 10px;
  }
  .lg-cover-placeholder {
    width: 100%; height: 80px;
    background: var(--bg3); border: 1px solid var(--border-red);
    display: flex; align-items: center; justify-content: center;
    color: var(--red); font-size: 24px;
    margin-bottom: 10px;
  }
  .lg-title {
    font-family: var(--font-display);
    font-size: 12px; font-weight: 700; color: white;
  }
  .lg-date {
    font-family: var(--font-mono);
    font-size: 10px; color: var(--text-dim); margin-top: 4px;
  }

  .stars {
    color: var(--gold);
    font-size: 13px;
    letter-spacing: 2px;
  }
  .stars.empty { color: var(--text-dim); opacity: 0.3; }
  @@media (max-width: 768px) {
    .profile-header { padding: 24px; flex-direction: column; }
    .profile-avatar { width: 56px; height: 56px; font-size: 22px; }
    .profile-name { font-size: 1.4rem; }
    .profile-bio { max-width: 100%; }
    .summary-row { grid-template-columns: 1fr; }
    .summary-item { padding: 16px; }
    .summary-num { font-size: 22px; }
    .section-block { padding: 20px; }
    .section-title { font-size: 1.8rem !important; }
  }
  @@media (max-width: 576px) {
    .profile-header { padding: 16px; }
    .profile-name { font-size: 1.2rem; flex-direction: column; align-items: flex-start; }
    .profile-actions { width: 100%; }
    .profile-actions a, .profile-actions form { width: 100%; }
    .profile-actions .btn { width: 100%; text-align: center; }
    .section-block { padding: 16px; }
    .lg-grid { grid-template-columns: repeat(2, 1fr); }
    .section-title { font-size: 1.4rem !important; }
  }
</style>

<div class="section-header">
  <div class="section-tag">User Intelligence</div>
  <h2 class="section-title glitch">USER PROFILE</h2>
</div>

<a asp-action="Index" class="btn btn-secondary" style="margin-bottom:24px;">
  <i class="bi bi-arrow-left"></i> BACK TO USERS
</a>

@* ── Profile Header ── *@
<div class="profile-header">
  <div class="profile-avatar">
    @Model.User.Username[..1].ToUpper()
  </div>
  <div class="profile-info">
    <div class="profile-name">
      @Model.User.Username
      <span class="badge role-badge role-@Model.User.Role.ToString().ToLower()">@Model.User.Role</span>
    </div>
    <div class="profile-email">@Model.User.Email</div>
    @if (!string.IsNullOrEmpty(Model.User.Bio))
    {
      <div class="profile-bio">@Model.User.Bio</div>
    }
  </div>
</div>

@* ── Stats Summary ── *@
<div class="summary-row">
  <div class="summary-item">
    <div class="summary-num">@Model.Orders.Count</div>
    <div class="summary-label">Orders</div>
  </div>
  <div class="summary-item">
    <div class="summary-num">@Model.LibraryGames.Count</div>
    <div class="summary-label">Games Owned</div>
  </div>
  <div class="summary-item">
    <div class="summary-num">@Model.Reviews.Count</div>
    <div class="summary-label">Reviews</div>
  </div>
</div>

@* ── Orders ── *@
<div class="section-block">
  <div class="section-block-title"><i class="bi bi-credit-card"></i> Orders (@Model.Orders.Count)</div>
  @if (Model.Orders.Any())
  {
    <div class="table-responsive" style="margin-top:0;">
      <table class="cyber-table">
        <thead>
          <tr>
            <th>Order ID</th>
            <th>Date</th>
            <th>Items</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var order in Model.Orders)
          {
            <tr>
              <td style="font-size:11px;color:var(--text-dim);">#@order.Id[..Math.Min(8, order.Id.Length)].ToUpper()</td>
              <td style="font-family:var(--font-mono);font-size:12px;">@order.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
              <td>
                <div style="display:flex;flex-direction:column;gap:2px;">
                @foreach (var item in order.OrderItems)
                {
                  <span style="color:var(--text);">
                    @(item.Game?.Title ?? "N/A")
                    <span style="color:var(--gold);">$@item.PriceAtPurchase.ToString("0.00")</span>
                  </span>
                }
                </div>
              </td>
              <td style="font-family:var(--font-display);font-weight:700;color:var(--gold);">$@order.TotalPrice.ToString("0.00")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
  else
  {
    <div class="empty-state" style="margin:0;">
      <i class="bi bi-cart-x"></i>
      <h4>NO ORDERS</h4>
      <p>This user has not placed any orders yet.</p>
    </div>
  }
</div>

@* ── Library ── *@
<div class="section-block">
  <div class="section-block-title"><i class="bi bi-controller"></i> Game Library (@Model.LibraryGames.Count)</div>
  @if (Model.LibraryGames.Any())
  {
    <div class="lg-grid">
      @foreach (var lg in Model.LibraryGames)
      {
        <div class="lg-card">
          @if (!string.IsNullOrEmpty(lg.Game?.CoverImageUrl))
          {
            <img class="lg-cover" src="@lg.Game.CoverImageUrl" alt="@lg.Game.Title" loading="lazy" />
          }
          else
          {
            <div class="lg-cover-placeholder"><i class="bi bi-play-fill"></i></div>
          }
          <div class="lg-title">@(lg.Game?.Title ?? "N/A")</div>
          <div class="lg-date">Added @lg.AddedAt.ToString("yyyy-MM-dd")</div>
          @if (lg.Game?.Price == 0)
          {
            <span class="badge badge-success" style="margin-top:4px;">FREE</span>
          }
        </div>
      }
    </div>
  }
  else
  {
    <div class="empty-state" style="margin:0;">
      <i class="bi bi-controller"></i>
      <h4>EMPTY LIBRARY</h4>
      <p>This user owns no games.</p>
    </div>
  }
</div>

@* ── Reviews ── *@
<div class="section-block">
  <div class="section-block-title"><i class="bi bi-star-fill"></i> Reviews (@Model.Reviews.Count)</div>
  @if (Model.Reviews.Any())
  {
    <div class="table-responsive" style="margin-top:0;">
      <table class="cyber-table">
        <thead>
          <tr>
            <th>Game</th>
            <th>Rating</th>
            <th>Comment</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var review in Model.Reviews)
          {
            <tr>
              <td>@(review.Game?.Title ?? "N/A")</td>
              <td>
                <span class="stars">
                  @for (int i = 1; i <= 5; i++)
                  {
                    @(i <= review.Rating ? "★" : "☆")
                  }
                </span>
              </td>
              <td style="max-width:300px;white-space:normal;word-break:break-word;">
                @(review.Comment ?? "—")
              </td>
              <td style="font-family:var(--font-mono);font-size:11px;color:var(--text-dim);">
                @review.CreatedAt.ToString("yyyy-MM-dd")
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
  else
  {
    <div class="empty-state" style="margin:0;">
      <i class="bi bi-star"></i>
      <h4>NO REVIEWS</h4>
      <p>This user has not written any reviews yet.</p>
    </div>
  }
</div>
