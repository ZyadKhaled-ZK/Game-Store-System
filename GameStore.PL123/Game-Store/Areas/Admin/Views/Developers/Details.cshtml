@model Developer
@{
    ViewData["Title"] = "Developer Profile";
    var games = ViewData["Games"] as List<Game> ?? new();
    var rawStats = ViewData["Stats"];
    var gameStatsList = ViewData["GameStats"] as List<(Game Game, int Downloads, double AvgRating, int ReviewCount)> ?? new();
    var stats = (GameCount: 0, TotalDownloads: 0, TotalReviews: 0, TotalRevenue: 0, AvgRating: 0.0);
    if (rawStats != null)
    {
        var t = ((int, int, int, int, double))rawStats;
        stats = (t.Item1, t.Item2, t.Item3, t.Item4, t.Item5);
    }
    var gameCount = stats.GameCount;
    var totalDownloads = stats.TotalDownloads;
    var totalReviews = stats.TotalReviews;
    var totalRevenue = stats.TotalRevenue;
    var avgRating = stats.AvgRating;
}

<style>
  .profile-header {
    background: var(--bg2);
    border: 1px solid var(--border-red);
    padding: 36px 40px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .profile-info { flex: 1; }
  .profile-name {
    font-family: var(--font-display);
    font-size: 1.8rem; font-weight: 900; color: white;
    display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
  }
  .profile-email {
    font-family: var(--font-mono); font-size: 13px;
    color: var(--text-dim); margin-top: 4px;
  }
  .profile-desc {
    font-family: var(--font-ui); font-size: 14px;
    color: var(--text); margin-top: 12px; padding: 12px 16px;
    background: var(--bg3); border: 1px solid rgba(230,57,70,0.08);
    max-width: 500px;
  }
  .profile-actions { display: flex; gap: 10px; flex-shrink: 0; }
  .summary-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2px;
    background: var(--border-red);
    margin-bottom: 40px;
  }
  .summary-item {
    background: var(--bg2);
    padding: 20px;
    text-align: center;
  }
  .summary-num {
    font-family: var(--font-display);
    font-size: 28px; font-weight: 900;
    color: var(--red);
  }
  .summary-label {
    font-family: var(--font-mono);
    font-size: 11px; color: var(--text-dim);
    letter-spacing: 1px; text-transform: uppercase;
    margin-top: 4px;
  }
  .section-block {
    background: var(--bg2);
    border: 1px solid var(--border-red);
    padding: 28px 32px;
    margin-bottom: 24px;
  }
  .section-block-title {
    font-family: var(--font-mono);
    font-size: 12px; color: var(--red);
    letter-spacing: 2px; text-transform: uppercase;
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border-red);
  }
  .section-block-title::before {
    content: ''; width: 20px; height: 2px; background: var(--red);
  }
  .stars { color: var(--gold); font-size: 13px; letter-spacing: 2px; }
</style>

<div class="section-header">
  <div class="section-tag">Developer Profile</div>
  <h2 class="section-title glitch">@Model.Name</h2>
</div>

<a asp-action="Index" class="btn btn-secondary" style="margin-bottom:24px;">
  <i class="bi bi-arrow-left"></i> BACK TO DEVELOPERS
</a>

<div class="profile-header">
  <div class="profile-info">
    <div class="profile-name">
      @Model.Name
      <span class="badge badge-primary">DEVELOPER</span>
    </div>
    <div class="profile-email">
      Owned by <strong style="color:var(--gold);">@(Model.User?.Username ?? "—")</strong>
      &middot; @Model.User?.Email
    </div>
    @if (!string.IsNullOrEmpty(Model.Country))
    {
      <div style="margin-top:8px;">
        <span class="badge badge-secondary">@Model.Country</span>
      </div>
    }
    @if (!string.IsNullOrEmpty(Model.Website))
    {
      <div style="margin-top:8px;">
        <a href="@Model.Website" target="_blank" style="color:var(--red);font-family:var(--font-mono);font-size:12px;">
          @Model.Website <i class="bi bi-box-arrow-up-right" style="font-size:10px;"></i>
        </a>
      </div>
    }
    @if (!string.IsNullOrEmpty(Model.Description))
    {
      <div class="profile-desc">@Model.Description</div>
    }
  </div>
  <div class="profile-actions">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">EDIT</a>
  </div>
</div>

<div class="summary-row">
  <div class="summary-item">
    <div class="summary-num">@gameCount</div>
    <div class="summary-label">Games</div>
  </div>
  <div class="summary-item">
    <div class="summary-num">@totalDownloads</div>
    <div class="summary-label">Downloads</div>
  </div>
  <div class="summary-item">
    <div class="summary-num">@totalReviews</div>
    <div class="summary-label">Reviews</div>
  </div>
  <div class="summary-item">
    <div class="summary-num">$@totalRevenue.ToString("0")</div>
    <div class="summary-label">Revenue</div>
  </div>
  <div class="summary-item">
    <div class="summary-num">@avgRating.ToString("0.0")</div>
    <div class="summary-label">Avg Rating</div>
  </div>
</div>

<div class="section-block">
  <div class="section-block-title"><i class="bi bi-controller"></i> Published Games (@games.Count)</div>
  @if (gameStatsList.Any())
  {
    <div class="table-responsive" style="margin-top:0;">
      <table class="cyber-table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Price</th>
            <th>Downloads</th>
            <th>Rating</th>
            <th>Reviews</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var gs in gameStatsList)
          {
            <tr>
              <td style="color:var(--gold);font-weight:600;">@gs.Game.Title</td>
              <td style="font-family:var(--font-mono);">
                @(gs.Game.Price > 0 ? "$" + gs.Game.Price.ToString("0.00") : "FREE")
              </td>
              <td style="font-family:var(--font-mono);color:var(--text-dim);">@gs.Downloads</td>
              <td>
                <span class="stars">
                  @for (int i = 1; i <= 5; i++)
                  {
                    @(i <= Math.Round(gs.AvgRating, 0) ? "★" : "☆")
                  }
                </span>
                <span style="font-family:var(--font-mono);font-size:10px;color:var(--text-dim);">(@gs.AvgRating.ToString("0.0"))</span>
              </td>
              <td style="font-family:var(--font-mono);color:var(--text-dim);">@gs.ReviewCount</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
  else
  {
    <div class="empty-state" style="margin:0;">
      <i class="bi bi-controller"></i>
      <h4>NO GAMES PUBLISHED</h4>
      <p>This developer has not published any games yet.</p>
    </div>
  }
</div>
