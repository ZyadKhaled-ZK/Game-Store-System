const recentOrders = @Html.Raw(Model.RecentOrdersJson);
const tbody = document.querySelector('#recentOrdersTable tbody');
if (recentOrders.length) {
    tbody.innerHTML = recentOrders.map(o => {
        const itemsStr = o.items.map(i => i.game).join(', ');
        return `<tr>
            <td class="ro-user">${o.user}</td>
            <td style="color:var(--text-dim);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${itemsStr}">${itemsStr}</td>
            <td class="ro-total">$${o.totalPrice.toFixed(2)}</td>
            <td class="ro-date">${o.createdAt}</td>
        </tr>`;
    }).join('');
} else {
    tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--text-dim);padding:40px;">[ NO ORDERS YET ]</td></tr>';
}
</script>
}
