@model List<SupportTicket>
@{
    var message = ViewData["Message"] as string;
    var isError = ViewData["IsError"] is true;
    var page = (int)ViewData["Page"];
    var totalPages = (int)ViewData["TotalPages"];
}

@if (!string.IsNullOrEmpty(message))
{
  <div class="alert @(isError ? "alert-danger" : "alert-success")" style="text-align:center;font-family:var(--font-mono);font-size:12px;letter-spacing:1px;margin-bottom:20px;">
    @message
  </div>
}

<div class="page-header">
  <div>
    <h1>Support Tickets</h1>
    <p>User-submitted support requests.</p>
  </div>
</div>

@if (!Model.Any())
{
  <div style="text-align:center;padding:80px;font-family:var(--font-mono);color:var(--text-dim);">
    [ NO TICKETS ]
  </div>
}
else
{
  <div class="table-responsive">
    <table class="cyber-table">
      <thead>
        <tr>
          <th>SUBJECT</th>
          <th>USER</th>
          <th>REPLIES</th>
          <th>STATUS</th>
          <th>DATE</th>
          <th>ACTIONS</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var t in Model)
        {
          <tr>
            <td style="color:var(--gold);font-weight:600;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@t.Subject">@t.Subject</td>
            <td style="font-size:11px;color:var(--text-dim);">@(t.User?.Username ?? "Guest")</td>
            <td style="font-size:11px;">@t.Replies.Count</td>
            <td>
              @switch (t.Status)
              {
                case TicketStatus.Open:
                  <span style="color:var(--gold);font-family:var(--font-mono);font-size:10px;border:1px solid var(--gold);padding:2px 8px;">OPEN</span>
                  break;
                case TicketStatus.InProgress:
                  <span style="color:var(--cyan);font-family:var(--font-mono);font-size:10px;border:1px solid var(--cyan);padding:2px 8px;">IN PROGRESS</span>
                  break;
                case TicketStatus.Resolved:
                  <span style="color:#4ade80;font-family:var(--font-mono);font-size:10px;border:1px solid #4ade80;padding:2px 8px;">RESOLVED</span>
                  break;
                case TicketStatus.Closed:
                  <span style="color:var(--text-dim);font-family:var(--font-mono);font-size:10px;border:1px solid rgba(255,255,255,0.08);padding:2px 8px;">CLOSED</span>
                  break;
              }
            </td>
            <td style="font-size:11px;">@t.CreatedAt.ToString("yyyy-MM-dd")</td>
            <td style="white-space:nowrap;">
              <a asp-action="Details" asp-route-id="@t.Id" class="btn btn-primary" style="padding:4px 10px;font-size:10px;text-decoration:none;">VIEW</a>
              <form method="post" asp-action="Delete" asp-route-id="@t.Id" style="display:inline;"
                onsubmit="event.preventDefault(); showConfirmModal('Delete this ticket?', this)">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger" style="padding:4px 10px;font-size:10px;">DELETE</button>
              </form>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>

  if (totalPages > 1)
  {
    <div style="display:flex;justify-content:center;gap:8px;margin-top:24px;">
      @for (var i = 1; i <= totalPages; i++)
      {
        <a asp-action="Index" asp-route-page="@i" style="padding:6px 14px;font-family:var(--font-mono);font-size:12px;color:@(i == page ? "var(--red)" : "var(--text-dim)");border:1px solid @(i == page ? "var(--red)" : "rgba(255,255,255,0.08)");text-decoration:none;transition:0.2s;"
           onmouseover="this.style.borderColor='var(--red)';this.style.color='var(--red)'" onmouseout="this.style.borderColor='@(i == page ? "var(--red)" : "rgba(255,255,255,0.08)")';this.style.color='@(i == page ? "var(--red)" : "var(--text-dim)")'">@i</a>
      }
    </div>
  }
}
