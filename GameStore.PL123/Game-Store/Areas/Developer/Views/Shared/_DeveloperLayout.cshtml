<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Developer Portal</title>
    @await RenderSectionAsync("MetaTags", required: false)
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;500;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <style>
      :root {
        --gold: #f5c542; --gold-dim: #b8922e;
        --red: #e63946; --red-dim: #9b1d25;
        --cyan: #00e5ff; --cyan-dim: #0099b3;
        --bg: #070709; --bg2: #0d0d12; --bg3: #111118;
        --bg-glass: rgba(17,17,24,0.85);
        --border: rgba(245,197,66,0.18); --border-cyan: rgba(0,229,255,0.22);
        --text: #e8e8f0; --text-dim: #7a7a99;
        --glow-cyan: 0 0 20px rgba(0,229,255,0.4);
        --glow-cyan-sm: 0 0 12px rgba(0,229,255,0.2);
        --font-display: 'Orbitron', monospace;
        --font-ui: 'Rajdhani', sans-serif;
        --font-mono: 'Share Tech Mono', monospace;
        --radius: 6px;
        --radius-sm: 3px;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      ::-webkit-scrollbar { width: 6px; height: 6px; }
      ::-webkit-scrollbar-track { background: var(--bg2); }
      ::-webkit-scrollbar-thumb { background: var(--cyan-dim); border-radius: var(--radius-sm); }
      ::-webkit-scrollbar-thumb:hover { background: var(--cyan); }
      * { scrollbar-width: thin; scrollbar-color: var(--cyan-dim) var(--bg2); }
      body {
        font-family: var(--font-ui); background: var(--bg); color: var(--text);
        overflow-x: hidden; min-height: 100vh; display: flex; flex-direction: column;
        line-height: 1.6;
      }
      body::before {
        content: ''; position: fixed; inset: 0;
        background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.06) 2px, rgba(0,0,0,0.06) 4px);
        pointer-events: none; z-index: 9999;
      }
      body::after {
        content: ''; position: fixed; inset: 0; z-index: 0; opacity: 0.08;
        background-image:
          linear-gradient(rgba(0,229,255,0.06) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0,229,255,0.06) 1px, transparent 1px);
        background-size: 60px 60px;
        animation: gridScroll 10s linear infinite;
        pointer-events: none;
      }
      @@keyframes gridScroll {
        0% { transform: translate(0, 0); }
        100% { transform: translate(-60px, -60px); }
      }
      @Html.Raw("@keyframes navFadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }")
      @Html.Raw("@keyframes logoBreath { 0%, 100% { opacity: 1; } 50% { opacity: 0.8; } }")
      @Html.Raw("@keyframes bellSwing { 0%, 100% { transform: rotate(0); } 25% { transform: rotate(8deg); } 75% { transform: rotate(-8deg); } }")

      nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 40px; height: 64px;
        background: #111111;
        backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
        box-shadow: 0 1px 0 rgba(255,255,255,0.06);
        animation: navFadeIn 0.4s ease;
      }
      nav .nav-logo {
        display: flex; align-items: center; gap: 12px; text-decoration: none;
      }
      nav .nav-logo-text {
        font-family: var(--font-display); font-size: 16px; letter-spacing: 2px;
        text-transform: uppercase; color: #e0e0e0;
        transition: opacity 0.3s;
      }
      nav .nav-logo-text:hover { opacity: 0.8; }
      nav .nav-logo-text span { color: var(--cyan); font-weight: 300; }
      nav ul.nav-links {
        list-style: none; display: flex; align-items: center; gap: 2px;
      }
      nav ul.nav-links li a {
        font-family: var(--font-mono); font-size: 13px; letter-spacing: 1px;
        text-transform: uppercase; color: #a0a0a0; text-decoration: none;
        padding: 8px 14px; transition: all 0.2s; border: none;
        border-radius: 6px; position: relative;
      }
      nav ul.nav-links li a::after {
        content: ''; position: absolute; bottom: 2px; left: 50%;
        width: 0; height: 2px; background: var(--cyan);
        transition: all 0.3s ease; transform: translateX(-50%); opacity: 0;
      }
      nav ul.nav-links li a:hover {
        color: #ffffff; background: rgba(255,255,255,0.06);
        transform: translateY(-1px);
      }
      nav ul.nav-links li a:hover::after {
        width: 60%; opacity: 1;
      }
      nav ul.nav-links li a.active {
        color: var(--cyan); background: rgba(0,229,255,0.08);
      }
      nav ul.nav-links li a.active::after {
        width: 60%; opacity: 1; background: var(--cyan);
      }
      main {
        margin-top: 70px; padding: 40px; flex: 1; position: relative; z-index: 1;
        animation: fadeIn 0.45s cubic-bezier(0.4, 0, 0.2, 1);
      }
      @@keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
      .page-header {
        margin-bottom: 32px; border-bottom: 1px solid rgba(0,229,255,0.08);
        padding-bottom: 24px;
      }
      .page-header h1 {
        font-family: var(--font-display); font-size: 26px; letter-spacing: 3px;
        color: var(--cyan); text-transform: uppercase; position: relative; display: inline-block;
        text-shadow: 0 0 30px rgba(0,229,255,0.15);
      }
      .page-header h1::after {
        content: ''; position: absolute; bottom: -8px; left: 0; width: 60px; height: 2px;
        background: var(--cyan); opacity: 0.4; border-radius: 1px;
      }
      .page-header p { color: var(--text-dim); font-size: 14px; margin-top: 8px; }
      .card {
        background: linear-gradient(135deg, rgba(13,13,18,0.95) 0%, rgba(17,17,24,0.9) 100%);
        border: 1px solid rgba(0,229,255,0.12); padding: 28px;
        margin-bottom: 24px; transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s;
        border-radius: var(--radius);
      }
      .card:hover {
        border-color: rgba(0,229,255,0.25);
        box-shadow: 0 4px 32px rgba(0,0,0,0.3), 0 0 20px rgba(0,229,255,0.04);
      }
      .card h3 {
        font-family: var(--font-mono); font-size: 11px; letter-spacing: 2px;
        color: var(--text-dim); text-transform: uppercase; margin-bottom: 18px;
      }
      .stat-grid {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
        gap: 20px; margin-bottom: 32px;
      }
      .stat-card {
        background: linear-gradient(145deg, rgba(17,17,24,0.9) 0%, rgba(13,13,18,0.95) 100%);
        border: 1px solid rgba(0,229,255,0.1); padding: 28px 20px 24px;
        text-align: center; position: relative; overflow: hidden;
        transition: border-color 0.3s, box-shadow 0.3s, transform 0.25s;
        border-radius: var(--radius); cursor: default;
      }
      .stat-card:hover {
        border-color: rgba(0,229,255,0.35);
        box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 30px rgba(0,229,255,0.06);
        transform: translateY(-3px);
      }
      .stat-card::before {
        content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
        background: radial-gradient(circle, rgba(0,229,255,0.03) 0%, transparent 70%);
        opacity: 0; transition: opacity 0.6s;
      }
      .stat-card:hover::before { opacity: 1; }
      .stat-card .stat-value {
        font-family: var(--font-display); font-size: 34px; color: var(--cyan);
        margin-bottom: 6px; position: relative; z-index: 1;
        line-height: 1.2;
      }
      .stat-card .stat-label {
        font-family: var(--font-mono); font-size: 10px; letter-spacing: 2px;
        color: var(--text-dim); text-transform: uppercase; position: relative; z-index: 1;
      }
      .btn {
        font-family: var(--font-mono); font-size: 11px; letter-spacing: 1.5px;
        text-transform: uppercase; padding: 10px 22px; border: none; cursor: pointer;
        transition: all 0.25s; text-decoration: none; display: inline-flex;
        align-items: center; gap: 8px; border-radius: var(--radius-sm);
        position: relative; overflow: hidden;
      }
      .btn::after {
        content: ''; position: absolute; inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 50%);
        pointer-events: none;
      }
      .btn:active { transform: scale(0.97); }
      .btn-primary {
        background: linear-gradient(135deg, rgba(0,229,255,0.15) 0%, rgba(0,153,179,0.1) 100%);
        color: var(--cyan); border: 1px solid rgba(0,229,255,0.3);
      }
      .btn-primary:hover {
        background: linear-gradient(135deg, rgba(0,229,255,0.25) 0%, rgba(0,153,179,0.15) 100%);
        box-shadow: 0 4px 20px rgba(0,229,255,0.15); transform: translateY(-1px);
      }
      .btn-secondary {
        background: rgba(255,255,255,0.02); color: var(--text-dim);
        border: 1px solid rgba(0,229,255,0.12);
      }
      .btn-secondary:hover {
        color: var(--cyan); border-color: rgba(0,229,255,0.3);
        background: rgba(0,229,255,0.04); transform: translateY(-1px);
      }
      .btn-danger {
        background: linear-gradient(135deg, rgba(230,57,70,0.15) 0%, rgba(155,29,37,0.1) 100%);
        color: var(--red); border: 1px solid rgba(230,57,70,0.3);
      }
      .btn-danger:hover {
        background: linear-gradient(135deg, rgba(230,57,70,0.25) 0%, rgba(155,29,37,0.15) 100%);
        box-shadow: 0 4px 20px rgba(230,57,70,0.15); transform: translateY(-1px);
      }
      .btn.loading { pointer-events: none; opacity: 0.6; }
      .btn.loading::after {
        content: ''; display: inline-block; width: 12px; height: 12px;
        border: 2px solid transparent; border-top-color: currentColor;
        border-radius: 50%; animation: spin 0.6s linear infinite;
        position: relative; margin-left: 4px;
      }
      @@keyframes spin { to { transform: rotate(360deg); } }
      .form-group { margin-bottom: 22px; }
      .form-group label {
        font-family: var(--font-mono); font-size: 10px; letter-spacing: 1.5px;
        color: var(--text-dim); text-transform: uppercase; display: block; margin-bottom: 8px;
      }
      .form-control {
        width: 100%; background: rgba(7,7,9,0.6); border: 1px solid rgba(0,229,255,0.12);
        color: var(--text); padding: 11px 16px; font-family: var(--font-ui);
        font-size: 14px; outline: none; transition: border-color 0.2s, box-shadow 0.2s;
        border-radius: var(--radius-sm);
      }
      .form-control:focus { border-color: var(--cyan); box-shadow: 0 0 0 3px rgba(0,229,255,0.06); }
      .form-control::placeholder { color: var(--text-dim); opacity: 0.4; }
      textarea.form-control { resize: vertical; min-height: 100px; }
      .table-responsive { overflow-x: auto; border-radius: var(--radius); border: 1px solid rgba(0,229,255,0.08); }
      .cyber-table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); white-space: nowrap; }
      .cyber-table th {
        background: rgba(0,229,255,0.04); color: var(--cyan); padding: 14px 18px;
        text-align: left; letter-spacing: 1.5px; text-transform: uppercase;
        border-bottom: 1px solid rgba(0,229,255,0.1); font-size: 11px;
      }
      .cyber-table td { padding: 14px 18px; border-bottom: 1px solid rgba(255,255,255,0.03); color: var(--text); font-size: 12px; }
      .cyber-table tbody tr { transition: background 0.15s; }
      .cyber-table tbody tr:hover { background: rgba(0,229,255,0.03); }
      .cyber-table tbody tr:last-child td { border-bottom: none; }
      .toast-container {
        position: fixed; top: 80px; right: 20px; z-index: 10000;
        display: flex; flex-direction: column; gap: 8px;
      }
      .toast {
        font-family: var(--font-mono); font-size: 12px; padding: 14px 18px;
        border: 1px solid rgba(0,229,255,0.2); background: var(--bg-glass);
        color: var(--text); animation: toastIn 0.35s cubic-bezier(0.4,0,0.2,1);
        max-width: 400px; border-radius: var(--radius-sm);
        backdrop-filter: blur(12px); display: flex; align-items: center; gap: 10px;
      }
      .toast.error { border-color: rgba(230,57,70,0.3); color: var(--red); }
      .toast.success { border-color: rgba(74,222,128,0.3); color: #4ade80; }
      .toast.warning { border-color: rgba(245,197,66,0.3); color: var(--gold); }
      .toast i { font-size: 1.1rem; flex-shrink: 0; }
      .toast-content { flex: 1; }
      .toast-close { background: none; border: none; color: var(--text-dim); cursor: pointer; padding: 2px 6px; font-size: 16px; opacity: 0.7; transition: opacity 0.2s; }
      .toast-close:hover { opacity: 1; }
      @@keyframes toastIn { from { transform: translateX(120%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
      .field-validation-error { color: var(--red); font-family: var(--font-mono); font-size: 11px; }
      .copy-trigger { cursor: pointer; position: relative; display: inline-flex; align-items: center; gap: 6px; border-radius: var(--radius-sm); transition: background 0.2s; }
      .copy-trigger:hover { background: rgba(0,229,255,0.03); }
      .copy-trigger .copy-tip {
        position: absolute; bottom: calc(100% + 8px); left: 50%; transform: translateX(-50%);
        background: var(--bg3); color: var(--cyan); font-family: var(--font-mono); font-size: 10px;
        padding: 5px 10px; border: 1px solid rgba(0,229,255,0.2); white-space: nowrap;
        opacity: 0; pointer-events: none; transition: opacity 0.2s; border-radius: var(--radius-sm);
      }
      .copy-trigger.copied .copy-tip { opacity: 1; }
      .mini-bar { display: flex; align-items: center; gap: 8px; }
      .mini-bar-track {
        flex: 1; height: 5px; background: rgba(7,7,9,0.6); border: 1px solid rgba(0,229,255,0.08);
        overflow: hidden; border-radius: 3px;
      }
      .mini-bar-fill {
        height: 100%; background: linear-gradient(90deg, var(--cyan-dim), var(--cyan));
        transition: width 1.2s cubic-bezier(0.4,0,0.2,1);
        box-shadow: 0 0 8px rgba(0,229,255,0.3);
      }
      .modal-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,0.75); z-index: 5000;
        display: flex; align-items: center; justify-content: center;
        opacity: 0; pointer-events: none; transition: opacity 0.3s;
        backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
      }
      .modal-overlay.show { opacity: 1; pointer-events: auto; }
      .modal-box {
        background: linear-gradient(145deg, rgba(13,13,18,0.98) 0%, rgba(17,17,24,0.95) 100%);
        border: 1px solid rgba(0,229,255,0.12); padding: 32px;
        max-width: 420px; width: 90%; text-align: center;
        border-radius: var(--radius); box-shadow: 0 24px 80px rgba(0,0,0,0.5);
        animation: modalIn 0.25s cubic-bezier(0.4,0,0.2,1);
      }
      @@keyframes modalIn { from { opacity: 0; transform: scale(0.95) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
      .modal-box h3 { font-family: var(--font-display); font-size: 16px; color: var(--red); margin-bottom: 12px; letter-spacing: 2px; }
      .modal-box p { font-size: 13px; color: var(--text-dim); margin-bottom: 24px; line-height: 1.5; }
      .modal-actions { display: flex; gap: 12px; justify-content: center; }
      .pulse-dot {
        display: inline-block; width: 8px; height: 8px; border-radius: 50%;
        background: var(--cyan); animation: pulse 2s ease infinite; vertical-align: middle;
      }
      @@keyframes pulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(0,229,255,0.4); } 50% { box-shadow: 0 0 0 8px rgba(0,229,255,0); } }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav>
      <a asp-area="Developer" asp-controller="Dashboard" asp-action="Index" class="nav-logo">
        <span class="nav-logo-text">DEV <span>PORTAL</span></span>
      </a>
      <ul class="nav-links">
        <li><a asp-area="Developer" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li><a asp-area="Developer" asp-controller="Games" asp-action="Index">My Games</a></li>
        <li><a asp-area="Developer" asp-controller="Sales" asp-action="Index">Sales</a></li>
        <li><a asp-area="Developer" asp-controller="Reviews" asp-action="Index">Reviews</a></li>
        <li><a asp-area="Developer" asp-controller="Profile" asp-action="Index">Profile</a></li>
        <li><a asp-area="" asp-controller="Friends" asp-action="Index"><i class="bi bi-people"></i> Social</a></li>
        <li><a asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-arrow-return-left"></i> Store</a></li>
        <li><a asp-area="" asp-controller="Auth" asp-action="Logout" class="btn btn-secondary" style="padding:6px 12px;margin-left:10px;">Logout</a></li>
      </ul>
    </nav>

    <div class="toast-container" id="toastContainer"></div>

    <main>
        @RenderBody()
    </main>

    <script>
      (function() {
        // ── Active Nav Link ──
        var path = window.location.pathname.toLowerCase();
        document.querySelectorAll('nav .nav-links a').forEach(function(a) {
          var href = a.getAttribute('href').toLowerCase();
          if (href !== '/' && path.indexOf(href) >= 0) a.classList.add('active');
        });

        // ── Form Loading ──
        document.querySelectorAll('form').forEach(function(f) {
          f.addEventListener('submit', function() {
            var btn = this.querySelector('.btn[type="submit"], button[type="submit"]');
            if (btn) btn.classList.add('loading');
          });
        });

        // ── Toast ──
        var msgEl = document.getElementById('alertMessage');
        if (msgEl && window.showToast) {
          var msg = msgEl.getAttribute('data-msg');
          var isErr = msgEl.getAttribute('data-error') === 'true';
          if (msg) showToast(msg, isErr ? 'error' : 'success');
        }

        // ── Stat Counter ──
        document.querySelectorAll('.stat-value[data-count]').forEach(function(el) {
          var target = parseInt(el.getAttribute('data-count'), 10);
          if (isNaN(target)) return;
          var suffix = el.getAttribute('data-suffix') || '';
          var duration = 1200;
          var start = performance.now();
          function step(now) {
            var p = Math.min((now - start) / duration, 1);
            el.textContent = Math.floor(p * target) + suffix;
            if (p < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        });

        // ── Typewriter ──
        document.querySelectorAll('[data-typewrite]').forEach(function(el) {
          var text = el.getAttribute('data-typewrite');
          el.textContent = '';
          var i = 0;
          function type() {
            if (i < text.length) {
              el.textContent += text.charAt(i);
              i++;
              setTimeout(type, 40 + Math.random() * 30);
            }
          }
          setTimeout(type, 600);
        });

        // ── Copy Trigger ──
        document.querySelectorAll('.copy-trigger').forEach(function(el) {
          el.addEventListener('click', function() {
            var val = this.getAttribute('data-copy');
            if (!val) return;
            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText(val);
            } else {
              var ta = document.createElement('textarea');
              ta.value = val; ta.style.position = 'fixed'; ta.style.opacity = '0';
              document.body.appendChild(ta); ta.select(); document.execCommand('copy');
              document.body.removeChild(ta);
            }
            this.classList.add('copied');
            var tip = this.querySelector('.copy-tip');
            if (tip) tip.textContent = 'COPIED!';
            var self = this;
            setTimeout(function() {
              self.classList.remove('copied');
              if (tip) tip.textContent = 'CLICK TO COPY';
            }, 2000);
          });
        });

        // ── Modal ──
        window.showModal = function(id) {
          var el = document.getElementById(id);
          if (el) el.classList.add('show');
        };
        window.closeModal = function(id) {
          var el = document.getElementById(id);
          if (el) el.classList.remove('show');
        };
        document.querySelectorAll('.modal-overlay').forEach(function(m) {
          m.addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('show');
          });
        });

        // ── Global confirm dialog ──
        window.confirmAction = function(title, message, cb) {
          document.getElementById('modalConfirmTitle').textContent = title;
          document.getElementById('modalConfirmMessage').textContent = message;
          window.modalConfirmCb = cb;
          showModal('confirmModal');
        };
      })();
    </script>
    <script>
      // ── Toast system ──
      function showToast(message, type) {
        type = type || 'success';
        var container = document.getElementById('toastContainer');
        if (!container) return;
        var icons = { success: 'bi-check-circle-fill', error: 'bi-x-circle-fill', warning: 'bi-exclamation-triangle-fill' };
        var toast = document.createElement('div');
        toast.className = 'toast ' + type;
        toast.style.display = 'flex';
        toast.style.alignItems = 'center';
        toast.style.gap = '10px';
        toast.innerHTML = '<i class="bi ' + (icons[type] || icons.success) + '"></i>' +
          '<div class="toast-content">' + message + '</div>' +
          '<button class="toast-close" onclick="this.parentElement.remove()">&times;</button>';
        container.appendChild(toast);
        setTimeout(function() {
          if (toast.parentElement) {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(100%)';
            toast.style.transition = 'all 0.3s';
            setTimeout(function() { if (toast.parentElement) toast.remove(); }, 300);
          }
        }, 4000);
      }
      // ── Initial toast from server ──
      (function() {
        var msgEl = document.getElementById('alertMessage');
        if (msgEl) {
          var msg = msgEl.getAttribute('data-msg');
          var isErr = msgEl.getAttribute('data-error') === 'true';
          if (msg) showToast(msg, isErr ? 'error' : 'success');
        }
      })();
    </script>
    <script>
      (function() {
        var userId = '@Context.Session.GetString("UserId")';
        if (!userId) return;
        var connection = new signalR.HubConnectionBuilder()
          .withUrl("/hub/notifications")
          .withAutomaticReconnect()
          .build();
        connection.on("ReceiveNotification", function(data) {
          if (typeof showToast === 'function') showToast(data.message || data.title, data.type || 'info');
        });

        connection.on("ReceiveMessage", function(msg) {
          if (typeof window.handleIncomingMessage === 'function') window.handleIncomingMessage(msg);
          if (typeof showToast === 'function') showToast(msg.senderName + ': ' + msg.content, 'info');
        });

        connection.on("UserOnline", function(data) {
          if (typeof window.handleUserOnline === 'function') window.handleUserOnline(data);
        });

        connection.on("UserOffline", function(data) {
          if (typeof window.handleUserOffline === 'function') window.handleUserOffline(data);
        });

        connection.on("UserTyping", function(data) {
          if (typeof window.handleUserTyping === 'function') window.handleUserTyping(data);
        });

        connection.on("MessagesRead", function(data) {
          if (typeof window.handleMessagesRead === 'function') window.handleMessagesRead(data);
        });

        connection.on("MessageSent", function(msg) {
          if (typeof window.handleMessageSent === 'function') window.handleMessageSent(msg);
        });

        window.chatConnection = connection;

        connection.start().then(function() {
          connection.invoke("JoinUserGroup", userId).catch(function(){});
        }).catch(function(){});

        document.dispatchEvent(new CustomEvent('chatConnectionReady'));
      })();
    </script>
    @* ── Global Confirm Delete Modal ── *@
    <div class="modal-overlay" id="confirmModal">
      <div class="modal-box">
        <h3 id="modalConfirmTitle">CONFIRM DELETE</h3>
        <p id="modalConfirmMessage" style="margin-bottom:24px;">Are you sure you want to proceed?</p>
        <div class="modal-actions">
          <button class="btn btn-danger" id="modalConfirmBtn" onclick="if(window.modalConfirmCb)window.modalConfirmCb()">DELETE</button>
          <button class="btn btn-secondary" onclick="closeModal('confirmModal')">CANCEL</button>
        </div>
      </div>
    </div>

    <footer style="text-align:center;padding:20px 40px;font-family:var(--font-mono);font-size:10px;color:#555;border-top:1px solid rgba(255,255,255,0.04);margin-top:40px;">
        <a asp-area="" asp-controller="Support" asp-action="Index" style="color:#555;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#555'">Support Center</a>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
