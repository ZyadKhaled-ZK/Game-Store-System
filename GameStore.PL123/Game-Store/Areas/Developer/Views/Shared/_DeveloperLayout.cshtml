<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Developer Portal</title>
    @await RenderSectionAsync("MetaTags", required: false)
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;500;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+" crossorigin="anonymous" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js" integrity="sha384-/taWmisziXYpcfnYsumSUmNaiMvG/fF/OJOUCLnqCIYTrpOZy7WbFF6FfIxwOrfL" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/developer.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav>
      <a asp-area="Developer" asp-controller="Dashboard" asp-action="Index" class="nav-logo">
        <span class="nav-logo-text">DEV <span>PORTAL</span></span>
      </a>
      <button class="nav-toggle" aria-label="Toggle navigation"><span></span><span></span><span></span></button>
      <ul class="nav-links">
        <li><a asp-area="Developer" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li><a asp-area="Developer" asp-controller="Games" asp-action="Index">My Games</a></li>
        <li><a asp-area="Developer" asp-controller="Sales" asp-action="Index">Sales</a></li>
        <li><a asp-area="Developer" asp-controller="Reviews" asp-action="Index">Reviews</a></li>
        <li><a asp-area="Developer" asp-controller="Profile" asp-action="Index">Profile</a></li>
        <li><a asp-area="" asp-controller="Friends" asp-action="Index"><i class="bi bi-people"></i> Social</a></li>
        <li><a asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-arrow-return-left"></i> Store</a></li>
        <li><a asp-area="" asp-controller="Auth" asp-action="Logout" class="btn btn-secondary nav-logout">Logout</a></li>
      </ul>
    </nav>

    <div class="toast-container" id="toastContainer"></div>

    <main>
        @RenderBody()
    </main>

    <script>
      (function() {
        // ── Active Nav Link ──
        var path = window.location.pathname.toLowerCase();
        document.querySelectorAll('nav .nav-links a').forEach(function(a) {
          var href = a.getAttribute('href').toLowerCase();
          if (href !== '/' && path.indexOf(href) >= 0) a.classList.add('active');
        });

        // ── Form Loading ──
        document.querySelectorAll('form').forEach(function(f) {
          f.addEventListener('submit', function() {
            var btn = this.querySelector('.btn[type="submit"], button[type="submit"]');
            if (btn) {
              btn.classList.add('loading');
              setTimeout(function() { btn.classList.remove('loading'); }, 2000);
            }
          });
        });

        // ── Toast ──
        var msgEl = document.getElementById('alertMessage');
        if (msgEl && window.showToast) {
          var msg = msgEl.getAttribute('data-msg');
          var isErr = msgEl.getAttribute('data-error') === 'true';
          if (msg) showToast(msg, isErr ? 'error' : 'success');
        }

        // ── Stat Counter ──
        document.querySelectorAll('.stat-value[data-count]').forEach(function(el) {
          var target = parseInt(el.getAttribute('data-count'), 10);
          if (isNaN(target)) return;
          var suffix = el.getAttribute('data-suffix') || '';
          var duration = 1200;
          var start = performance.now();
          function step(now) {
            var p = Math.min((now - start) / duration, 1);
            el.textContent = Math.floor(p * target) + suffix;
            if (p < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        });

        // ── Typewriter ──
        document.querySelectorAll('[data-typewrite]').forEach(function(el) {
          var text = el.getAttribute('data-typewrite');
          el.textContent = '';
          var i = 0;
          function type() {
            if (i < text.length) {
              el.textContent += text.charAt(i);
              i++;
              setTimeout(type, 40 + Math.random() * 30);
            }
          }
          setTimeout(type, 600);
        });

        // ── Copy Trigger ──
        document.querySelectorAll('.copy-trigger').forEach(function(el) {
          el.addEventListener('click', function() {
            var val = this.getAttribute('data-copy');
            if (!val) return;
            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText(val);
            } else {
              var ta = document.createElement('textarea');
              ta.value = val; ta.style.position = 'fixed'; ta.style.opacity = '0';
              document.body.appendChild(ta); ta.select(); document.execCommand('copy');
              document.body.removeChild(ta);
            }
            this.classList.add('copied');
            var tip = this.querySelector('.copy-tip');
            if (tip) tip.textContent = 'COPIED!';
            var self = this;
            setTimeout(function() {
              self.classList.remove('copied');
              if (tip) tip.textContent = 'CLICK TO COPY';
            }, 2000);
          });
        });

        // ── Modal ──
        window.showModal = function(id) {
          var el = document.getElementById(id);
          if (el) el.classList.add('show');
        };
        window.closeModal = function(id) {
          var el = document.getElementById(id);
          if (el) el.classList.remove('show');
        };
        document.querySelectorAll('.modal-overlay').forEach(function(m) {
          m.addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('show');
          });
        });

        // ── Global confirm dialog ──
        window.confirmAction = function(title, message, cb) {
          document.getElementById('modalConfirmTitle').textContent = title;
          document.getElementById('modalConfirmMessage').textContent = message;
          window.modalConfirmCb = cb;
          showModal('confirmModal');
        };
      })();
    </script>
    <script>
      // ── Toast system ──
      function showToast(message, type) {
        type = type || 'success';
        var container = document.getElementById('toastContainer');
        if (!container) return;
        var icons = { success: 'bi-check-circle-fill', error: 'bi-x-circle-fill', warning: 'bi-exclamation-triangle-fill' };
        var toast = document.createElement('div');
        toast.className = 'toast ' + type;
        toast.style.display = 'flex';
        toast.style.alignItems = 'center';
        toast.style.gap = '10px';
        toast.innerHTML = '<i class="bi ' + (icons[type] || icons.success) + '"></i>' +
          '<div class="toast-content">' + message + '</div>' +
          '<button class="toast-close" onclick="this.parentElement.remove()">&times;</button>';
        container.appendChild(toast);
        setTimeout(function() {
          if (toast.parentElement) {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(100%)';
            toast.style.transition = 'all 0.3s';
            setTimeout(function() { if (toast.parentElement) toast.remove(); }, 300);
          }
        }, 4000);
      }
      // ── Initial toast from server ──
      (function() {
        var msgEl = document.getElementById('alertMessage');
        if (msgEl) {
          var msg = msgEl.getAttribute('data-msg');
          var isErr = msgEl.getAttribute('data-error') === 'true';
          if (msg) showToast(msg, isErr ? 'error' : 'success');
        }
      })();
    </script>
    <script>
      (function() {
        var userId = '@Context.Session.GetString("UserId")';
        if (!userId) return;
        var connection = new signalR.HubConnectionBuilder()
          .withUrl("/hub/notifications")
          .withAutomaticReconnect()
          .build();
        connection.on("ReceiveNotification", function(data) {
          if (typeof showToast === 'function') showToast(data.message || data.title, data.type || 'info');
        });

        connection.on("ReceiveMessage", function(msg) {
          if (typeof window.handleIncomingMessage === 'function') window.handleIncomingMessage(msg);
          if (typeof showToast === 'function') showToast(msg.senderName + ': ' + msg.content, 'info');
        });

        connection.on("UserOnline", function(data) {
          if (typeof window.handleUserOnline === 'function') window.handleUserOnline(data);
        });

        connection.on("UserOffline", function(data) {
          if (typeof window.handleUserOffline === 'function') window.handleUserOffline(data);
        });

        connection.on("UserTyping", function(data) {
          if (typeof window.handleUserTyping === 'function') window.handleUserTyping(data);
        });

        connection.on("MessagesRead", function(data) {
          if (typeof window.handleMessagesRead === 'function') window.handleMessagesRead(data);
        });

        connection.on("MessageSent", function(msg) {
          if (typeof window.handleMessageSent === 'function') window.handleMessageSent(msg);
        });

        window.chatConnection = connection;

        connection.start().then(function() {
          connection.invoke("JoinUserGroup", userId).catch(function(){});
        }).catch(function(){});

        document.dispatchEvent(new CustomEvent('chatConnectionReady'));
      })();
    </script>
    @* ── Global Confirm Delete Modal ── *@
    <div class="modal-overlay" id="confirmModal">
      <div class="modal-box">
        <h3 id="modalConfirmTitle">CONFIRM DELETE</h3>
        <p id="modalConfirmMessage" class="mb-18">Are you sure you want to proceed?</p>
        <div class="modal-actions">
          <button class="btn btn-danger" id="modalConfirmBtn" onclick="if(window.modalConfirmCb)window.modalConfirmCb()">DELETE</button>
          <button class="btn btn-secondary" onclick="closeModal('confirmModal')">CANCEL</button>
        </div>
      </div>
    </div>

    <footer class="dev-footer">
        <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
        <span>·</span>
        <a asp-area="" asp-controller="Support" asp-action="Index">Support Center</a>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
