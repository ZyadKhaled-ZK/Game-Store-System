@model PagedResult<Sale>

<style>
  @@media (max-width: 768px) {
    .page-header.flex-between { flex-direction: column; align-items: stretch !important; gap: 12px; }
    .page-header.flex-between .btn { width: 100%; text-align: center; }
  }
  @@media (max-width: 576px) {
    .page-header.flex-between h1 { font-size: 1.2rem; }
    .empty-state { padding: 40px 20px; }
  }
</style>

<div id="alertMessage" data-msg="@ViewData["Message"]" data-error="@ViewData["IsError"]"></div>

<div class="page-header flex-between" style="align-items:flex-end;">
    <div>
        <h1>Sales & Offers</h1>
        <p>Create and manage discount sales for your games.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ NEW SALE</a>
</div>

@if (!Model.Items.Any())
{
    <div class="empty-state">
        <h3>NO SALES YET</h3>
        <p>Create a sale offer for one of your games.</p>
        <a asp-action="Create" class="btn btn-primary">CREATE SALE</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="cyber-table">
            <thead>
                <tr>
                    <th>GAME</th>
                    <th>ORIGINAL</th>
                    <th>SALE PRICE</th>
                    <th>PERIOD</th>
                    <th>STATUS</th>
                    <th>SUBMITTED</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sale in Model.Items)
                {
                    <tr>
                        <td class="fw-700" style="color:white;">@(sale.Game?.Title ?? "Unknown")</td>
                        <td class="price-original">$@(sale.Game?.Price.ToString("N2") ?? "0.00")</td>
                        <td class="price-sale">$@sale.NewPrice.ToString("N2")</td>
                        <td class="fs-12">
                            @sale.StartDate.ToString("MMM dd") - @sale.EndDate.ToString("MMM dd, yyyy")
                        </td>
                        <td>
                            @{
                                var statusLabel = sale.Status switch
                                {
                                    SaleStatus.Pending => "PENDING",
                                    SaleStatus.Approved when sale.IsActive => "ACTIVE",
                                    SaleStatus.Approved => "SCHEDULED",
                                    SaleStatus.Rejected => "REJECTED",
                                    SaleStatus.Cancelled => "CANCELLED",
                                    SaleStatus.Expired => "EXPIRED",
                                    _ => sale.Status.ToString().ToUpper()
                                };
                                var statusColor = sale.Status switch
                                {
                                    SaleStatus.Pending => "var(--gold)",
                                    SaleStatus.Approved when sale.IsActive => "#4ade80",
                                    SaleStatus.Approved => "var(--cyan)",
                                    SaleStatus.Rejected => "var(--red)",
                                    SaleStatus.Cancelled => "var(--text-dim)",
                                    SaleStatus.Expired => "var(--text-dim)",
                                    _ => "var(--text-dim)"
                                };
                            }
                            <span class="status-badge" style="color:@statusColor;">@statusLabel</span>
                            @if (sale.Status == SaleStatus.Rejected && !string.IsNullOrEmpty(sale.RejectReason))
                            {
                                <br/><span class="fs-10 text-dim">@sale.RejectReason</span>
                            }
                        </td>
                        <td class="fs-11 text-dim">@sale.CreatedAt.ToString("MMM dd, yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model" />
}
