@model Developer?
@{
    var hasProfile = (bool)(ViewData["HasProfile"] ?? false);
    var devName = ViewData["DeveloperName"] ?? "Developer";
    var gameCount = (int)(ViewData["GameCount"] ?? 0);
    var totalDownloads = (int)(ViewData["TotalDownloads"] ?? 0);
    var totalReviews = (int)(ViewData["TotalReviews"] ?? 0);
    var totalRevenue = (int)(ViewData["TotalRevenue"] ?? 0);
    var avgRating = (double)(ViewData["AvgRating"] ?? 0.0);
    var gameStats = ViewData["GameStats"] as List<(Game Game, int Downloads, double AvgRating, int ReviewCount)> ?? new();
    var recentReviews = ViewData["RecentReviews"] as List<Review> ?? new();
    var maxDownloads = gameStats.Any() ? gameStats.Max(gs => gs.Downloads) : 0;
}

<div id="alertMessage" data-msg="@TempData["Message"]" data-error="@TempData["IsError"]"></div>

@if (!hasProfile)
{
    <div class="card" style="text-align:center;padding:80px;">
        <div style="font-size:40px;color:var(--cyan);opacity:0.3;margin-bottom:16px;"><i class="bi bi-person-x-fill"></i></div>
        <h3 style="font-size:18px;color:var(--gold);margin-bottom:16px;">NO PROFILE FOUND</h3>
        <p style="color:var(--text-dim);margin-bottom:24px;">Create your developer profile to start publishing games and tracking your stats.</p>
        <a asp-area="Developer" asp-controller="Profile" asp-action="Index" class="btn btn-primary">CREATE PROFILE</a>
    </div>
}
else
{
    <div class="page-header" style="display:flex;justify-content:space-between;align-items:flex-end;">
        <div>
            <h1 class="glitch-hover" data-text="Dashboard">Dashboard</h1>
            <p><span data-typewrite="Welcome back, @devName."></span></p>
        </div>
        <div style="display:flex;gap:10px;align-items:center;">
            @if (Model?.Id != null)
            {
                <span class="copy-trigger" data-copy="@Model.Id.ToString()" style="font-family:var(--font-mono);font-size:10px;color:var(--text-dim);padding:6px 10px;border:1px solid var(--border-cyan);">
                    <i class="bi bi-clipboard"></i> ID
                    <span class="copy-tip">CLICK TO COPY</span>
                </span>
            }
            <a asp-area="" asp-controller="Developers" asp-action="Details" asp-route-id="@Model?.Id" class="btn btn-secondary" target="_blank"><i class="bi bi-box-arrow-up-right"></i> PUBLIC PROFILE</a>
        </div>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-value" data-count="@gameCount">0</div>
            <div class="stat-label">Games Published</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" data-count="@totalDownloads">0</div>
            <div class="stat-label">Downloads</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" data-count="@totalReviews">0</div>
            <div class="stat-label">Reviews</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="font-size:28px;" data-count="@totalRevenue" data-suffix="">$@totalRevenue</div>
            <div class="stat-label">Revenue</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">
                @if (avgRating > 0)
                {
                    <span>@avgRating.ToString("0.0")</span>
                }
                else
                {
                    <span style="font-size:16px;color:var(--text-dim);">—</span>
                }
            </div>
            <div class="stat-label">Avg Rating</div>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

        @* Recent Games *@
        <div class="card" style="padding:20px;">
            <h3 style="display:flex;justify-content:space-between;align-items:center;">
                <span><span class="pulse-dot" style="margin-right:8px;"></span>Recent Games</span>
                <a asp-area="Developer" asp-controller="Games" asp-action="Index" style="color:var(--cyan);font-size:10px;text-decoration:none;font-family:var(--font-mono);">VIEW ALL &rarr;</a>
            </h3>
            @if (!gameStats.Any())
            {
                <div style="text-align:center;padding:40px 20px;background:var(--bg3);border:1px dashed var(--border-cyan);">
                    <div style="font-size:32px;color:var(--cyan);opacity:0.2;margin-bottom:12px;"><i class="bi bi-controller"></i></div>
                    <p style="color:var(--text-dim);font-size:12px;font-family:var(--font-mono);margin-bottom:16px;">No games published yet.</p>
                    <a asp-area="Developer" asp-controller="Games" asp-action="Index" class="btn btn-primary">PUBLISH GAME</a>
                </div>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table class="cyber-table" style="font-size:12px;">
                        <thead>
                            <tr><th>Game</th><th style="text-align:center;">DL</th><th style="text-align:center;">Rating</th><th style="text-align:center;">Rev</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var gs in gameStats.Take(5))
                            {
                                var barPct = maxDownloads > 0 ? (gs.Downloads * 100.0 / maxDownloads) : 0;
                                <tr>
                                    <td style="color:var(--gold);max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@gs.Game.Title</td>
                                    <td style="text-align:center;">
                                        @gs.Downloads
                                        <div class="mini-bar" style="margin-top:4px;">
                                            <div class="mini-bar-track">
                                                <div class="mini-bar-fill" style="width:@(barPct)%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td style="text-align:center;">
                                        @if (gs.AvgRating > 0) { <span style="color:var(--gold);">@gs.AvgRating.ToString("0.0")</span> } else { <span style="color:var(--text-dim);">—</span> }
                                    </td>
                                    <td style="text-align:center;color:var(--text-dim);">@gs.ReviewCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @* Recent Reviews *@
        <div class="card" style="padding:20px;">
            <h3 style="display:flex;justify-content:space-between;align-items:center;">
                <span><i class="bi bi-chat-dots" style="color:var(--cyan);margin-right:6px;"></i>Recent Reviews</span>
                <a asp-area="Developer" asp-controller="Reviews" asp-action="Index" style="color:var(--cyan);font-size:10px;text-decoration:none;font-family:var(--font-mono);">VIEW ALL &rarr;</a>
            </h3>
            @if (!recentReviews.Any())
            {
                <div style="text-align:center;padding:40px 20px;">
                    <div style="font-size:32px;color:var(--cyan);opacity:0.2;margin-bottom:12px;"><i class="bi bi-chat-dots"></i></div>
                    <p style="color:var(--text-dim);font-size:12px;font-family:var(--font-mono);">No reviews yet. They will appear here once players rate your games.</p>
                </div>
            }
            else
            {
                <div style="max-height:250px;overflow-y:auto;">
                    @foreach (var r in recentReviews)
                    {
                        <div style="padding:12px 0;border-bottom:1px solid rgba(0,229,255,0.06);transition:background 0.2s;padding-left:8px;" onmouseover="this.style.background='rgba(0,229,255,0.03)'" onmouseout="this.style.background='transparent'">
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
                                <span style="font-family:var(--font-mono);font-size:11px;color:var(--cyan);">@@@r.User?.Username</span>
                                <span style="color:var(--gold);font-size:13px;letter-spacing:2px;">
                                    @(new string('\u2605', r.Rating))<span style="color:var(--text-dim);">@(new string('\u2605', 5 - r.Rating))</span>
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(r.Comment))
                            {
                                <p style="font-size:13px;color:var(--text);margin:4px 0 2px;word-wrap:break-word;">@r.Comment</p>
                            }
                            <span style="font-size:10px;color:var(--text-dim);font-family:var(--font-mono);">@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @* Quick Actions *@
    <div class="card" style="padding:20px;">
        <h3>Quick Actions</h3>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <a asp-area="Developer" asp-controller="Games" asp-action="Index" class="btn btn-primary"><i class="bi bi-controller"></i> MANAGE GAMES</a>
            <a asp-area="Developer" asp-controller="Reviews" asp-action="Index" class="btn btn-secondary"><i class="bi bi-star"></i> REVIEWS</a>
            <a asp-area="Developer" asp-controller="Profile" asp-action="Index" class="btn btn-secondary"><i class="bi bi-person-gear"></i> PROFILE</a>
            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-secondary"><i class="bi bi-shop"></i> STORE</a>
        </div>
    </div>
}


