@model Developer?
@{
    var hasProfile = (bool)(ViewData["HasProfile"] ?? false);
    var devName = ViewData["DeveloperName"] ?? "Developer";
    var gameCount = (int)(ViewData["GameCount"] ?? 0);
    var totalDownloads = (int)(ViewData["TotalDownloads"] ?? 0);
    var totalReviews = (int)(ViewData["TotalReviews"] ?? 0);
    var totalRevenue = (int)(ViewData["TotalRevenue"] ?? 0);
    var avgRating = (double)(ViewData["AvgRating"] ?? 0.0);
    var gameStats = ViewData["GameStats"] as List<(Game Game, int Downloads, double AvgRating, int ReviewCount, decimal TotalRevenue)> ?? new();
    var recentReviews = ViewData["RecentReviews"] as List<Review> ?? new();
    var maxDownloads = gameStats.Any() ? gameStats.Max(gs => gs.Downloads) : 0;
}

<style>
  @@media (max-width: 768px) {
    .page-header.flex-between { flex-direction: column; align-items: flex-start !important; gap: 12px; }
    .page-header.flex-between .flex { width: 100%; }
    .page-header.flex-between .btn { width: 100%; text-align: center; }
    .empty-state { padding: 40px 20px; }
    .quick-actions { flex-direction: column; }
    .quick-actions .btn { width: 100%; text-align: center; }
    .review-meta { flex-direction: column; align-items: flex-start; gap: 4px; }
  }
  @@media (max-width: 576px) {
    .page-header.flex-between h1 { font-size: 1.2rem; letter-spacing: 1px; }
    .empty-state { padding: 30px 16px; }
  }
</style>

<div id="alertMessage" data-msg="@TempData["Message"]" data-error="@TempData["IsError"]"></div>

@if (!hasProfile)
{
    <div class="empty-state">
        <div class="empty-state-icon"><i class="bi bi-person-x-fill"></i></div>
        <h3 style="font-size:18px;color:var(--gold);margin-bottom:16px;">NO PROFILE FOUND</h3>
        <p style="color:var(--text-dim);margin-bottom:24px;">Create your developer profile to start publishing games and tracking your stats.</p>
        <a asp-area="Developer" asp-controller="Profile" asp-action="Index" class="btn btn-primary">CREATE PROFILE</a>
    </div>
}
else
{
    <div class="page-header flex-between" style="align-items:flex-end;">
        <div>
            <h1 class="glitch-hover" data-text="Dashboard">Dashboard</h1>
            <p><span data-typewrite="Welcome back, @devName."></span></p>
        </div>
        <div class="flex gap-10" style="align-items:center;">
            @if (Model?.Id != null)
            {
                <span class="copy-trigger text-mono fs-10 text-dim" style="padding:6px 10px;border:1px solid var(--border-cyan);">
                    <i class="bi bi-clipboard"></i> ID
                    <span class="copy-tip">CLICK TO COPY</span>
                </span>
            }
            <a asp-area="" asp-controller="Developers" asp-action="Details" asp-route-id="@Model?.Id" class="btn btn-secondary" target="_blank"><i class="bi bi-box-arrow-up-right"></i> PUBLIC PROFILE</a>
        </div>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-value" data-count="@gameCount">0</div>
            <div class="stat-label">Games Published</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" data-count="@totalDownloads">0</div>
            <div class="stat-label">Downloads</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" data-count="@totalReviews">0</div>
            <div class="stat-label">Reviews</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" data-count="@totalRevenue" data-suffix="">$@totalRevenue</div>
            <div class="stat-label">Revenue</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">
                @if (avgRating > 0)
                {
                    <span>@avgRating.ToString("0.0")</span>
                }
                else
                {
                    <span class="text-dim" style="font-size:16px;">—</span>
                }
            </div>
            <div class="stat-label">Avg Rating</div>
        </div>
    </div>

    <div class="grid-2" style="margin-bottom:20px;">

        @* Recent Games *@
        <div class="card p-20">
            <h3 class="section-header">
                <span><span class="pulse-dot" style="margin-right:8px;"></span>Recent Games</span>
                <a asp-area="Developer" asp-controller="Games" asp-action="Index">VIEW ALL &rarr;</a>
            </h3>
            @if (!gameStats.Any())
            {
                <div class="dashed-empty">
                    <div style="font-size:32px;color:var(--cyan);opacity:0.2;margin-bottom:12px;"><i class="bi bi-controller"></i></div>
                    <p class="text-mono text-dim fs-12" style="margin-bottom:16px;">No games published yet.</p>
                    <a asp-area="Developer" asp-controller="Games" asp-action="Index" class="btn btn-primary">PUBLISH GAME</a>
                </div>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table class="cyber-table mini-table">
                        <thead>
                            <tr><th>Game</th><th class="text-center">DL</th><th class="text-center">Rating</th><th class="text-center">Revenue</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var gs in gameStats.Take(5))
                            {
                                var barPct = maxDownloads > 0 ? (gs.Downloads * 100.0 / maxDownloads) : 0;
                                <tr>
                                    <td class="text-gold" style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@gs.Game.Title</td>
                                    <td style="text-align:center;">
                                        @gs.Downloads
                                        <div class="mini-bar" style="margin-top:4px;">
                                            <div class="mini-bar-track">
                                                <div class="mini-bar-fill" style="width:@(barPct)%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @if (gs.AvgRating > 0) { <span class="text-gold">@gs.AvgRating.ToString("0.0")</span> } else { <span class="text-dim">—</span> }
                                    </td>
                                    <td class="text-center text-mono text-dim">$@gs.TotalRevenue</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @* Recent Reviews *@
        <div class="card p-20">
            <h3 class="section-header">
                <span><i class="bi bi-chat-dots text-cyan" style="margin-right:6px;"></i>Recent Reviews</span>
                <a asp-area="Developer" asp-controller="Reviews" asp-action="Index">VIEW ALL &rarr;</a>
            </h3>
            @if (!recentReviews.Any())
            {
                <div style="text-align:center;padding:40px 20px;">
                    <div style="font-size:32px;color:var(--cyan);opacity:0.2;margin-bottom:12px;"><i class="bi bi-chat-dots"></i></div>
                    <p class="text-mono text-dim fs-12">No reviews yet. They will appear here once players rate your games.</p>
                </div>
            }
            else
            {
                <div style="max-height:250px;overflow-y:auto;">
                    @foreach (var r in recentReviews)
                    {
                        <div class="review-item" onmouseover="this.style.background='rgba(0,229,255,0.03)'" onmouseout="this.style.background='transparent'">
                            <div class="review-meta">
                                <span class="review-user">@@@r.User?.Username</span>
                                <span class="review-stars">
                                    @(new string('\u2605', r.Rating))<span class="review-stars-dim">@(new string('\u2605', 5 - r.Rating))</span>
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(r.Comment))
                            {
                                <p class="review-comment">@r.Comment</p>
                            }
                            <span class="review-date">@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @* Quick Actions *@
    <div class="card p-20">
        <h3>Quick Actions</h3>
        <div class="quick-actions">
            <a asp-area="Developer" asp-controller="Games" asp-action="Index" class="btn btn-primary"><i class="bi bi-controller"></i> MANAGE GAMES</a>
            <a asp-area="Developer" asp-controller="Reviews" asp-action="Index" class="btn btn-secondary"><i class="bi bi-star"></i> REVIEWS</a>
            <a asp-area="Developer" asp-controller="Profile" asp-action="Index" class="btn btn-secondary"><i class="bi bi-person-gear"></i> PROFILE</a>
            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-secondary"><i class="bi bi-shop"></i> STORE</a>
        </div>
    </div>
}


