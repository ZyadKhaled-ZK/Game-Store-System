@model PagedResult<Review>
@{
    var gameLookup = ViewData["GameLookup"] as Dictionary<string, string> ?? new();
}

<style>
  @@media (max-width: 576px) {
    .page-header h1 { font-size: 1.2rem; }
    .empty-state { padding: 40px 20px; }
  }
</style>

<div id="alertMessage" data-msg="@ViewData["Message"]" data-error="@ViewData["IsError"]"></div>

<div class="page-header">
    <h1>Game Reviews</h1>
    <p>Reviews and ratings from players on your published games.</p>
</div>

@if (!Model.Items.Any())
{
    <div class="empty-state">
        <h3>NO REVIEWS YET</h3>
        <p>Reviews will appear here once players rate your games.</p>
        <a asp-area="Developer" asp-controller="Games" asp-action="Index" class="btn btn-primary">MY GAMES</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="cyber-table">
            <thead>
                <tr>
                    <th>GAME</th>
                    <th>USER</th>
                    <th>RATING</th>
                    <th>COMMENT</th>
                    <th>DATE</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var review in Model.Items)
                {
                    <tr>
                        <td class="text-gold">@(gameLookup.GetValueOrDefault(review.GameId) ?? "Unknown")</td>
                        <td class="text-mono fs-12 text-dim">@review.User?.Username</td>
                        <td>
                            <span class="text-gold" style="font-family:var(--font-display);">
                            @for (int ri = 0; ri < review.Rating; ri++) { <text>★</text> }
                            @for (int ri = review.Rating; ri < 5; ri++) { <text>☆</text> }
                        </span>
                        </td>
                        <td style="max-width:300px;white-space:normal;word-wrap:break-word;color:var(--text);">
                            @if (!string.IsNullOrEmpty(review.Comment))
                            {
                                @review.Comment
                            }
                            else
                            {
                                <span class="text-dim" style="font-style:italic;">—</span>
                            }
                        </td>
                        <td class="fs-11 text-mono text-dim">@review.CreatedAt.ToString("yyyy-MM-dd")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model" />
}

<div class="mt-20">
    <a asp-area="Developer" asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">&lt; BACK TO DASHBOARD</a>
</div>
