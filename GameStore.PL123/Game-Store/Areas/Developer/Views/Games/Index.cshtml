@model List<Game>
@{
    var categories = ViewData["Categories"] as List<Category> ?? new();
    var devId = ViewData["DeveloperId"]?.ToString() ?? "";
}

<div id="alertMessage" data-msg="@ViewData["Message"]" data-error="@ViewData["IsError"]"></div>

<div class="page-header" style="display:flex;justify-content:space-between;align-items:flex-end;">
    <div>
        <h1>My Games</h1>
        <p>Manage your published games.</p>
    </div>
    <button type="button" class="btn btn-primary" onclick="openCreateModal()">+ NEW GAME</button>
</div>

@if (!Model.Any())
{
    <div class="card" style="text-align:center;padding:60px;">
        <h3 style="font-size:16px;color:var(--text-dim);">NO GAMES YET</h3>
        <p style="color:var(--text-dim);margin:10px 0 20px;">Publish your first game to the store.</p>
        <button type="button" class="btn btn-primary" onclick="openCreateModal()">PUBLISH GAME</button>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="cyber-table">
            <thead>
                <tr>
                    <th>TITLE</th>
                    <th>PRICE</th>
                    <th>RELEASED</th>
                    <th>CATEGORIES</th>
                    <th>FILE</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var game in Model)
                {
                    <tr>
                        <td style="color:var(--gold);">@game.Title</td>
                        <td style="font-family:var(--font-mono);">@(game.Price == 0 ? "FREE" : $"${game.Price:F2}")</td>
                        <td style="font-size:11px;">@game.ReleaseDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (game.GameCategories.Any())
                            {
                                @string.Join(", ", game.GameCategories.Select(gc => gc.Category?.Name))
                            }
                            else
                            {
                                <span style="color:var(--text-dim);">—</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(game.GameFileUrl))
                            {
                                <a href="@game.GameFileUrl" class="btn btn-secondary" style="padding:2px 8px;font-size:10px;text-decoration:none;" download="@(game.GameFileName ?? "game-file")"><i class="bi bi-download"></i> DL</a>
                            }
                            else
                            {
                                <span style="color:var(--text-dim);">—</span>
                            }
                        </td>
                        <td>
                            <button type="button" class="btn btn-secondary" style="padding:4px 10px;font-size:10px;margin-right:4px;" onclick="openEditModal('@game.Id', '@game.Title.Replace("'", "\\'")', '@Html.Raw((game.Description ?? "").Replace("'", "\\'").Replace("\r\n", "\\n").Replace("\n", "\\n"))', '@game.Price', '@game.ReleaseDate.ToString("yyyy-MM-dd")', '@(game.CoverImageUrl ?? "")', '@(game.TrailerUrl ?? "")', '@string.Join(",", game.GameCategories.Select(gc => gc.CategoryId))', '@(game.GameFileUrl ?? "")', '@(game.GameFileName ?? "")', '@game.GameFileSizeBytes')">EDIT</button>
                            <button type="button" class="btn btn-danger" style="padding:4px 10px;font-size:10px;" onclick="confirmAction('DELETE @game.Title?', 'Are you sure you want to delete this game? This action cannot be undone.', function(){ document.getElementById('deleteForm_@game.Id').submit(); })">DELETE</button>
                            <form method="post" asp-action="Delete" id="deleteForm_@game.Id" style="display:none;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@game.Id"/>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Create Modal -->
<div id="createModal" class="modal-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:2000;justify-content:center;align-items:center;">
  <div class="modal-box" style="background:var(--bg2);border:1px solid var(--border-cyan);max-width:600px;width:90%;max-height:90vh;overflow-y:auto;">
    <div class="modal-header" style="display:flex;justify-content:space-between;align-items:center;padding:20px;border-bottom:1px solid var(--border-cyan);">
      <span class="modal-title" style="font-family:var(--font-display);font-size:16px;letter-spacing:2px;color:var(--cyan);text-transform:uppercase;">New Game</span>
      <span class="modal-close" onclick="closeCreateModal()" style="cursor:pointer;font-size:24px;color:var(--text-dim);">&times;</span>
    </div>
    <form method="post" asp-action="Create" enctype="multipart/form-data">
      @Html.AntiForgeryToken()
      <div style="padding:20px;">
        <div class="form-group">
            <label>Title *</label>
            <input type="text" name="Title" class="form-control" required maxlength="200" />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea name="Description" class="form-control" maxlength="4000"></textarea>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
            <div class="form-group">
                <label>Price ($)</label>
                <input type="number" name="Price" class="form-control" step="0.01" min="0" max="9999.99" value="0" />
            </div>
            <div class="form-group">
                <label>Release Date *</label>
                <input type="date" name="ReleaseDate" class="form-control" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div class="form-group">
            <label>Cover Image URL</label>
            <input type="url" name="CoverImageUrl" class="form-control" maxlength="500" />
        </div>
        <div class="form-group">
            <label>Game File (ZIP/RAR/EXE)</label>
            <input type="file" name="GameFile" class="form-control" style="padding:8px 14px;" accept=".zip,.rar,.7z,.exe,.msi,.apk" />
        </div>
        <div class="form-group">
            <label>Trailer URL</label>
            <input type="url" name="TrailerUrl" class="form-control" maxlength="500" />
        </div>
        <div class="form-group">
            <label>Categories</label>
            <div style="display:flex;flex-wrap:wrap;gap:10px;">
                @foreach (var cat in categories)
                {
                    <label style="font-family:var(--font-mono);font-size:11px;display:flex;align-items:center;gap:6px;cursor:pointer;">
                        <input type="checkbox" name="CategoryIds" value="@cat.Id" />
                        @cat.Name
                    </label>
                }
            </div>
        </div>
      </div>
      <div class="modal-footer" style="display:flex;justify-content:flex-end;gap:10px;padding:20px;border-top:1px solid var(--border-cyan);">
        <button type="button" class="btn btn-secondary" onclick="closeCreateModal()">CANCEL</button>
        <button type="submit" class="btn btn-primary">PUBLISH</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Modal -->
<div id="editModal" class="modal-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:2000;justify-content:center;align-items:center;">
  <div class="modal-box" style="background:var(--bg2);border:1px solid var(--border-cyan);max-width:600px;width:90%;max-height:90vh;overflow-y:auto;">
    <div class="modal-header" style="display:flex;justify-content:space-between;align-items:center;padding:20px;border-bottom:1px solid var(--border-cyan);">
      <span class="modal-title" style="font-family:var(--font-display);font-size:16px;letter-spacing:2px;color:var(--cyan);text-transform:uppercase;">Edit Game</span>
      <span class="modal-close" onclick="closeEditModal()" style="cursor:pointer;font-size:24px;color:var(--text-dim);">&times;</span>
    </div>
    <form method="post" asp-action="Edit" enctype="multipart/form-data">
      @Html.AntiForgeryToken()
      <input type="hidden" name="GameId" id="editGameId" />
      <div style="padding:20px;">
        <div class="form-group">
            <label>Title *</label>
            <input type="text" name="Title" id="editTitle" class="form-control" required maxlength="200" />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea name="Description" id="editDescription" class="form-control" maxlength="4000"></textarea>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
            <div class="form-group">
                <label>Price ($)</label>
                <input type="number" name="Price" id="editPrice" class="form-control" step="0.01" min="0" max="9999.99" />
            </div>
            <div class="form-group">
                <label>Release Date *</label>
                <input type="date" name="ReleaseDate" id="editReleaseDate" class="form-control" required />
            </div>
        </div>
        <div class="form-group">
            <label>Cover Image URL</label>
            <input type="url" name="CoverImageUrl" id="editCoverImageUrl" class="form-control" maxlength="500" />
        </div>
        <div class="form-group">
            <label>Game File (ZIP/RAR/EXE)</label>
            <input type="file" name="GameFile" id="editGameFile" class="form-control" style="padding:8px 14px;" accept=".zip,.rar,.7z,.exe,.msi,.apk" />
            <div id="currentFileInfo" style="display:none; margin-top:8px; font-family:var(--font-mono); font-size:12px; color:var(--text-dim); padding:8px 12px; background:var(--bg3); border:1px solid var(--border-cyan);">
              <span style="color:var(--cyan);">CURRENT FILE:</span>
              <span id="currentFileName"></span>
              <label style="margin-left:16px; cursor:pointer; color:var(--red);">
                <input type="checkbox" name="RemoveGameFile" value="true" id="editRemoveGameFile" style="accent-color:var(--red);"/>
                REMOVE FILE
              </label>
            </div>
        </div>
        <div class="form-group">
            <label>Trailer URL</label>
            <input type="url" name="TrailerUrl" id="editTrailerUrl" class="form-control" maxlength="500" />
        </div>
        <div class="form-group">
            <label>Categories</label>
            <div style="display:flex;flex-wrap:wrap;gap:10px;">
                @foreach (var cat in categories)
                {
                    <label style="font-family:var(--font-mono);font-size:11px;display:flex;align-items:center;gap:6px;cursor:pointer;">
                        <input type="checkbox" name="CategoryIds" value="@cat.Id" class="edit-cat" data-cat-id="@cat.Id" />
                        @cat.Name
                    </label>
                }
            </div>
        </div>
      </div>
      <div class="modal-footer" style="display:flex;justify-content:flex-end;gap:10px;padding:20px;border-top:1px solid var(--border-cyan);">
        <button type="button" class="btn btn-secondary" onclick="closeEditModal()">CANCEL</button>
        <button type="submit" class="btn btn-primary">UPDATE</button>
      </div>
    </form>
  </div>
</div>

@section Scripts {
<script>
function fmtSize(bytes) {
    if (!bytes || bytes == 0 || bytes == '0') return '';
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + ' KB';
    if (bytes < 1024*1024*1024) return (bytes/(1024*1024)).toFixed(1) + ' MB';
    return (bytes/(1024*1024*1024)).toFixed(2) + ' GB';
}

function openCreateModal() { document.getElementById('createModal').style.display = 'flex'; }
function closeCreateModal() { document.getElementById('createModal').style.display = 'none'; }
document.getElementById('createModal').addEventListener('click', function(e) { if (e.target === this) closeCreateModal(); });

function openEditModal(id, title, desc, price, releaseDate, cover, trailer, catIds, fileUrl, fileName, fileSize) {
    document.getElementById('editGameId').value = id;
    document.getElementById('editTitle').value = title;
    document.getElementById('editDescription').value = desc.replace(/\\n/g, '\n');
    document.getElementById('editPrice').value = price;
    document.getElementById('editReleaseDate').value = releaseDate;
    document.getElementById('editCoverImageUrl').value = cover;
    document.getElementById('editTrailerUrl').value = trailer;
    document.getElementById('editGameFile').value = '';
    document.getElementById('editRemoveGameFile').checked = false;
    document.querySelectorAll('.edit-cat').forEach(function(cb) { cb.checked = false; });
    if (catIds) {
        catIds.split(',').forEach(function(cid) {
            var cb = document.querySelector('.edit-cat[data-cat-id="' + cid + '"]');
            if (cb) cb.checked = true;
        });
    }
    var fileInfo = document.getElementById('currentFileInfo');
    if (fileUrl) {
        fileInfo.style.display = 'block';
        document.getElementById('currentFileName').textContent = fileName || 'GAME FILE';
    } else {
        fileInfo.style.display = 'none';
    }
    document.getElementById('editModal').style.display = 'flex';
}
function closeEditModal() { document.getElementById('editModal').style.display = 'none'; }
document.getElementById('editModal').addEventListener('click', function(e) { if (e.target === this) closeEditModal(); });
</script>
}
