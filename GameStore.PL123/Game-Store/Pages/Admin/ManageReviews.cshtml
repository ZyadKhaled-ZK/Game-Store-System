@page
@model GameStore.PL.Pages.Admin.ManageReviewsModel
@{
    ViewData["Title"] = "Review Monitor";
    Layout = "_AdminLayout";
}

<style>
  .page-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 16px; margin-bottom: 32px; }
  .filter-bar { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 24px; }
  .gs-search-input {
    background: var(--bg2); border: 1px solid var(--border-red); color: var(--text);
    padding: 10px 16px; font-family: var(--font-mono); font-size: 12px; width: 300px; outline: none;
  }
  .gs-search-input:focus { border-color: var(--red); }
  .gs-search-input::placeholder { color: var(--text-dim); }

  .star-display { color: var(--gold); letter-spacing: 2px; font-size: 14px; }
  .star-empty   { color: var(--bg3); }
  .comment-cell { max-width: 300px; color: var(--text-dim); font-size: 13px; font-style: italic; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .rating-filter {
    background: var(--bg2); border: 1px solid var(--border-red); color: var(--text);
    padding: 10px 16px; font-family: var(--font-mono); font-size: 12px; outline: none; cursor: pointer;
  }
  .rating-filter option { background: var(--bg2); }

  .review-row { transition: background 0.2s; }
  .review-row td { transition: color 0.2s; }
  .review-row:hover td { color: white; }
</style>

<div class="page-header">
  <div>
    <div class="section-tag">Content Moderation</div>
    <h2 class="section-title glitch">REVIEW MONITOR</h2>
  </div>
  <a href="/Admin/Dashboard" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Dashboard</a>
</div>

<div class="filter-bar">
  <input type="text" id="searchInput" class="gs-search-input" placeholder="Search by user, game, or comment..."/>
  <select id="ratingFilter" class="rating-filter">
    <option value="">ALL RATINGS</option>
    <option value="5"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i> 5</option>
    <option value="4"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i> 4</option>
    <option value="3"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i> 3</option>
    <option value="2"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i> 2</option>
    <option value="1"><i class="bi bi-star-fill"></i> 1</option>
  </select>
  <span style="font-family:var(--font-mono); font-size:12px; color:var(--text-dim);">
    [ <span id="reviewCount">@Model.Reviews.Count</span> RECORDS ]
  </span>
</div>

<div class="table-responsive">
<table class="cyber-table" id="reviewsTable">
  <thead>
    <tr>
      <th>User</th>
      <th>Game</th>
      <th>Rating</th>
      <th>Comment</th>
      <th>Date</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    @foreach (var review in Model.Reviews)
    {
      <tr class="review-row"
        data-search="@(review.User?.Username ?? "").ToLower() @(review.Game?.Title ?? "").ToLower() @(review.Comment ?? "").ToLower()"
        data-rating="@review.Rating">
        <td style="color: var(--gold);">@(review.User?.Username ?? "—")</td>
        <td style="font-family: var(--font-display); font-size: 12px; color: white; font-weight: 700;">@(review.Game?.Title ?? "—")</td>
        <td>
          <span class="star-display">
            @for (int i = 1; i <= 5; i++)
            {
              if (i <= review.Rating) { <text><i class="bi bi-star-fill"></i></text> } else { <span class="star-empty"><i class="bi bi-star"></i></span> }
            }
          </span>
          <span style="font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); margin-left: 6px;">@review.Rating/5</span>
        </td>
        <td class="comment-cell" title="@review.Comment">@(string.IsNullOrEmpty(review.Comment) ? "— no comment —" : review.Comment)</td>
        <td style="font-family: var(--font-mono); font-size: 12px; color: var(--text-dim);">@review.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
        <td>
          <form method="post" asp-page-handler="Delete" asp-route-id="@review.Id" style="display:inline;"
            onsubmit="return confirm('DELETE this review?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary ripple" style="padding:6px 12px; font-size:11px;">REMOVE</button>
          </form>
        </td>
      </tr>
    }
  </tbody>
</table>
</div>

@if (!Model.Reviews.Any())
{
  <div style="text-align:center; padding:80px; font-family:var(--font-mono); color:var(--text-dim);">
    [ NO REVIEWS IN DATABASE ]
  </div>
}

<script>
  const searchInput  = document.getElementById('searchInput');
  const ratingFilter = document.getElementById('ratingFilter');
  const rows = document.querySelectorAll('.review-row');

  function filterRows() {
    const q = searchInput.value.toLowerCase();
    const r = ratingFilter.value;
    let visible = 0;
    rows.forEach(row => {
      const matchQ = !q || row.dataset.search.includes(q);
      const matchR = !r || row.dataset.rating === r;
      const show = matchQ && matchR;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    document.getElementById('reviewCount').textContent = visible;
  }
  searchInput.addEventListener('input', filterRows);
  ratingFilter.addEventListener('change', filterRows);
</script>
