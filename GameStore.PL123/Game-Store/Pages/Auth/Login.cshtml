@page
@model GameStore.PL.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Dev Login";
    Layout = "_Layout";
}

<style>
  .login-box {
    background: var(--bg2);
    border: 1px solid var(--border-red);
    padding: 40px;
    box-shadow: var(--glow-red);
    animation: loginIn 0.4s ease;
    position: relative;
  }
  .login-box::before {
    content: '';
    position: absolute;
    inset: -1px;
    border: 1px solid transparent;
    background: linear-gradient(135deg, var(--red), transparent, var(--red)) border-box;
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s;
  }
  .login-box:hover::before { opacity: 1; }

  @Html.Raw("@keyframes loginIn { from { opacity: 0; transform: translateY(20px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }")

  .login-input {
    background: var(--bg3) !important;
    border: 1px solid var(--border-red) !important;
    color: var(--text) !important;
    border-radius: 0 !important;
    transition: all 0.25s !important;
    padding: 12px 16px !important;
    font-family: var(--font-mono) !important;
    font-size: 13px !important;
  }
  .login-input:hover {
    border-color: var(--red-dim) !important;
    box-shadow: 0 0 14px rgba(230,57,70,0.1) !important;
  }
  .login-input:focus {
    border-color: var(--red) !important;
    box-shadow: 0 0 0 2px #070709, 0 0 16px 3px rgba(230,57,70,0.35) !important;
    background: #0a0a0e !important;
  }
  .login-input::placeholder {
    color: var(--text-dim) !important;
    font-family: var(--font-mono);
    font-size: 12px;
  }
</style>

<div class="row w-100 justify-content-center mt-5 pt-5">
    <div class="col-md-5">
        <div class="section-header text-center mb-4">
            <h2 class="section-title glitch">DEV LOGIN</h2>
            <div class="section-tag d-inline-flex">Authentication Node</div>
        </div>

        <div class="login-box">
            <div style="color: var(--red); border: 1px solid var(--red); padding: 5px 15px; display: inline-block; font-size: 12px; margin-bottom: 20px; font-family: var(--font-mono);">
                SYS_ACCESS_REQUIRED
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div style="background: rgba(230,57,70,0.1); border: 1px solid var(--red); color: white; padding: 10px; margin-bottom: 15px; font-family: var(--font-mono); font-size: 12px;">
                    [ERROR] @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div class="mb-3">
                    <label asp-for="Email" class="form-label" style="color: var(--text-dim); font-family: var(--font-mono); font-size: 12px; letter-spacing: 1px;">Email_Address //:</label>
                    <input asp-for="Email" type="email" class="form-control login-input" placeholder="dev@gamestore.com" autocomplete="email"/>
                </div>
                <div class="mb-4">
                    <label asp-for="Password" class="form-label" style="color: var(--text-dim); font-family: var(--font-mono); font-size: 12px; letter-spacing: 1px;">Access_Code //:</label>
                    <input asp-for="Password" type="password" class="form-control login-input" placeholder="&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;" autocomplete="current-password"/>
                </div>

                <button type="submit" class="btn btn-primary w-100 d-block text-center mt-4 ripple">INITIALIZE LOGIN</button>
            </form>

            <div style="margin-top: 30px; font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); text-align: center; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 15px;">
                <strong style="color: var(--gold);">DEFAULT_CREDENTIALS</strong><br/>
                dev@gamestore.com | Dev@1234
            </div>
        </div>

        <div class="text-center mt-3">
            <a href="/" style="color: var(--text-dim); font-family: var(--font-mono); text-decoration: none; transition: all 0.2s;"
               onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text-dim)'">
                &lt; ABORT_CONNECTION
            </a>
        </div>
    </div>
</div>
