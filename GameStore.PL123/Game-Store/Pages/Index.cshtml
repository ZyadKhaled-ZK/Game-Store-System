<!-- HERO (featured = most recent game) -->
@if (Model.FeaturedGame != null)
{
    var fg = Model.FeaturedGame;
    var fgJson = System.Text.Json.JsonSerializer.Serialize(new {
        title = fg.Title,
        developer = fg.Developer ?? "UNKNOWN",
        price = fg.Price,
        description = fg.Description,
        trailerUrl = fg.TrailerUrl,
        screenshots = fg.ScreenshotUrls,
        coverImageUrl = fg.CoverImageUrl,
        releaseDate = fg.ReleaseDate.ToString("yyyy-MM-dd"),
        categories = fg.GameCategories.Select(gc => gc.Category.Name).ToList(),
        hasFile = fg.GameFileUrl != null,
        fileName = fg.GameFileName,
        fileSizeBytes = fg.GameFileSizeBytes
    });
    <div class="hero-section mt-5">
        <div class="hero-label"><span class="glitch" data-text="FEATURED_DATASET"><i class="bi bi-star-fill me-1"></i>FEATURED_DATASET</span></div>
        <div class="hero-card" onclick='openModal(@Html.Raw(fgJson))'>
            @if (!string.IsNullOrEmpty(fg.CoverImageUrl)) { <img class="hero-img" src="@fg.CoverImageUrl" alt="@fg.Title" /> }
            else if (fg.ScreenshotUrls.Any()) { <img class="hero-img" src="@fg.ScreenshotUrls[0]" alt="@fg.Title" /> }
            else { <div class="hero-placeholder">[ NO_VISUAL ]</div> }
            <div class="hero-overlay">
                <div class="hero-title glitch" data-text="@fg.Title.ToUpper()">@fg.Title.ToUpper()</div>
                <div class="hero-meta">
                    @foreach (var gc in fg.GameCategories.Take(4)) { <span class="hero-tag">@gc.Category.Name</span> }
                    <span class="hero-price @(fg.Price == 0 ? "price-free" : "price-paid")">@(fg.Price == 0 ? "FREE_ACCESS" : "CR " + fg.Price.ToString("F2"))</span>
                </div>
                @if (!string.IsNullOrEmpty(fg.Description)) { <div class="hero-desc">@(fg.Description.Length > 160 ? fg.Description[..157] + "..." : fg.Description)</div> }
            </div>
        </div>
    </div>
}

<!-- BROWSE -->
<div class="browse-section mt-4">
    <div class="browse-top">
        <div class="browse-title glitch" data-text="GLOBAL_DATABASE">GLOBAL_DATABASE</div>
        <div class="browse-controls">
            <div class="search-wrap">
                <span class="search-icon"><i class="bi bi-search"></i></span>
                <input type="text" id="searchInput" class="gs-search" placeholder="Query Matrix..." oninput="applyFilters()"/>
            </div>
            <select class="gs-sort" id="sortSelect" onchange="applyFilters()">
                <option value="newest">LATEST_SYNC</option>
                <option value="name">ALPHABETICAL (A-Z)</option>
                <option value="price-asc">CREDITS (LOW-HIGH)</option>
                <option value="price-desc">CREDITS (HIGH-LOW)</option>
                <option value="free">FREE_ACCESS_ONLY</option>
            </select>
        </div>
    </div>

    <div class="cat-pills">
        <div class="cat-pill active" onclick="selectCat(this,'')" data-cat="">[ ALL_MAPPING ]</div>
        @foreach (var cat in Model.Categories)
        {
            <div class="cat-pill" onclick="selectCat(this,'@cat.Name.ToLower()')" data-cat="@cat.Name.ToLower()">@cat.Name</div>
        }
    </div>

    <div class="games-grid" id="gamesGrid">
        @if (!Model.Games.Any())
        {
            <div class="empty-state">
                <h5 style="color:var(--red); font-family: var(--font-display);">CRITICAL: DATABASE EMPTY</h5>
                <p style="font-family: var(--font-mono); font-size: 0.9rem;">No entries found. <a href="/Auth/Login" style="color:var(--gold);">INITIATE_DEV_UPLINK →</a></p>
            </div>
        }
        else
        {
            @foreach (var game in Model.Games)
            {
                var cats = string.Join(" ", game.GameCategories.Select(gc => gc.Category.Name?.ToLower() ?? ""));
                var gameJson = System.Text.Json.JsonSerializer.Serialize(new { title = game.Title, developer = game.Developer ?? "UNKNOWN", price = game.Price, description = game.Description, trailerUrl = game.TrailerUrl, screenshots = game.ScreenshotUrls, coverImageUrl = game.CoverImageUrl, releaseDate = game.ReleaseDate.ToString("yyyy-MM-dd"), categories = game.GameCategories.Select(gc => gc.Category.Name).ToList(), hasFile = game.GameFileUrl != null, fileName = game.GameFileName, fileSizeBytes = game.GameFileSizeBytes });
                <div class="game-card" data-title="@game.Title.ToLower()" data-cats="@cats" data-price="@game.Price" data-date="@game.ReleaseDate.Ticks" onclick='openModal(@Html.Raw(gameJson))'>
                    @if (!string.IsNullOrEmpty(game.CoverImageUrl)) { <img class="game-card-img" src="@game.CoverImageUrl" alt="@game.Title" loading="lazy"/> }
                    else if (game.ScreenshotUrls.Any()) { <img class="game-card-img" src="@game.ScreenshotUrls[0]" alt="@game.Title" loading="lazy"/> }
                    else { <div class="game-card-placeholder">⊗</div> }
                    <div class="game-card-body">
                        <div class="game-card-title">@game.Title.ToUpper()</div>
                        <div class="game-card-dev">@((game.Developer ?? "Anon").ToUpper())</div>
                        <div class="game-card-tags">@foreach (var gc in game.GameCategories.Take(3)) { <span class="game-tag">@gc.Category.Name</span> }</div>
                        <div class="game-card-footer">
                            @if (game.Price == 0) { <span class="price-free">FREE</span> } else { <span class="price-paid">CR @game.Price.ToString("0.00")</span> }
                            @if (game.GameFileUrl != null) { <span class="has-file-badge">▼ BLK_DATA</span> }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="gs-modal-overlay" id="gameModal" onclick="closeModalOutside(event)">
    <div class="gs-modal">
        <button class="modal-close" onclick="closeModal()">✕</button>
        <div id="modalContent"></div>
    </div>
</div>

@section Scripts {
<script>
    let activeCat = '';
    function selectCat(el, cat) { document.querySelectorAll('.cat-pill').forEach(p => p.classList.remove('active')); el.classList.add('active'); activeCat = cat; applyFilters(); }
    function applyFilters() {
        const q = document.getElementById('searchInput').value.toLowerCase().trim();
        const sort = document.getElementById('sortSelect').value;
        const cards = Array.from(document.querySelectorAll('.game-card'));
        cards.forEach(c => {
            const matchTitle = c.dataset.title.includes(q);
            const matchCat = !activeCat || c.dataset.cats.includes(activeCat);
            const matchFree = sort !== 'free' || parseFloat(c.dataset.price) === 0;
            c.style.display = (matchTitle && matchCat && matchFree) ? '' : 'none';
        });
        const visible = cards.filter(c => c.style.display !== 'none');
        visible.sort((a, b) => {
            if (sort === 'name') return a.dataset.title.localeCompare(b.dataset.title);
            if (sort === 'price-asc') return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
            if (sort === 'price-desc') return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
            return parseInt(b.dataset.date) - parseInt(a.dataset.date);
        });
        const grid = document.getElementById('gamesGrid');
        visible.forEach(c => grid.appendChild(c));
    }
    function fmtSize(bytes) {
        if (!bytes || bytes === 0) return '';
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + ' KB';
        if (bytes < 1024*1024*1024) return (bytes/(1024*1024)).toFixed(1) + ' MB';
        return (bytes/(1024*1024*1024)).toFixed(2) + ' GB';
    }
    function openModal(game) {
        let html = '';
        const heroSrc = game.coverImageUrl || (game.screenshots && game.screenshots.length > 0 ? game.screenshots[0] : null);
        if (heroSrc) html += `<img class="modal-hero-img" src="${heroSrc}" alt="${game.title}"/>`;
        else html += `<div class="modal-hero-placeholder" style="background:#0d0d12;height:350px;display:flex;align-items:center;justify-content:center;color:#e63946;font-family:'Orbitron', monospace;font-size:3rem;border-bottom:2px solid #e63946;">NO_VISUAL_DATA</div>`;
        html += `<div class="modal-body">`;
        html += `<div class="modal-title glitch">${game.title.toUpperCase()}</div>`;
        html += `<div class="modal-meta"><span style="color:var(--gold);">SRC: ${game.developer}</span><span style="color:var(--text-dim);">SYNC: ${game.releaseDate}</span></div>`;
        if (game.categories && game.categories.length) html += `<div style="display:flex;gap:8px;margin-bottom:20px;">` + game.categories.map(c => `<span style="background:rgba(230,57,70,0.1);color:#e63946;border:1px solid rgba(230,57,70,0.4);padding:4px 10px;font-size:0.8rem;">${c}</span>`).join('') + `</div>`;
        if (game.description) html += `<p class="modal-desc">${game.description}</p>`;
        const shots = game.screenshots || [];
        const displayShots = shots.slice(game.coverImageUrl ? 0 : 1);
        if (displayShots.length > 0) html += `<div class="modal-screenshots">` + displayShots.map(s => `<img src="${s}" onclick="this.requestFullscreen && this.requestFullscreen()"/>`).join('') + `</div>`;
        if (game.trailerUrl) html += `<iframe class="modal-trailer" src="${game.trailerUrl}" allowfullscreen></iframe>`;
        html += `<div class="modal-price-box">`;
        if (game.price === 0) html += `<div class="modal-price-val" style="color:var(--gold);">FREE_OVERRIDE</div>`;
        else html += `<div class="modal-price-val">CR ${game.price.toFixed(2)}</div>`;
        if (game.hasFile) html += `<div style="display:flex;align-items:center;gap:15px;"><span style="font-size:1.5rem;color:var(--gold);">💾</span><div><div style="font-weight:bold;color:white;">${game.fileName || 'DATA_BLOCK'}</div><div style="font-size:0.8rem;color:var(--text-dim);">${fmtSize(game.fileSizeBytes)} OK</div></div></div>`;
        html += `</div>`;
        html += `<div class="viewer-only-note">[SECURE_ZONE] — <a href="/Auth/Login" style="color:var(--gold);text-decoration:none;">AUTHENTICATE</a> TO EDIT DATA TRACES.</div>`;
        html += `</div>`;
        document.getElementById('modalContent').innerHTML = html;
        document.getElementById('gameModal').classList.add('open');
        document.body.style.overflow = 'hidden';
    }
    function closeModal() { document.getElementById('gameModal').classList.remove('open'); document.body.style.overflow = ''; }
    function closeModalOutside(e) { if (e.target.id === 'gameModal') closeModal(); }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    // Ripple on game cards and category pills
    document.querySelectorAll('.game-card, .cat-pill').forEach(el => {
        el.classList.add('ripple');
        el.addEventListener('mousedown', function(e) {
            const rect = this.getBoundingClientRect();
            this.style.setProperty('--mx', (e.clientX - rect.left) + 'px');
            this.style.setProperty('--my', (e.clientY - rect.top) + 'px');
        });
    });
</script>
}
