@page
@model GameStore.PL.Pages.IndexModel
@{
    ViewData["Title"] = "Game Store";
    Layout = "_Layout";
}

<style>
    /* HERO / FEATURED */
    .hero-section { max-width: 1400px; margin: 28px auto 40px; padding: 0 24px; }
    .hero-label { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 3px; color: var(--gold); margin-bottom: 10px; font-family: var(--font-mono); }
    .hero-card { position: relative; border-radius: 0; overflow: hidden; border: 1px solid var(--border-red); cursor: pointer; display: flex; flex-direction: column; background: var(--bg2); box-shadow: 0 4px 20px rgba(0,0,0,0.3); }
    .hero-card::after { content: ''; position: absolute; inset: 0; pointer-events: none; border: 1px solid transparent; transition: border-color 0.3s; }
    .hero-card:hover::after { border-color: var(--red); box-shadow: inset 0 0 30px rgba(230,57,70,0.3); }
    
    .hero-img { width: 100%; height: 450px; object-fit: cover; display: block; opacity: 0.85; transition: opacity 0.3s, transform: 0.8s; filter: brightness(0.9); }
    .hero-card:hover .hero-img { opacity: 1; transform: scale(1.02); filter: brightness(1); }
    .hero-placeholder { width: 100%; height: 450px; background: repeating-linear-gradient(45deg, var(--bg2) 0, var(--bg2) 10px, var(--bg3) 10px, var(--bg3) 20px); display: flex; align-items: center; justify-content: center; font-size: 3rem; color: var(--red); }
    
    .hero-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(transparent, rgba(7,7,9,0.95) 80%); padding: 60px 40px 30px; border-top: 1px solid rgba(230,57,70,0.1); }
    .hero-title { font-family: var(--font-display); font-size: 2.8rem; font-weight: 900; color: white; margin-bottom: 10px; text-shadow: var(--glow-red); letter-spacing: 2px; }
    .hero-meta { display: flex; align-items: center; gap: 15px; margin-bottom: 18px; flex-wrap: wrap; font-family: var(--font-mono); }
    .hero-tag { background: rgba(230,57,70,0.15); color: var(--red); border: 1px solid rgba(230,57,70,0.3); padding: 3px 12px; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; }
    .hero-price { font-size: 1.5rem; font-weight: 700; color: var(--gold); text-shadow: var(--glow-gold); }
    .price-free { color: var(--gold-dim); }
    .hero-desc { color: var(--text-dim); font-size: 1rem; max-width: 800px; font-family: var(--font-ui); line-height: 1.5; }

    /* SEARCH & FILTER */
    .browse-section { max-width: 1400px; margin: 0 auto; padding: 0 24px; }
    .browse-top { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 25px; flex-wrap: wrap; border-bottom: 1px solid var(--border-red); padding-bottom: 15px; }
    .browse-title { font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: white; letter-spacing: 2px; }
    .browse-controls { display: flex; gap: 15px; align-items: center; flex-wrap: wrap; font-family: var(--font-mono); }
    
    .gs-search { background: var(--bg3); border: 1px solid var(--border-red); color: white; padding: 10px 14px 10px 38px; font-size: 0.9rem; width: 260px; outline: none; transition: all 0.2s; }
    .gs-search:hover { border-color: var(--red-dim); }
    .gs-search:focus { border-color: var(--red); box-shadow: var(--glow-red); }
    .search-wrap { position: relative; }
    .search-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--red); font-size: 0.9rem; pointer-events: none; }
    
    .gs-sort { background: var(--bg3); border: 1px solid var(--border-red); color: white; padding: 10px 15px; font-size: 0.9rem; cursor: pointer; outline: none; transition: all 0.2s; }
    .gs-sort:hover { border-color: var(--red-dim); }
    .gs-sort:focus { border-color: var(--red); box-shadow: var(--glow-red); }
    .gs-sort option { background: var(--bg2); color: white; }

    .cat-pills { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 30px; font-family: var(--font-mono); }
    .cat-pill { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.1); color: var(--text-dim); padding: 8px 18px; font-size: 0.85rem; cursor: pointer; text-transform: uppercase; transition: 0.2s; clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%); }
    .cat-pill:hover { border-color: var(--red); color: var(--red); background: rgba(230,57,70,0.05); }
    .cat-pill.active { background: var(--red); border-color: var(--red); color: white; font-weight: 700; box-shadow: var(--glow-red); text-shadow: 0 0 5px rgba(255,255,255,0.5); }

    /* GAME GRID */
    .games-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; padding-bottom: 60px; }
    .game-card { background: var(--bg3); border: 1px solid var(--border-red); cursor: pointer; transition: 0.2s; position: relative; }
    .game-card::before { content: ''; position: absolute; top:0; left:0; width: 3px; height: 0%; background: var(--red); transition: 0.3s; z-index: 2; }
    .game-card:hover { transform: translateY(-5px); box-shadow: var(--glow-red); border-color: var(--red); }
    .game-card:hover::before { height: 100%; }
    
    .game-card-img { width: 100%; height: 160px; object-fit: cover; filter: grayscale(20%); transition: 0.3s; border-bottom: 1px solid rgba(230,57,70,0.2); }
    .game-card:hover .game-card-img { filter: grayscale(0%); }
    .game-card-placeholder { width: 100%; height: 160px; background: var(--bg2); border-bottom: 1px solid var(--border-red); display: flex; align-items: center; justify-content: center; font-size: 2rem; color: var(--red); opacity: 0.5; }
    
    .game-card-body { padding: 15px; }
    .game-card-title { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: white; margin-bottom: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .game-card-dev { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-dim); margin-bottom: 12px; text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; border-bottom: 1px dashed rgba(255,255,255,0.05); padding-bottom: 10px; }
    .game-card-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px; font-family: var(--font-mono); }
    .game-tag { font-size: 0.7rem; padding: 2px 8px; background: rgba(230,57,70,0.08); border: 1px solid var(--border-red); color: var(--red); text-transform: uppercase; letter-spacing: 1px; transition: all 0.2s; }
    .game-tag:hover { background: rgba(230,57,70,0.2); border-color: var(--red); color: white; }
    
    .game-card-footer { display: flex; align-items: center; justify-content: space-between; font-family: var(--font-mono); }
    .price-paid { color: white; background: var(--red-dim); padding: 3px 8px; font-weight: 700; font-size: 0.9rem; border: 1px solid var(--red); }
    .has-file-badge { font-size: 0.7rem; color: var(--gold); background: rgba(245,197,66,0.08); border: 1px solid rgba(245,197,66,0.3); padding: 2px 8px; text-transform: uppercase; }

    /* EMPTY STATE */
    .empty-state { grid-column: 1/-1; text-align: center; padding: 80px 20px; border: 1px dashed var(--border-red); background: rgba(230,57,70,0.02); }
    
    /* MODAL */
    .gs-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 9999; align-items: center; justify-content: center; padding: 40px 20px; }
    .gs-modal-overlay.open { display: flex; }
    .gs-modal { background: var(--bg); border: 1px solid var(--red); box-shadow: var(--glow-red); max-width: 900px; width: 100%; max-height: 90vh; overflow-y: auto; position: relative; animation: modalIn 0.2s ease forwards; clip-path: polygon(20px 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%, 0 20px); }
    
    @Html.Raw("@keyframes modalIn { 0%{opacity:0; transform:scale(0.98);} 100%{opacity:1; transform:scale(1);} }")
    .modal-hero-img { width: 100%; height: 350px; object-fit: cover; border-bottom: 2px solid var(--red); }
    
    .modal-body { padding: 35px; }
    .modal-title { font-family: var(--font-display); font-size: 2rem; color: white; text-shadow: 2px 2px 0px var(--red); margin-bottom: 10px; text-transform: uppercase; }
    .modal-meta { display: flex; gap: 20px; font-family: var(--font-mono); margin-bottom: 20px; }
    
    .modal-desc { color: var(--text); border-left: 3px solid var(--red); padding-left: 15px; margin-bottom: 30px; font-size: 1rem; line-height: 1.6; }
    
    .modal-screenshots { display: flex; gap: 15px; overflow-x: auto; margin-bottom: 30px; padding-bottom: 10px; }
    .modal-screenshots img { height: 110px; border: 1px solid var(--border-red); transition: 0.2s; }
    .modal-screenshots img:hover { border-color: var(--red); transform: scale(1.05); }
    
    .modal-trailer { width: 100%; aspect-ratio: 16/9; border: 1px solid var(--border-red); margin-bottom: 30px; }
    
    .modal-close { position: absolute; top: 15px; right: 15px; background: rgba(7,7,9,0.8); border: 1px solid var(--red); color: white; width: 40px; height: 40px; cursor: pointer; font-family: var(--font-mono); transition: 0.2s; clip-path: polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px); z-index: 10; }
    .modal-close:hover { background: var(--red); }
    
    .modal-price-box { border: 1px solid var(--border-red); background: rgba(0,0,0,0.3); padding: 20px; display: flex; align-items: center; justify-content: space-between; font-family: var(--font-mono); position: relative; }
    .modal-price-box::before { content: 'SYS_TICKET'; position: absolute; top: -8px; left: 15px; background: var(--bg); padding: 0 10px; font-size: 0.7rem; color: var(--text-dim); }
    
    .modal-price-val { font-family: var(--font-display); font-size: 1.8rem; color: var(--red); font-weight: bold; }
    .viewer-only-note { color: var(--text-dim); font-family: var(--font-mono); font-size: 0.8rem; background: rgba(245,197,66,0.05); border: 1px solid rgba(245,197,66,0.2); padding: 10px 15px; margin-top: 20px; text-transform: uppercase; }

