@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<style>
  .auth-page { max-width: 420px; margin: 60px auto; }
  .auth-box { background: var(--bg2); border: 1px solid var(--border-red); padding: 40px; }
  .auth-title { font-family: var(--font-display); font-size: 1.6rem; font-weight: 900; color: white; text-align: center; margin-bottom: 8px; letter-spacing: 2px; }
  .auth-sub { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-dim); text-align: center; margin-bottom: 32px; }
  .form-group { margin-bottom: 20px; }
  .form-label { font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); letter-spacing: 1px; margin-bottom: 6px; display: block; text-transform: uppercase; }
  .form-input { width: 100%; background: var(--bg3); border: 1px solid var(--border-red); color: var(--text); padding: 12px 16px; font-family: var(--font-ui); font-size: 14px; outline: none; transition: all 0.2s; }
  .form-input:hover { border-color: var(--red-dim); }
  .form-input:focus { border-color: var(--red); box-shadow: var(--glow-red); }
  .form-error { color: var(--red); font-family: var(--font-mono); font-size: 11px; margin-top: 4px; }
</style>

<div class="auth-page">
  <div class="auth-box">
    <div class="auth-title">RESET PASSWORD</div>
    <div class="auth-sub">Enter your email to receive a reset link.</div>

    <form method="post">
      @Html.AntiForgeryToken()
      <div class="form-group">
        <label class="form-label">Email //</label>
        <input type="email" asp-for="Email" class="form-input" placeholder="your@email.com" required/>
        <span asp-validation-for="Email" class="form-error"></span>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">SEND RESET LINK</button>
    </form>

    <partial name="_Alert" />

    <div style="text-align:center; margin-top:20px;">
      <a href="/Auth/Login" style="color:var(--gold); font-family:var(--font-mono); font-size:12px;">BACK TO LOGIN</a>
    </div>
  </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
