@model ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<style>
  .profile-box {
    background: var(--bg2);
    border: 1px solid var(--border-red);
    padding: 40px;
    max-width: 600px;
    margin: 0 auto;
  }
  .profile-box + .profile-box { margin-top: 24px; }
  .pf-input {
    background: var(--bg3) !important;
    border: 1px solid var(--border-red) !important;
    color: var(--text) !important;
    border-radius: 0 !important;
    padding: 12px 16px !important;
    font-family: var(--font-mono) !important;
    font-size: 13px !important;
    width: 100%;
  }
  .pf-input:hover { border-color: var(--red-dim) !important; }
  .pf-input:focus { border-color: var(--red) !important; box-shadow: 0 0 0 2px #070709, 0 0 16px 3px rgba(230,57,70,0.35) !important; }
  .pf-label { color: var(--text-dim); font-family: var(--font-mono); font-size: 11px; letter-spacing: 1px; margin-bottom: 6px; text-transform: uppercase; }
  .pf-info { font-family: var(--font-mono); font-size: 14px; color: white; padding: 12px 16px; background: var(--bg3); border: 1px solid rgba(230,57,70,0.1); }
</style>

<div class="row w-100 justify-content-center mt-4 pt-4">
  <div class="col-md-7">
    <div class="section-header text-center mb-4">
      <h2 class="section-title glitch">MY PROFILE</h2>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
      <div style="background: @(Model.IsError ? "rgba(230,57,70,0.1); border-color: var(--red); color: var(--red)" : "rgba(74,222,128,0.1); border-color: #4ade80; color: #4ade80"); border: 1px solid; padding: 10px 16px; margin-bottom: 20px; font-family: var(--font-mono); font-size: 12px;">
        @(Model.IsError ? "[ERROR]" : "[OK]") @Model.Message
      </div>
    }

    <div class="profile-box">
      <div style="color: var(--red); border: 1px solid var(--red); padding: 5px 15px; display: inline-block; font-size: 12px; margin-bottom: 20px; font-family: var(--font-mono);">
        ACCOUNT INFO
      </div>

      <div class="mb-3">
        <div class="pf-label">USERNAME</div>
        <div class="pf-info">@Model.Username</div>
      </div>
      <div class="mb-3">
        <div class="pf-label">EMAIL</div>
        <div class="pf-info">@Model.Email</div>
      </div>
    </div>

    <div class="profile-box">
      <div style="color: var(--gold); border: 1px solid rgba(245,197,66,0.4); padding: 5px 15px; display: inline-block; font-size: 12px; margin-bottom: 20px; font-family: var(--font-mono);">
        CHANGE EMAIL
      </div>

      <form method="post" asp-action="UpdateEmail">
        @Html.AntiForgeryToken()
        <div class="mb-3">
          <label class="pf-label" for="NewEmail">New Email //:</label>
          <input type="email" class="pf-input" id="NewEmail" name="NewEmail" value="@Model.NewEmail" required maxlength="200" />
          <span asp-validation-for="NewEmail" class="text-danger" style="font-family:var(--font-mono);font-size:11px;"></span>
        </div>
        <button type="submit" class="btn btn-primary w-100 d-block text-center mt-3">UPDATE EMAIL</button>
      </form>
    </div>

    <div class="profile-box">
      <div style="color: var(--gold); border: 1px solid rgba(245,197,66,0.4); padding: 5px 15px; display: inline-block; font-size: 12px; margin-bottom: 20px; font-family: var(--font-mono);">
        CHANGE PASSWORD
      </div>

      <form method="post" asp-action="ChangePassword">
        @Html.AntiForgeryToken()
        <div class="mb-3">
          <label class="pf-label" for="CurrentPassword">Current Password //:</label>
          <input type="password" class="pf-input" id="CurrentPassword" name="CurrentPassword" required />
        </div>
        <div class="mb-3">
          <label class="pf-label" for="NewPassword">New Password //:</label>
          <input type="password" class="pf-input" id="NewPassword" name="NewPassword" required maxlength="100" />
        </div>
        <div class="mb-3">
          <label class="pf-label" for="ConfirmPassword">Confirm New Password //:</label>
          <input type="password" class="pf-input" id="ConfirmPassword" name="ConfirmPassword" required maxlength="100" />
        </div>
        <button type="submit" class="btn btn-primary w-100 d-block text-center mt-3">CHANGE PASSWORD</button>
      </form>
    </div>
  </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
