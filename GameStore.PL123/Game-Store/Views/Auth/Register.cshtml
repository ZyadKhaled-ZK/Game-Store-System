@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<style>
  .register-box {
    background: var(--bg2);
    border: 1px solid var(--border-red);
    padding: 40px;
    box-shadow: var(--glow-red);
    animation: loginIn 0.4s ease;
    position: relative;
  }
  .register-box::before {
    content: '';
    position: absolute;
    inset: -1px;
    border: 1px solid transparent;
    background: linear-gradient(135deg, var(--red), transparent, var(--red)) border-box;
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s;
  }
  .register-box:hover::before { opacity: 1; }

  .reg-input {
    background: var(--bg3) !important;
    border: 1px solid var(--border-red) !important;
    color: var(--text) !important;
    border-radius: 0 !important;
    transition: all 0.25s !important;
    padding: 12px 16px !important;
    font-family: var(--font-mono) !important;
    font-size: 13px !important;
  }
  .reg-input:hover { border-color: var(--red-dim) !important; box-shadow: 0 0 14px rgba(230,57,70,0.1) !important; }
  .reg-input:focus { border-color: var(--red) !important; box-shadow: 0 0 0 2px #070709, 0 0 16px 3px rgba(230,57,70,0.35) !important; background: #0a0a0e !important; }
  .reg-input::placeholder { color: var(--text-dim) !important; font-family: var(--font-mono); font-size: 12px; }
</style>

<div class="row w-100 justify-content-center mt-5 pt-5">
  <div class="col-md-5">
    <div class="section-header text-center mb-4">
      <h2 class="section-title glitch">REGISTER</h2>
      <div class="section-tag d-inline-flex">Create New Account</div>
    </div>

    <div class="register-box">
      <div style="color: var(--red); border: 1px solid var(--red); padding: 5px 15px; display: inline-block; font-size: 12px; margin-bottom: 20px; font-family: var(--font-mono);">
        NEW USER
      </div>

      <partial name="_Alert" />

      <form method="post">
        <div class="mb-3">
          <label asp-for="Username" class="form-label" style="color: var(--text-dim); font-family: var(--font-mono); font-size: 12px; letter-spacing: 1px;">Username //:</label>
          <input asp-for="Username" class="form-control reg-input" placeholder="Choose a username (3-100 chars)" required maxlength="100"/>
          <span asp-validation-for="Username" class="text-danger" style="font-family:var(--font-mono);font-size:11px;"></span>
        </div>
        <div class="mb-3">
          <label asp-for="Email" class="form-label" style="color: var(--text-dim); font-family: var(--font-mono); font-size: 12px; letter-spacing: 1px;">Email //:</label>
          <input asp-for="Email" type="email" class="form-control reg-input" placeholder="you@example.com" required maxlength="200"/>
          <span asp-validation-for="Email" class="text-danger" style="font-family:var(--font-mono);font-size:11px;"></span>
        </div>
        <div class="mb-4">
          <label asp-for="Password" class="form-label" style="color: var(--text-dim); font-family: var(--font-mono); font-size: 12px; letter-spacing: 1px;">Password //:</label>
          <div style="position:relative;">
            <input asp-for="Password" type="password" class="form-control reg-input" placeholder="Min 6 characters" required maxlength="100" style="padding-right:40px;"/>
            <button type="button" class="pwd-toggle" onclick="togglePwd(this)"><i class="bi bi-eye-slash"></i></button>
          </div>
          <span asp-validation-for="Password" class="text-danger" style="font-family:var(--font-mono);font-size:11px;"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 d-block text-center mt-4 ripple">CREATE ACCOUNT</button>
      </form>

      <div style="margin-top: 20px; text-align: center;">
          <a href="/Auth/ExternalLogin?provider=Google&returnUrl=/" style="display:inline-flex;align-items:center;gap:10px;padding:10px 24px;background:#fff;color:#333;border-radius:4px;text-decoration:none;font-family:var(--font-mono);font-size:13px;font-weight:600;transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 2px 8px rgba(0,0,0,0.3)'" onmouseout="this.style.boxShadow='none'">
              <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59A14.5 14.5 0 0 1 9.5 24c0-1.59.28-3.14.76-4.59l-7.98-6.19A23.99 23.99 0 0 0 0 24c0 3.77.87 7.35 2.56 10.56l7.97-5.97z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 5.97C6.51 42.62 14.62 48 24 48z"/></svg>
              Sign up with Google
          </a>
      </div>

      <div style="margin-top: 20px; font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); text-align: center;">
        Already have an account? <a href="/Auth/Login" style="color: var(--gold);">LOGIN</a>
      </div>
    </div>

    <div class="text-center mt-3">
      <a href="/" style="color: var(--text-dim); font-family: var(--font-mono); text-decoration: none; transition: all 0.2s;"
         onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text-dim)'">
        &lt; BACK
      </a>
    </div>
  </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
