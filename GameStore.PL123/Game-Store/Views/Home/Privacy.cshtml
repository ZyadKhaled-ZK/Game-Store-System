@{
    ViewData["Title"] = "Privacy Policy";
}

<style>
  .privacy-box {
    max-width: 800px;
    margin: 0 auto;
    background: var(--bg2);
    border: 1px solid var(--border-red);
    padding: 40px;
    animation: fadeIn 0.4s ease;
  }
  .privacy-box h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 900;
    color: white;
    letter-spacing: 2px;
    margin-bottom: 8px;
    text-shadow: var(--glow-red);
  }
  .privacy-box .tag {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--red);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 30px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .privacy-box .tag::before {
    content: '';
    width: 30px;
    height: 2px;
    background: var(--red);
  }
  .privacy-box p {
    color: var(--text-dim);
    font-family: var(--font-ui);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 16px;
    border-left: 2px solid var(--border-red);
    padding-left: 20px;
    transition: all 0.2s;
  }
  .privacy-box p:hover {
    border-left-color: var(--red);
    color: var(--text);
  }
  .privacy-box .highlight {
    color: var(--gold);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .privacy-box .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 30px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--red);
    text-decoration: none;
    border: 1px solid var(--border-red);
    padding: 8px 16px;
    transition: all 0.2s;
    clip-path: polygon(6px 0, 100% 0, calc(100% - 6px) 100%, 0 100%);
  }
  .privacy-box .back-link:hover {
    background: rgba(230,57,70,0.1);
    border-color: var(--red);
    color: white;
  }
  @@media (max-width: 768px) {
    .privacy-box { padding: 28px; }
    .privacy-box h1 { font-size: 1.6rem; }
  }
  @@media (max-width: 576px) {
    .privacy-box { padding: 20px; margin: 0 12px; }
    .privacy-box h1 { font-size: 1.3rem; }
    .privacy-box p { font-size: 0.9rem; padding-left: 12px; }
  }
</style>

<div class="privacy-box">
  <h1>PRIVACY PROTOCOL</h1>
  <div class="tag">System Directive // GDPR Compliance</div>
  <p>This is a demonstration application. No real user data is collected, stored, or processed. All credentials and records shown within this interface are either hardcoded defaults or mock data used solely for testing and showcase purposes.</p>
  <p>Any resemblance to real persons, games, or entities is purely coincidental. The <span class="highlight">GAME STORE</span> platform operates in a sandbox environment and does not transmit data to external services beyond what is necessary for core functionality.</p>
  <p>For questions regarding this policy, contact the system administrator.</p>
  <a href="/" class="back-link"><i class="bi bi-arrow-left"></i> RETURN_TO_HOME</a>
</div>
