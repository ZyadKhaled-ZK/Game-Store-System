@model HomeViewModel
@{
    ViewData["Title"] = "Game Store";
}
<style>
    .welcome-overlay { position: fixed; inset: 0; z-index: 10000; background: #070709; display: flex; align-items: center; justify-content: center; flex-direction: column; transition: opacity 0.6s ease, visibility 0.6s ease; }
    .welcome-overlay.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
    .welcome-overlay canvas { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.15; }
    .welcome-content { position: relative; z-index: 1; text-align: center; }
    .welcome-logo { width: 120px; height: 120px; margin: 0 auto 20px; position: relative; }
    .welcome-logo svg { width: 100%; height: 100%; filter: drop-shadow(0 0 25px rgba(230,57,70,0.6)); }
    .welcome-title { font-family: var(--font-display); font-size: 4rem; font-weight: 900; color: white; letter-spacing: 6px; text-shadow: 0 0 40px rgba(230,57,70,0.5), 0 0 80px rgba(230,57,70,0.2); margin-bottom: 8px; }
    .welcome-title span { color: var(--red); text-shadow: 0 0 30px rgba(230,57,70,0.8); }
    .welcome-sub { font-family: var(--font-mono); font-size: 0.9rem; color: var(--text-dim); letter-spacing: 8px; text-transform: uppercase; margin-bottom: 40px; }
    .welcome-sub .blink { animation: blink 0.6s step-end infinite; }
    .welcome-boot { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-dim); margin-top: 20px; letter-spacing: 3px; }
    .welcome-boot .bar { display: inline-block; width: 200px; height: 2px; background: rgba(255,255,255,0.08); vertical-align: middle; margin-left: 10px; overflow: hidden; border-radius: 1px; }
    .welcome-boot .bar span { display: block; height: 100%; width: 0; background: var(--red); box-shadow: 0 0 10px var(--red); animation: bootLoad 2.2s ease-in-out forwards; }
    .welcome-version { position: absolute; bottom: 30px; right: 40px; font-family: var(--font-mono); font-size: 0.7rem; color: rgba(255,255,255,0.1); letter-spacing: 1px; z-index: 1; }
    .welcome-gltch { position: fixed; inset: 0; z-index: 99999; pointer-events: none; background: black; opacity: 0; transition: opacity 0.15s; }
    .welcome-gltch.active { opacity: 1; }
    .welcome-particle { position: fixed; width: 4px; height: 4px; border-radius: 50%; background: var(--red); pointer-events: none; z-index: 99998; animation: partFly 0.8s ease-out forwards; }
    .welcome-scan { position: absolute; inset: 0; overflow: hidden; pointer-events: none; z-index: 0; }
    .welcome-scan::after { content: ''; position: absolute; top: -2px; left: 0; width: 100%; height: 2px; background: linear-gradient(90deg, transparent, var(--red), transparent); animation: scanMove 3s linear infinite; }
    .logo-rotator { transform-origin: 60px 40px; animation: logoSpin 5s linear infinite; }
    .logo-blink { animation: textBlink 2s ease-in-out infinite; }
    .welcome-overlay.hidden .logo-rotator, .welcome-overlay.hidden .logo-blink, .welcome-overlay.hidden .welcome-scan { animation-play-state: paused !important; }
    .hero-section { max-width: 1400px; margin: 28px auto 40px; padding: 0 24px; position: relative; }
    .hero-label { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 3px; color: var(--gold); margin-bottom: 10px; font-family: var(--font-mono); }
    .hero-card { position: relative; border-radius: 0; overflow: hidden; border: 1px solid var(--border-red); cursor: pointer; display: flex; flex-direction: column; background: var(--bg2); transition: box-shadow 0.4s; }
    .hero-card:hover { box-shadow: 0 0 30px rgba(230,57,70,0.25); }
    .hero-card::after { content: ''; position: absolute; left: 0; bottom: 0; width: 0%; height: 3px; background: linear-gradient(90deg, var(--red), var(--gold)); transition: width 0.5s ease; z-index: 4; }
    .hero-card:hover::after { width: 100%; }
    .hero-badge-new { position: absolute; top: 12px; left: 12px; z-index: 5; background: linear-gradient(135deg, var(--red), #ff6b35); color: #fff; font-family: var(--font-mono); font-size: 11px; font-weight: 700; letter-spacing: 1px; padding: 4px 12px; border-radius: 3px; box-shadow: 0 2px 12px rgba(230,57,70,0.4); animation: badgePop 0.4s cubic-bezier(0.4,0,0.2,1); pointer-events: none; }
    @@keyframes badgePop { 0% { transform: scale(0); opacity: 0; } 60% { transform: scale(1.15); } 100% { transform: scale(1); opacity: 1; } }
    .hero-img { width: 100%; height: 450px; object-fit: cover; display: block; opacity: 0.9; transition: transform 0.6s; filter: brightness(0.8); }
    .hero-card:hover .hero-img { transform: scale(1.02); filter: brightness(1); }
    .hero-placeholder { width: 100%; height: 450px; background: repeating-linear-gradient(45deg, var(--bg2) 0, var(--bg2) 10px, var(--bg3) 10px, var(--bg3) 20px); display: flex; align-items: center; justify-content: center; font-size: 3rem; color: var(--red); }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(7,7,9,0.95) 0%, rgba(7,7,9,0.4) 50%, transparent 100%); padding: 30px; display: flex; flex-direction: column; justify-content: flex-end; }
    .hero-title { font-family: var(--font-display); font-size: 2.8rem; font-weight: 900; color: #fff; letter-spacing: 2px; line-height: 1.1; margin-bottom: 8px; }
    .hero-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; flex-wrap: wrap; font-family: var(--font-mono); }
    .hero-tag { background: var(--red); color: #fff; padding: 3px 12px; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; }
    .hero-price { font-size: 1.4rem; font-weight: 700; color: var(--gold); }
    .price-free { color: #4ade80 !important; }
    .hero-rating { font-family: var(--font-mono); font-size: 0.85rem; color: var(--gold); letter-spacing: 1px; }
    .hero-desc { color: rgba(255,255,255,0.6); font-size: 0.95rem; max-width: 650px; font-family: var(--font-ui); line-height: 1.5; }
    .hero-actions { display: flex; align-items: center; gap: 10px; margin-top: 16px; }
    .hero-btn { padding: 10px 20px; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); border: none; text-decoration: none; font-family: var(--font-mono); border-radius: 6px; }
    .hero-btn-primary { background: linear-gradient(135deg, var(--red), var(--red-dim)); color: #fff; box-shadow: 0 4px 15px rgba(230,57,70,0.3); }
    .hero-btn-primary:hover { background: linear-gradient(135deg, #ff4757, var(--red)); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(230,57,70,0.5); }
    .hero-btn-secondary { background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(4px); }
    .hero-btn-secondary:hover { background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.3); transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.3); }
    .hero-carousel { position: relative; }
    .hero-track { position: relative; min-height: 450px; }
    .hero-item { position: absolute; inset: 0; opacity: 0; pointer-events: none; transition: opacity 0.5s ease; z-index: 1; }
    .hero-item.active { opacity: 1; pointer-events: auto; position: relative; z-index: 2; }
    .hero-arrow { position: absolute; top: 50%; transform: translateY(-50%); z-index: 10; background: rgba(7,7,9,0.6); border: 1px solid var(--border-red); color: white; width: 44px; height: 44px; cursor: pointer; font-size: 1.2rem; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
    .hero-arrow:hover { background: var(--red); border-color: var(--red); }
    .hero-arrow-left { left: 12px; }
    .hero-arrow-right { right: 12px; }
    .hero-dots { display: flex; justify-content: center; gap: 8px; margin-top: 14px; }
    .hero-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--bg3); border: 1px solid var(--border-red); cursor: pointer; transition: 0.2s; }
    .hero-dot.active { background: var(--red); border-color: var(--red); box-shadow: 0 0 8px rgba(230,57,70,0.5); }
    .hero-dot:hover { border-color: var(--red); }
    .browse-section { max-width: 1400px; margin: 0 auto; padding: 0 24px; }
    .browse-top { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 25px; flex-wrap: wrap; border-bottom: 1px solid var(--border-red); padding-bottom: 15px; }
    .browse-title { font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: white; letter-spacing: 2px; }
    .browse-controls { display: flex; gap: 15px; align-items: center; flex-wrap: wrap; font-family: var(--font-mono); }
    .gs-search { background: rgba(255,255,255,0.02); border: 1px solid var(--border-red); color: white; padding: 10px 14px 10px 38px; font-size: 0.9rem; width: 280px; outline: none; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); border-radius: 6px; }
    .gs-search:hover { border-color: rgba(230,57,70,0.5); background: rgba(255,255,255,0.05); }
    .gs-search:focus { border-color: var(--red); box-shadow: 0 0 0 3px rgba(230,57,70,0.25); background: var(--bg); width: 320px; }
    .search-wrap { position: relative; }
    .search-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--red); font-size: 0.9rem; pointer-events: none; transition: color 0.3s; }
    .gs-search:focus + .search-icon, .gs-search:focus ~ .search-icon { color: white; }
    .gs-sort { background: rgba(255,255,255,0.02); border: 1px solid var(--border-red); color: white; padding: 10px 15px; font-size: 0.9rem; cursor: pointer; outline: none; transition: all 0.3s; border-radius: 6px; }
    .gs-sort:hover { border-color: rgba(230,57,70,0.5); background: rgba(255,255,255,0.05); }
    .gs-sort:focus { border-color: var(--red); box-shadow: 0 0 0 3px rgba(230,57,70,0.25); }
    .gs-sort option { background: var(--bg2); color: white; }
    .cat-pills { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 30px; font-family: var(--font-mono); }
    .cat-pill { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.1); color: var(--text-dim); padding: 8px 18px; font-size: 0.85rem; cursor: pointer; text-transform: uppercase; transition: 0.2s; clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%); }
    .cat-pill:hover { border-color: var(--red); color: var(--red); background: rgba(230,57,70,0.05); }
    .cat-pill.active { background: var(--red); border-color: var(--red); color: white; font-weight: 700; box-shadow: var(--glow-red); text-shadow: 0 0 5px rgba(255,255,255,0.5); }
    .games-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; padding-bottom: 60px; }
    .game-card { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); cursor: pointer; transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1); position: relative; overflow: hidden; border-radius: 12px; backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
    .game-card-badge-new { position: absolute; top: 12px; left: 12px; z-index: 3; background: linear-gradient(135deg, var(--red), #ff6b35); color: #fff; font-family: var(--font-mono); font-size: 10px; font-weight: 700; letter-spacing: 1.5px; padding: 4px 12px; border-radius: 4px; box-shadow: 0 4px 12px rgba(230,57,70,0.4); pointer-events: none; }
    .game-card::before { content: ''; position: absolute; top:0; left:0; width: 3px; height: 0%; background: linear-gradient(to bottom, var(--red), var(--gold)); transition: 0.4s; z-index: 2; }
    .game-card:hover { transform: translateY(-8px); box-shadow: 0 12px 30px rgba(0,0,0,0.5), 0 0 15px rgba(230,57,70,0.2); border-color: rgba(230,57,70,0.4); }
    .game-card:hover::before { height: 100%; }
    .game-card-img { width: 100%; height: 180px; object-fit: cover; filter: grayscale(30%) brightness(0.8); transition: filter 0.5s ease, transform 0.5s ease; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .game-card:hover .game-card-img { filter: grayscale(0%) brightness(1.05); transform: scale(1.05); }
    .game-card-placeholder { width: 100%; height: 180px; background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: center; font-size: 2.5rem; color: rgba(230,57,70,0.5); }
    .game-card-body { padding: 15px; }
    .game-card-title { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: white; margin-bottom: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .game-card-dev { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-dim); margin-bottom: 12px; text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; border-bottom: 1px dashed rgba(255,255,255,0.05); padding-bottom: 10px; }
    .game-card-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px; font-family: var(--font-mono); }
    .game-tag { font-size: 0.7rem; padding: 2px 8px; background: rgba(230,57,70,0.08); border: 1px solid var(--border-red); color: var(--red); text-transform: uppercase; letter-spacing: 1px; transition: all 0.2s; }
    .game-tag:hover { background: rgba(230,57,70,0.2); border-color: var(--red); color: white; }
    .game-card-footer { display: flex; align-items: center; justify-content: space-between; font-family: var(--font-mono); }
    .price-paid { color: white; background: var(--red-dim); padding: 3px 8px; font-weight: 700; font-size: 0.9rem; border: 1px solid var(--red); }
    .has-file-badge { font-size: 0.7rem; color: var(--gold); background: rgba(245,197,66,0.08); border: 1px solid rgba(245,197,66,0.3); padding: 2px 8px; text-transform: uppercase; }
    .empty-state { grid-column: 1/-1; text-align: center; padding: 80px 20px; border: 1px dashed var(--border-red); background: rgba(230,57,70,0.02); }
    .gs-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 9999; align-items: center; justify-content: center; padding: 20px; backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); }
    .gs-modal-overlay.open { display: flex; }
    .gs-modal { background: linear-gradient(160deg, #0d0d12 0%, #111118 100%); border: 1px solid rgba(230,57,70,0.15); border-radius: 12px; box-shadow: 0 24px 80px rgba(0,0,0,0.6); max-width: 720px; width: 100%; max-height: 85vh; position: relative; animation: modalSlideUp 0.3s cubic-bezier(0.4,0,0.2,1) forwards; display: flex; flex-direction: column; }
    #modalContent { display: flex; flex-direction: column; flex: 1; overflow: hidden; }
    @@keyframes modalSlideUp { from { opacity: 0; transform: translateY(24px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .modal-hero-img { width: 100%; height: 260px; object-fit: cover; display: block; flex-shrink: 0; }
    .modal-hero-placeholder { background: linear-gradient(160deg, #111118, #0a0a0f); height: 260px; display: flex; align-items: center; justify-content: center; color: var(--red); font-family: var(--font-display); font-size: 2rem; opacity: 0.3; flex-shrink: 0; }
    .modal-body { padding: 28px 32px 24px; overflow-y: auto; flex: 1; }
    .modal-title { font-family: var(--font-display); font-size: 1.6rem; color: #fff; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; }
    .modal-meta { display: flex; gap: 16px; font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); margin-bottom: 16px; flex-wrap: wrap; }
    .modal-desc { color: rgba(232,232,240,0.85); margin-bottom: 24px; font-size: 0.92rem; line-height: 1.7; }
    .modal-screenshots { display: flex; gap: 10px; overflow-x: auto; margin-bottom: 24px; padding-bottom: 8px; }
    .modal-screenshots img { height: 90px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.06); transition: all 0.2s; cursor: pointer; flex-shrink: 0; }
    .modal-screenshots img:hover { border-color: rgba(230,57,70,0.3); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.3); }
    .modal-trailer-wrap { width: 100%; aspect-ratio: 16/9; border-radius: 10px; overflow: hidden; margin-bottom: 24px; background: #000; border: 1px solid rgba(255,255,255,0.04); }
    .modal-trailer { width: 100%; height: 100%; border: none; display: block; }
    .modal-close { position: absolute; top: 12px; right: 12px; background: rgba(0,0,0,0.5); border: none; color: #fff; width: 36px; height: 36px; border-radius: 50%; cursor: pointer; font-size: 18px; transition: all 0.2s; z-index: 10; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(8px); }
    .modal-close:hover { background: rgba(230,57,70,0.7); transform: scale(1.1); }
    .modal-price-box { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; font-family: var(--font-mono); margin-bottom: 8px; }
    .modal-price-val { font-family: var(--font-display); font-size: 1.5rem; color: var(--gold); font-weight: 700; letter-spacing: 1px; }
    .viewer-only-note { color: var(--text-dim); font-family: var(--font-mono); font-size: 0.75rem; background: rgba(245,197,66,0.04); border: 1px solid rgba(245,197,66,0.1); padding: 8px 14px; margin-top: 16px; border-radius: 6px; }
    .modal-categories { display: flex; gap: 6px; margin-bottom: 16px; flex-wrap: wrap; }
    .modal-cat-tag { background: rgba(230,57,70,0.08); color: var(--red); border: 1px solid rgba(230,57,70,0.2); padding: 3px 10px; font-size: 0.7rem; font-family: var(--font-mono); border-radius: 4px; letter-spacing: 0.5px; }
    .modal-download-box { display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; justify-content: flex-end; }
    .modal-download-icon { font-size: 1.2rem; opacity: 0.6; }
    .modal-download-info { display: flex; flex-direction: column; }
    .modal-download-name { font-weight: 600; color: #fff; font-family: var(--font-mono); font-size: 0.8rem; max-width: 220px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .modal-download-size { font-size: 0.7rem; color: var(--text-dim); font-family: var(--font-mono); }
    .modal-actions { display: flex; gap: 10px; margin-top: 8px; }
    .modal-actions .btn { flex: 1; justify-content: center; border-radius: 6px; }
    .modal-wishlist-btn { flex: 0 0 auto; padding: 10px 14px; font-size: 16px; border-radius: 6px; }
    .modal-reviews { margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.05); }
    .modal-reviews-title { font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); letter-spacing: 1.5px; margin-bottom: 14px; text-transform: uppercase; }
    .modal-review-card { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); border-radius: 8px; padding: 12px 16px; margin-bottom: 8px; transition: border-color 0.2s; }
    .modal-review-card:hover { border-color: rgba(230,57,70,0.12); }
    .modal-review-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
    .modal-review-user { font-family: var(--font-mono); font-size: 11px; color: var(--gold); font-weight: 600; }
    .modal-review-stars { font-family: var(--font-mono); font-size: 12px; color: var(--gold); letter-spacing: 1px; }
    .modal-review-comment { font-size: 13px; color: rgba(232,232,240,0.8); }
    .modal-review-date { font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); margin-top: 6px; opacity: 0.6; }
    .modal-no-reviews { font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); margin-bottom: 14px; }
    .modal-review-form-box { margin-top: 16px; padding: 18px; background: rgba(255,255,255,0.015); border: 1px solid rgba(255,255,255,0.04); border-radius: 8px; }
    .modal-review-form-title { font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); letter-spacing: 1px; margin-bottom: 12px; text-transform: uppercase; }
    .modal-stars-select { display: flex; gap: 6px; margin-bottom: 12px; }
    .modal-star { cursor: pointer; font-size: 22px; color: rgba(255,255,255,0.15); transition: color 0.2s, transform 0.15s; }
    .modal-star:hover { transform: scale(1.2); }
    .modal-review-textarea { width: 100%; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.06); border-radius: 6px; color: var(--text); padding: 10px 14px; font-family: var(--font-ui); font-size: 13px; resize: vertical; min-height: 60px; outline: none; transition: border-color 0.2s; }
    .modal-review-textarea:focus { border-color: rgba(230,57,70,0.25); }
    .modal-review-msg { font-family: var(--font-mono); font-size: 11px; margin-top: 8px; }
    @@media (max-width: 992px) {
      .hero-section { padding: 0 16px; }
      .browse-section { padding: 0 16px; }
      .hero-title { font-size: 2rem; }
      .hero-desc { font-size: 0.85rem; max-width: 100%; }
      .gs-modal { max-width: 90vw; }
      .modal-body { padding: 20px 20px 16px; }
      .modal-title { font-size: 1.3rem; }
    }
    @@media (max-width: 768px) {
      .hero-img, .hero-placeholder { height: 300px; }
      .hero-overlay { padding: 20px; }
      .hero-title { font-size: 1.6rem; }
      .welcome-title { font-size: 2.5rem; letter-spacing: 4px; }
      .welcome-logo { width: 80px; height: 80px; }
      .hero-arrow { width: 36px; height: 36px; font-size: 1rem; }
      .gs-search { width: 100%; }
      .browse-controls { width: 100%; }
      .browse-controls .search-wrap { flex: 1; }
      .browse-controls select { width: 100%; }
      .browse-top { flex-direction: column; align-items: flex-start; }
      .gs-modal { max-width: 96vw; }
      .modal-hero-img, .modal-hero-placeholder { height: 180px; }
      .modal-price-box { flex-direction: column; align-items: flex-start; }
      .modal-download-box { justify-content: flex-start; width: 100%; }
      #modalContent details > div { grid-template-columns: 1fr !important; }
    }
    @@media (max-width: 576px) {
      .hero-img, .hero-placeholder { height: 220px; }
      .hero-title { font-size: 1.2rem; }
      .hero-arrow { width: 30px; height: 30px; font-size: 0.8rem; }
      .hero-arrow-left { left: 6px; }
      .hero-arrow-right { right: 6px; }
      .hero-tag { font-size: 0.6rem; padding: 2px 8px; }
