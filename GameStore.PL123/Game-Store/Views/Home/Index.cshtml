@{
    var isLoggedInHero = !string.IsNullOrEmpty(Context.Session.GetString("UserId"));
}
@if (Model.HeroGames.Any())
{
<div class="hero-section mt-5">
    <div class="hero-label"><i class="bi bi-star-fill" style="color:var(--gold);margin-right:6px;"></i> FEATURED</div>
    <div class="hero-carousel" id="heroCarousel">
        <div class="hero-track" id="heroTrack">
            @for (int hi = 0; hi < Model.HeroGames.Count; hi++)
            {
                var g = Model.HeroGames[hi];
                var gIsNew = g.CreatedAt >= DateTime.UtcNow.AddDays(-30);
                var gIsPreRelease = Model.PreReleaseGameIds.Contains(g.Id);
                var gCanPreview = Model.PreviewableGameIds.Contains(g.Id);
                var gJson = System.Text.Json.JsonSerializer.Serialize(new { id = g.Id, title = g.Title, developer = g.Developer ?? "UNKNOWN", price = g.Price, description = g.Description, trailerUrl = g.TrailerUrl, screenshots = g.ScreenshotUrls, coverImageUrl = g.CoverImageUrl, releaseDate = g.ReleaseDate.ToString("yyyy-MM-dd"), categories = g.GameCategories.Select(gc => gc.Category.Name).ToList(), hasFile = g.GameFileUrl != null, fileName = g.GameFileName, fileSizeBytes = g.GameFileSizeBytes });
                var gReviews = Model.ReviewsByGame.TryGetValue(g.Id, out var revs) ? revs : new();
                var gAvg = gReviews.Any() ? gReviews.Average(r => r.Rating) : 0;
                var gPriceText = g.Price == 0 ? "FREE" : "$" + g.Price.ToString("F2");
                <div class="hero-item @(hi == 0 ? "active" : "")" data-hero-index="@hi">
                    <div class="hero-card" onclick='openModal(@Html.Raw(gJson))'>
                        @if (gIsNew) { <div class="hero-badge-new">🔥 NEW</div> }
                        @if (gIsPreRelease) { <div class="hero-badge-new" style="background:#8a1c24;color:white;">COMING SOON</div> }
                        @if (!string.IsNullOrEmpty(g.CoverImageUrl)) { <img class="hero-img" src="@g.CoverImageUrl" alt="@g.Title" /> }
                        else if (g.ScreenshotUrls.Any()) { <img class="hero-img" src="@g.ScreenshotUrls[0]" alt="@g.Title" /> }
                        else { <div class="hero-placeholder"><i class="bi bi-image"></i></div> }
                        <div class="hero-overlay">
                            <div class="hero-title">@g.Title.ToUpper()</div>
                            <div class="hero-meta">
                                @foreach (var gc in g.GameCategories.Take(3)) { <span class="hero-tag">@gc.Category.Name</span> }
                                @if (gIsPreRelease) { <span class="hero-price" style="color:var(--gold);font-size:10px;">COMING @g.ReleaseDate.ToString("MMM d, yyyy")</span> }
                                else { <span class="hero-price @(g.Price == 0 ? "price-free" : "")">@gPriceText</span> }
                                @if (gReviews.Any()) { <span class="hero-rating"><i class="bi bi-star-fill" style="margin-right:4px;"></i>@gAvg.ToString("0.0") (@gReviews.Count)</span> }
                                <span class="hero-rating" style="color:var(--text-dim);"><i class="bi bi-calendar3"></i> @g.ReleaseDate.ToString("MMM d, yyyy")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(g.Description)) { <div class="hero-desc">@(g.Description.Length > 180 ? g.Description[..177] + "..." : g.Description)</div> }
                            <div class="hero-actions">
                                @if (gIsPreRelease)
                                {
                                    if (isLoggedInHero) { <button class="hero-btn hero-btn-secondary" onclick="event.stopPropagation();toggleWishlist('@g.Id', this)"><i class="bi bi-heart"></i> WISHLIST</button> }
                                    else { <a href="/Auth/Login" class="hero-btn hero-btn-secondary" onclick="event.stopPropagation()"><i class="bi bi-heart"></i> WISHLIST</a> }
                                }
                                else if (isLoggedInHero && Model.OwnedGameIds.Contains(g.Id)) { <span class="hero-btn hero-btn-primary" style="background:rgba(74,222,128,0.08);border-color:rgba(74,222,128,0.2);color:#4ade80;cursor:default;">✓ OWNED</span> }
                                else if (isLoggedInHero) { <button class="hero-btn hero-btn-primary" onclick="event.stopPropagation();addToCart('@g.Id', this)"><i class="bi bi-cart-plus"></i> ADD TO CART</button> <button class="hero-btn hero-btn-secondary" onclick="event.stopPropagation();toggleWishlist('@g.Id', this)"><i class="bi bi-heart"></i></button> }
                                else { <a href="/Auth/Login" class="hero-btn hero-btn-primary" onclick="event.stopPropagation()"><i class="bi bi-box-arrow-in-right"></i> LOGIN TO BUY</a> }
                                <button class="hero-btn hero-btn-secondary" onclick='event.stopPropagation();openModal(@Html.Raw(gJson))'><i class="bi bi-info-circle"></i> DETAILS</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <button class="hero-arrow hero-arrow-left" onclick="heroPrev(event)"><i class="bi bi-chevron-left"></i></button>
        <button class="hero-arrow hero-arrow-right" onclick="heroNext(event)"><i class="bi bi-chevron-right"></i></button>
    </div>
    <div class="hero-dots" id="heroDots"></div>
</div>
}

<div class="browse-section mt-4">
    <div class="browse-top">
        <div class="browse-title glitch" data-text="GAMES">GAMES</div>
        <div class="browse-controls">
            <div class="search-wrap">
                <span class="search-icon"><i class="bi bi-search"></i></span>
                <input type="text" id="searchInput" class="gs-search" placeholder="Query Matrix..." oninput="applyFilters()"/>
            </div>
            <select class="gs-sort" id="sortSelect" onchange="applyFilters()">
                <option value="newest">NEWEST</option>
                <option value="name">ALPHABETICAL (A-Z)</option>
