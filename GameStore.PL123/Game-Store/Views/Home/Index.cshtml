      .welcome-title { font-size: 1.8rem; letter-spacing: 2px; }
      .welcome-sub { font-size: 0.7rem; letter-spacing: 4px; }
      .welcome-logo { width: 60px; height: 60px; }
      .welcome-version { display: none; }
      .welcome-boot .bar { width: 120px; }
      .gs-modal { max-width: 100vw; border-radius: 0; max-height: 100vh; }
      .modal-body { padding: 16px; }
      .modal-title { font-size: 1.1rem; }
      .modal-desc { font-size: 0.85rem; }
      .modal-screenshots img { height: 60px; }
    }
</style>

