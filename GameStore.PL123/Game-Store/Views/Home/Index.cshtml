@Html.AntiForgeryToken()

@section Scripts {
<script>
    const cartIds = [];
    const reviewsData = @Html.Raw(Model.ReviewsJson) || {};
    const wishlistIds = [];
    const ownedGameIds = @Html.Raw(Json.Serialize(Model.OwnedGameIds.ToList())) || [];
    const preReleaseIds = @Html.Raw(Json.Serialize(Model.PreReleaseGameIds.ToList())) || [];
    const previewableIds = @Html.Raw(Json.Serialize(Model.PreviewableGameIds.ToList())) || [];
    const isLoggedIn = @Html.Raw(string.IsNullOrEmpty(Context.Session.GetString("UserId")) ? "false" : "true");
    const heroGames = @Html.Raw(Model.HeroGamesJson) || [];

    function escapeHtml(text) {
        if (!text) return '';
        var d = document.createElement('div');
        d.textContent = text;
        return d.innerHTML;
    }

    function getEmbedUrl(url) {
        if (!url) return '';
        try {
            var u = new URL(url);
            if (u.hostname.includes('youtube.com') || u.hostname.includes('youtu.be')) {
                var vid = '';
                if (u.hostname.includes('youtu.be')) vid = u.pathname.slice(1).split('?')[0];
                else if (u.pathname.includes('/embed/')) vid = u.pathname.split('/embed/')[1].split('?')[0];
                else if (u.pathname.includes('/watch')) vid = u.searchParams.get('v');
                if (vid) return 'https://www.youtube-nocookie.com/embed/' + vid;
            }
        } catch(e) {}
        return url;
    }
    function fmtSize(bytes) {
        if (!bytes || bytes === 0) return '';
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + ' KB';
        if (bytes < 1024*1024*1024) return (bytes/(1024*1024)).toFixed(1) + ' MB';
        return (bytes/(1024*1024*1024)).toFixed(2) + ' GB';
    }
    function renderStars(rating) { let s = ''; for (let i = 1; i <= 5; i++) s += i <= rating ? '★' : '☆'; return s; }

    function openModal(game) {
        var e = escapeHtml;
        let html = '';
        const heroSrc = game.coverImageUrl;
        if (heroSrc) html += `<img class="modal-hero-img" src="${heroSrc}" alt="${e(game.title)}"/>`;
        else html += `<div class="modal-hero-placeholder">NO IMAGE</div>`;
        html += `<div class="modal-body">`;
        html += `<div class="modal-title">${e(game.title).toUpperCase()}</div>`;
        html += `<div class="modal-meta"><span><i class="bi bi-buildings"></i> ${e(game.developer)}</span><span><i class="bi bi-calendar3"></i> ${e(game.releaseDate)}</span></div>`;
        if (game.categories && game.categories.length) html += `<div class="modal-categories">` + game.categories.map(c => `<span class="modal-cat-tag">${e(c)}</span>`).join('') + `</div>`;
        if (game.description) html += `<p class="modal-desc">${e(game.description)}</p>`;
        if (game.trailerUrl) html += `<div class="modal-trailer-wrap"><iframe class="modal-trailer" src="${getEmbedUrl(game.trailerUrl)}" allowfullscreen loading="lazy"></iframe></div>`;
        html += `<div id="modalReqs_${e(game.id)}" style="margin-bottom:16px;"></div>`;
        html += `<div id="modalVersions_${e(game.id)}" style="margin-bottom:12px;"></div>`;
        html += `<div class="modal-price-box">`;
        if (game.isPreRelease) {
            html += `<div class="modal-price-val" style="color:var(--gold);font-size:14px;">COMING SOON</div>`;
            html += `<div style="font-family:var(--font-mono);font-size:11px;color:var(--text-dim);margin-top:4px;">releases ${e(game.releaseDate)}</div>`;
        } else if (game.salePrice && game.salePrice < game.price) {
            html += `<span style="color:var(--text-dim);font-size:12px;text-decoration:line-through;margin-right:8px;">$${game.price.toFixed(2)}</span>`;
            html += `<div class="modal-price-val" style="color:var(--red);">$${game.salePrice.toFixed(2)}</div>`;
        } else if (game.price === 0) html += `<div class="modal-price-val" style="color:var(--gold);">FREE</div>`;
        else html += `<div class="modal-price-val">$${game.price.toFixed(2)}</div>`;
        if (ownedGameIds.includes(game.id)) html += `<span style="font-family:var(--font-mono);font-size:11px;color:#4ade80;margin-left:12px;">[ OWNED ]</span>`;
        if (ownedGameIds.includes(game.id)) html += `<div class="modal-download-box" id="modalDlBox_${e(game.id)}"><span class="modal-download-icon"><i class="fas fa-save"></i></span><div class="modal-download-info"><div class="modal-download-name">${e(game.fileName) || 'GAME FILE'}</div><div class="modal-download-size">${fmtSize(game.fileSizeBytes)} OK</div></div><a href="/Library/Download/${game.id}" class="btn btn-primary" style="padding:8px 16px;font-size:12px;text-decoration:none;">⬇ DOWNLOAD</a></div>`;
        html += `<div class="modal-actions">`;
        if (game.isPreRelease) {
            if (isLoggedIn) {
                if (previewableIds.includes(game.id)) {
                    html += `<a href="/Library/PreviewDownload/${game.id}" class="btn btn-primary" style="background:rgba(138,28,36,0.15);border-color:rgba(138,28,36,0.3);color:var(--red);">⬇ PREVIEW DOWNLOAD</a>`;
                }
                html += `<button onclick="toggleWishlist('${game.id}', this)" class="btn btn-secondary modal-wishlist-btn" title="Add to wishlist">&#9825;</button>`;
            } else {
                html += `<a href="/Auth/Login" class="btn btn-secondary">LOGIN TO WISHLIST</a>`;
            }
        } else if (isLoggedIn) {
            if (ownedGameIds.includes(game.id)) { html += `<span class="btn btn-primary" style="background:rgba(74,222,128,0.08);border-color:rgba(74,222,128,0.2);color:#4ade80;cursor:default;opacity:0.8;">✓ IN LIBRARY</span>`; }
            else { html += `<button onclick="addToCart('${game.id}', this)" class="btn btn-primary">+ ADD TO CART</button>`; }
            html += `<button onclick="toggleWishlist('${game.id}', this)" class="btn btn-secondary modal-wishlist-btn" title="Add to wishlist">&#9825;</button>`;
        } else {
            html += `<a href="/Auth/Login" class="btn btn-secondary">LOGIN TO PURCHASE</a>`;
        }
        html += `</div></div>`;
        const gameReviews = reviewsData[game.id] || [];
        html += `<div class="modal-reviews"><div class="modal-reviews-title">> REVIEWS (${gameReviews.length})</div>`;
        if (gameReviews.length === 0) { html += `<div class="modal-no-reviews">No reviews yet.</div>`; }
        else { gameReviews.forEach(r => { html += `<div class="modal-review-card"><div class="modal-review-top"><span class="modal-review-user">${e(r.username)}</span><span class="modal-review-stars">${renderStars(r.rating)}</span></div>${r.comment ? `<div class="modal-review-comment">${e(r.comment)}</div>` : ''}<div class="modal-review-date">${e(r.createdAt)}</div></div>`; }); }
        if (isLoggedIn && ownedGameIds.includes(game.id)) {
            html += `<div class="modal-review-form-box"><div class="modal-review-form-title">WRITE A REVIEW</div><div class="modal-stars-select">`;
            for (let i = 1; i <= 5; i++) html += `<span onclick="setRating(this, ${i})" class="modal-star" data-rating="${i}">☆</span>`;
            html += `</div><textarea id="reviewComment" class="modal-review-textarea" placeholder="Share your thoughts..."></textarea><button onclick="submitReview('${game.id}')" class="btn btn-primary" style="margin-top:12px; padding:8px 16px; font-size:12px;">SUBMIT REVIEW</button><div id="reviewMsg" class="modal-review-msg"></div></div>`;
        }
        html += `</div></div>`;
        document.getElementById('modalContent').innerHTML = html;
        document.getElementById('gameModal').classList.add('open');
        loadModalReqs(game.id);
        loadModalVersions(game.id);
        document.body.style.overflow = 'hidden';
    }

    function loadModalReqs(gameId) {
        var container = document.getElementById('modalReqs_' + gameId);
        if (!container) return;
        fetch('/Home/GetRequirements/' + gameId)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (!data || (!data.minimum && !data.recommended)) { container.innerHTML = ''; return; }
            var min = data.minimum, rec = data.recommended;
            if (!min && !rec) { container.innerHTML = ''; return; }
            var reqHtml = '<details style="margin:0;border:1px solid rgba(138,28,36,0.2);border-radius:2px;"><summary style="cursor:pointer;padding:8px 12px;font-family:var(--font-mono);font-size:11px;color:var(--text-dim);letter-spacing:1px;">SYSTEM REQUIREMENTS</summary><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:8px 12px;font-family:var(--font-mono);font-size:11px;">';
            if (min) {
              reqHtml += '<div><div style="color:var(--red);margin-bottom:4px;font-size:10px;letter-spacing:1px;">MINIMUM</div>';
              reqHtml += (min.os ? '<div style="margin-bottom:2px;">' + escapeHtml(min.os) + '</div>' : '');
              reqHtml += (min.processor ? '<div style="margin-bottom:2px;">' + escapeHtml(min.processor) + '</div>' : '');
              reqHtml += (min.memory ? '<div style="margin-bottom:2px;">' + escapeHtml(min.memory) + '</div>' : '');
              reqHtml += (min.graphics ? '<div style="margin-bottom:2px;">' + escapeHtml(min.graphics) + '</div>' : '');
              reqHtml += (min.directX ? '<div style="margin-bottom:2px;">' + escapeHtml(min.directX) + '</div>' : '');
              reqHtml += (min.storage ? '<div style="margin-bottom:2px;">' + escapeHtml(min.storage) + '</div>' : '');
              reqHtml += '</div>';
            }
            if (rec) {
              reqHtml += '<div><div style="color:var(--gold);margin-bottom:4px;font-size:10px;letter-spacing:1px;">RECOMMENDED</div>';
              reqHtml += (rec.os ? '<div style="margin-bottom:2px;">' + escapeHtml(rec.os) + '</div>' : '');
              reqHtml += (rec.processor ? '<div style="margin-bottom:2px;">' + escapeHtml(rec.processor) + '</div>' : '');
              reqHtml += (rec.memory ? '<div style="margin-bottom:2px;">' + escapeHtml(rec.memory) + '</div>' : '');
              reqHtml += (rec.graphics ? '<div style="margin-bottom:2px;">' + escapeHtml(rec.graphics) + '</div>' : '');
              reqHtml += (rec.directX ? '<div style="margin-bottom:2px;">' + escapeHtml(rec.directX) + '</div>' : '');
              reqHtml += (rec.storage ? '<div style="margin-bottom:2px;">' + escapeHtml(rec.storage) + '</div>' : '');
              reqHtml += '</div>';
            }
            reqHtml += '</div></details>';
            container.innerHTML = reqHtml;
          })
          .catch(function() { container.innerHTML = ''; });
    }

    function loadModalVersions(gameId) {
        var container = document.getElementById('modalVersions_' + gameId);
        var dlBox = document.getElementById('modalDlBox_' + gameId);
        if (!container) return;
        fetch('/Home/GetVersions/' + gameId)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (!data || data.length === 0) { container.innerHTML = ''; return; }
            var currentVer = data.find(function(v) { return v.isCurrent; }) || data[0];
            var verHtml = '<div style="font-family:var(--font-mono);font-size:11px;color:var(--gold);margin-bottom:4px;">v' + escapeHtml(currentVer.versionLabel) + (currentVer.isCurrent ? ' <span style="color:#4ade80;border:1px solid rgba(74,222,128,0.3);padding:1px 5px;font-size:9px;">CURRENT</span>' : '') + '</div>';
            if (data.length > 1) {
                verHtml += '<select id="verSelect_' + gameId + '" style="background:var(--bg3);border:1px solid var(--border-red);color:var(--text);font-family:var(--font-mono);font-size:11px;padding:4px 8px;width:100%;outline:none;margin-bottom:6px;" onchange="updateModalDl(\'' + gameId + '\', this)">';
                data.sort(function(a, b) { return new Date(b.uploadedAt) - new Date(a.uploadedAt); }).forEach(function(v) {
                    verHtml += '<option value="' + v.id + '"' + (v.isCurrent ? ' selected' : '') + '>v' + escapeHtml(v.versionLabel) + (v.isCurrent ? ' (CURRENT)' : '') + ' — ' + escapeHtml(v.fileName) + '</option>';
                });
                verHtml += '</select>';
            }
            container.innerHTML = verHtml;
            // Update download box with version info
            if (dlBox) {
                var nameEl = dlBox.querySelector('.modal-download-name');
                var sizeEl = dlBox.querySelector('.modal-download-size');
                var linkEl = dlBox.querySelector('a');
                if (nameEl) nameEl.textContent = currentVer.fileName || 'GAME FILE';
                if (sizeEl) sizeEl.textContent = fmtSize(currentVer.fileSizeBytes) + ' OK';
                if (linkEl) linkEl.href = '/Library/Download/' + gameId + '?versionId=' + encodeURIComponent(currentVer.id);
            }
          })
          .catch(function() { container.innerHTML = ''; });
    }

    function updateModalDl(gameId, select) {
        var versionId = select.value;
        var dlBox = document.getElementById('modalDlBox_' + gameId);
        if (dlBox) {
            var linkEl = dlBox.querySelector('a');
            if (linkEl) linkEl.href = '/Library/Download/' + gameId + '?versionId=' + encodeURIComponent(versionId);
        }
    }

    let selectedRating = 0;
    function setRating(el, rating) {
        selectedRating = rating;
        document.querySelectorAll('#modalContent [data-rating]').forEach(s => { const r = parseInt(s.dataset.rating); s.textContent = r <= rating ? '★' : '☆'; s.style.color = r <= rating ? 'var(--gold)' : 'var(--text-dim)'; });
    }

    function addToCart(gameId, btn) {
        btn.textContent = 'ADDING...'; btn.disabled = true;
        fetch('/Cart/AddToCart', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value }, body: JSON.stringify(gameId) })
        .then(r => r.json()).then(d => {
            if (d.success) { btn.textContent = '✓ ADDED'; btn.classList.remove('btn-primary'); btn.classList.add('btn-secondary'); cartIds.push(gameId); showToast('Added to cart!', 'success'); }
            else { alert(d.message); btn.textContent = '+ ADD TO CART'; btn.disabled = false; }
        }).catch(() => { btn.textContent = '+ ADD TO CART'; btn.disabled = false; });
    }

    function toggleWishlist(gameId, btn) {
        btn.textContent = '...'; btn.disabled = true;
        fetch('/Wishlist/ToggleWishlist', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value }, body: JSON.stringify(gameId) })
        .then(r => r.json()).then(d => {
            if (d.success) {
                if (d.inWishlist) { wishlistIds.push(gameId); btn.innerHTML = '&#9829;'; showToast('Added to wishlist!', 'success'); }
                else { const idx = wishlistIds.indexOf(gameId); if (idx > -1) wishlistIds.splice(idx, 1); btn.innerHTML = '&#9825;'; showToast('Removed from wishlist.', 'warning'); }
            } else { showToast(d.message || 'Error', 'error'); }
            btn.disabled = false;
        }).catch(() => { btn.disabled = false; btn.innerHTML = '&#9825;'; });
    }

    function submitReview(gameId) {
        const comment = document.getElementById('reviewComment').value;
        const msg = document.getElementById('reviewMsg');
        if (selectedRating === 0) { msg.textContent = '[ERROR] Please select a rating.'; msg.style.color = 'var(--red)'; return; }
        msg.textContent = '[SUBMITTING...]'; msg.style.color = 'var(--text-dim)';
        fetch('/Reviews/AddReview', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value }, body: JSON.stringify({ gameId, rating: selectedRating, comment }) })
        .then(r => r.json()).then(d => {
            if (d.success) { msg.textContent = '[OK] Review submitted!'; msg.style.color = '#4ade80'; document.getElementById('reviewComment').value = ''; selectedRating = 0; document.querySelectorAll('#modalContent [data-rating]').forEach(s => { s.textContent = '☆'; s.style.color = 'var(--text-dim)'; }); }
            else { msg.textContent = '[ERROR] ' + d.message; msg.style.color = 'var(--red)'; }
        }).catch(() => { msg.textContent = '[ERROR] Something went wrong.'; msg.style.color = 'var(--red)'; });
    }

    function closeModal() { document.getElementById('gameModal').classList.remove('open'); document.body.style.overflow = ''; selectedRating = 0; }
    function closeModalOutside(e) { if (e.target.id === 'gameModal') closeModal(); }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    let heroIdx = 0, heroTimer = null;
    function heroGoTo(i) {
        if (i === heroIdx) return;
        document.querySelectorAll('.hero-item').forEach((el, idx) => el.classList.toggle('active', idx === i));
        document.querySelectorAll('.hero-dot').forEach((d, idx) => d.classList.toggle('active', idx === i));
        heroIdx = i; resetHeroTimer();
    }
    function heroNext(e) { if (e) e.stopPropagation(); heroGoTo((heroIdx + 1) % heroGames.length); }
    function heroPrev(e) { if (e) e.stopPropagation(); heroGoTo((heroIdx - 1 + heroGames.length) % heroGames.length); }
    function resetHeroTimer() { if (heroTimer) clearInterval(heroTimer); heroTimer = setInterval(() => heroGoTo((heroIdx + 1) % heroGames.length), 5000); }
    if (heroGames.length > 0) {
        for (let i = 0; i < heroGames.length; i++) { const dot = document.createElement('div'); dot.className = 'hero-dot' + (i === 0 ? ' active' : ''); dot.onclick = function() { heroGoTo(i); }; document.getElementById('heroDots').appendChild(dot); }
        resetHeroTimer();
        const carousel = document.getElementById('heroCarousel');
        carousel.addEventListener('mouseenter', () => { if (heroTimer) clearInterval(heroTimer); heroTimer = null; });
        carousel.addEventListener('mouseleave', resetHeroTimer);
    }

    let activeCat = '';
    function selectCat(el) { var cat = el.dataset.cat || ''; document.querySelectorAll('.cat-pill').forEach(p => p.classList.remove('active')); el.classList.add('active'); activeCat = cat; applyFilters(); }
    function applyFilters() {
        const q = document.getElementById('searchInput').value.trim();
        pageCache = {};
        loadPage(1, q);
    }
    function applyClientFilters() {
        var sort = document.getElementById('sortSelect').value;
        var cards = Array.from(document.querySelectorAll('.game-card'));
        cards.forEach(function(c) {
            var matchCat = !activeCat || (c.dataset.cats || '').includes(activeCat);
            var matchFree = sort !== 'free' || parseFloat(c.dataset.price) === 0;
            c.style.display = (matchCat && matchFree) ? '' : 'none';
        });
        var visible = cards.filter(function(c) { return c.style.display !== 'none'; });
        visible.sort(function(a, b) {
            if (sort === 'name') return a.dataset.title.localeCompare(b.dataset.title);
            if (sort === 'price-asc') return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
            if (sort === 'price-desc') return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
            return parseInt(b.dataset.date) - parseInt(a.dataset.date);
        });
        var grid = document.getElementById('gamesGrid');
        visible.forEach(function(c) { grid.appendChild(c); });
    }

    document.querySelectorAll('.game-card, .cat-pill').forEach(el => {
        el.classList.add('ripple');
        el.addEventListener('mousedown', function(e) { const rect = this.getBoundingClientRect(); this.style.setProperty('--mx', (e.clientX - rect.left) + 'px'); this.style.setProperty('--my', (e.clientY - rect.top) + 'px'); });
    });

    // ── AJAX Pagination ──────────────────────────────────────────────
    var pageCache = {};
    document.getElementById('gameGridContainer').addEventListener('click', function(e) {
        var link = e.target.closest('.pagination-link');
        if (!link) return;
        e.preventDefault();
        var page = link.dataset.page;
        var search = link.dataset.search || '';
        if (!page) return;
        loadPage(page, search);
    });

    function loadPage(page, search) {
        search = search || document.getElementById('searchInput').value.trim();
        var cacheKey = page + '|' + search;
        function afterLoad() {
            history.replaceState(null, '', '?page=' + page + (search ? '&search=' + encodeURIComponent(search) : ''));
            applyClientFilters();
        }
        if (pageCache[cacheKey]) {
            document.getElementById('gameGridContainer').innerHTML = pageCache[cacheKey];
            afterLoad();
            return;
        }
        var url = '/Home/GetGameGrid?page=' + page;
        if (search) url += '&search=' + encodeURIComponent(search);
        fetch(url)
            .then(function(r) { return r.text(); })
            .then(function(html) {
                pageCache[cacheKey] = html;
                document.getElementById('gameGridContainer').innerHTML = html;
                afterLoad();
            });
    }

    var hash = window.location.hash;
    if (hash && hash.startsWith('#game-')) {
        var gameId = hash.substring(6);
        var card = document.querySelector('.game-card[data-game-id="' + gameId + '"]');
        if (card) { card.click(); }
    }
</script>
}
