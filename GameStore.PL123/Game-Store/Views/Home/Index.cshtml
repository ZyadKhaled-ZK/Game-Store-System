                <defs><linearGradient id="wg" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#e63946"/><stop offset="100%" stop-color="#8a1c24"/></linearGradient></defs>
                <polygon class="logo-rotator" points="60,10 90,40 60,70 30,40" fill="url(#wg)"/>
                <polygon points="60,25 75,40 60,55 45,40" fill="#070709"/>
                <text class="logo-blink" x="60" y="95" font-family="'Orbitron',monospace" font-size="36" font-weight="900" fill="white" text-anchor="middle" letter-spacing="2">GS</text>
            </svg>
        </div>
        <div class="welcome-title"><span>G</span>AME <span>S</span>TORE</div>
        <div class="welcome-sub"><span class="blink">_</span> WELCOME BACK, <span id="welcomeUsername"></span> <span class="blink">_</span></div>
