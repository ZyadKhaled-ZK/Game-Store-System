@model Tuple<Developer, List<Game>>
@{
    var dev = Model.Item1;
    var games = Model.Item2;
    Layout = "_Layout";
}

<div class="container" style="padding:40px 20px;max-width:1200px;margin:0 auto;">
    <div style="margin-bottom:40px;">
        <a asp-action="Index" style="color:var(--text-dim);font-family:var(--font-mono);font-size:11px;text-decoration:none;letter-spacing:1px;">&larr; BACK TO DEVELOPERS</a>
    </div>

    <div style="display:flex;gap:30px;align-items:flex-start;margin-bottom:40px;border-bottom:1px solid var(--border);padding-bottom:30px;flex-wrap:wrap;">
        @if (!string.IsNullOrEmpty(dev.LogoUrl))
        {
            <img src="@dev.LogoUrl" alt="@dev.Name" style="width:120px;height:120px;object-fit:contain;filter:drop-shadow(0 0 12px rgba(245,197,66,0.3));" loading="lazy" />
        }
        else
        {
            <div style="width:120px;height:120px;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:48px;color:var(--gold);">@dev.Name[0]</div>
        }
        <div style="flex:1;min-width:250px;">
            <h1 style="font-family:var(--font-display);font-size:28px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:10px;">@dev.Name</h1>
            @if (!string.IsNullOrEmpty(dev.Country))
            {
                <span style="font-size:12px;color:var(--text-dim);display:block;margin-bottom:8px;">@dev.Country</span>
            }
            @if (!string.IsNullOrEmpty(dev.Description))
            {
                <p style="font-size:13px;color:var(--text);line-height:1.8;margin-bottom:12px;">@dev.Description</p>
            }
            @if (!string.IsNullOrEmpty(dev.Website))
            {
                <a href="@dev.Website" target="_blank" class="btn btn-secondary" style="padding:8px 16px;font-size:10px;text-decoration:none;">VISIT WEBSITE &#8599;</a>
            }
        </div>
        <div style="display:flex;gap:20px;">
            <div style="text-align:center;padding:20px;background:var(--bg2);border:1px solid var(--border);min-width:100px;">
                <div style="font-family:var(--font-display);font-size:24px;color:var(--gold);">@ViewData["GameCount"]</div>
                <div style="font-family:var(--font-mono);font-size:9px;color:var(--text-dim);letter-spacing:1px;">GAMES</div>
            </div>
            <div style="text-align:center;padding:20px;background:var(--bg2);border:1px solid var(--border);min-width:100px;">
                <div style="font-family:var(--font-display);font-size:24px;color:var(--gold);">@ViewData["TotalDownloads"]</div>
                <div style="font-family:var(--font-mono);font-size:9px;color:var(--text-dim);letter-spacing:1px;">DOWNLOADS</div>
            </div>
            <div style="text-align:center;padding:20px;background:var(--bg2);border:1px solid var(--border);min-width:100px;">
                <div style="font-family:var(--font-display);font-size:24px;color:var(--gold);">@ViewData["AvgRating"]</div>
                <div style="font-family:var(--font-mono);font-size:9px;color:var(--text-dim);letter-spacing:1px;">RATING</div>
            </div>
        </div>
    </div>

    <h2 style="font-family:var(--font-mono);font-size:16px;letter-spacing:2px;text-transform:uppercase;color:var(--text-dim);margin-bottom:20px;">Games by @dev.Name</h2>

    @if (!games.Any())
    {
        <div style="padding:60px;text-align:center;">
            <p style="font-family:var(--font-mono);color:var(--text-dim);">[ NO GAMES PUBLISHED YET ]</p>
        </div>
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px;">
            @foreach (var game in games)
            {
                <a asp-controller="Home" asp-action="Details" asp-route-id="@game.Id" style="text-decoration:none;">
                    <div style="background:var(--bg2);border:1px solid var(--border);padding:20px;transition:0.2s;"
                         onmouseover="this.style.borderColor='var(--gold)';this.style.boxShadow='var(--glow-gold)'"
                         onmouseout="this.style.borderColor='';this.style.boxShadow=''">
                        @if (!string.IsNullOrEmpty(game.CoverImageUrl))
                        {
                            <img src="@game.CoverImageUrl" alt="@game.Title" style="width:100%;height:140px;object-fit:cover;margin-bottom:12px;" loading="lazy" />
                        }
                        <h3 style="font-family:var(--font-mono);font-size:13px;color:var(--text);margin-bottom:6px;">@game.Title</h3>
                        <span style="font-family:var(--font-mono);font-size:12px;color:var(--gold);">@(game.Price == 0 ? "FREE" : $"${game.Price:F2}")</span>
                    </div>
                </a>
            }
        </div>
    }
</div>
