@model OrderListViewModel
@{
    ViewData["Title"] = "My Orders";
}

<style>
  .orders-page { max-width: 1000px; margin: 0 auto; }
  .order-card {
    background: var(--bg2);
    border: 1px solid var(--border-red);
    margin-bottom: 16px;
    transition: border-color 0.2s;
  }
  .order-card:hover { border-color: var(--red); }
  .order-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border-red);
    background: rgba(230,57,70,0.03);
  }
  .order-id { font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); }
  .order-date { font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); }
  .order-total { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--gold); }
  .order-body { padding: 16px 20px; }
  .order-game {
    display: flex; align-items: center; gap: 12px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(230,57,70,0.08);
  }
  .order-game:last-child { border-bottom: none; }
  .order-game-img { width: 48px; height: 32px; object-fit: cover; border: 1px solid var(--border-red); }
  .order-game-img-placeholder {
    width: 48px; height: 32px;
    background: var(--bg3); border: 1px solid var(--border-red);
    display: flex; align-items: center; justify-content: center;
    color: var(--red); font-size: 14px;
  }
  .order-game-title { font-family: var(--font-display); font-size: 0.9rem; color: white; flex: 1; }
  .order-game-price { font-family: var(--font-mono); font-size: 0.85rem; color: var(--gold); }
  .empty-orders { text-align: center; padding: 80px; font-family: var(--font-mono); color: var(--text-dim); }
</style>

<div class="orders-page">
  <div class="page-header" style="display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:16px; margin-bottom:32px;">
    <div>
      <h2 class="section-title glitch">MY ORDERS</h2>
    </div>
    <a href="/" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> BACK TO STORE</a>
  </div>

  @if (!Model.Orders.Any())
  {
    <div class="empty-orders">
      <div style="font-size:3rem; margin-bottom:16px; color:var(--red);">&empty;</div>
      <h3 style="font-family:var(--font-display); color:white; margin-bottom:8px;">NO ORDERS YET</h3>
      <p>You haven't purchased any games. <a href="/" style="color:var(--gold);">BROWSE GAMES &rarr;</a></p>
    </div>
  }

  @foreach (var order in Model.Orders)
  {
    <div class="order-card">
      <div class="order-header">
        <div>
          <div class="order-id">ORDER #@order.Id.Substring(0, Math.Min(8, order.Id.Length)).ToUpper()</div>
          <div class="order-date">@order.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
        </div>
        <div class="order-total">$@order.TotalPrice.ToString("0.00")</div>
        <div>
          <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-secondary" style="padding:6px 12px; font-size:11px;">VIEW</a>
        </div>
      </div>
      <div class="order-body">
        @foreach (var item in order.OrderItems)
        {
          <div class="order-game">
            @if (!string.IsNullOrEmpty(item.Game?.CoverImageUrl))
            {
              <img class="order-game-img" src="@item.Game.CoverImageUrl" alt="@item.Game.Title" />
            }
            else if (item.Game?.ScreenshotUrls.Any() == true)
            {
              <img class="order-game-img" src="@item.Game.ScreenshotUrls[0]" alt="@item.Game.Title" />
            }
            else
            {
              <div class="order-game-img-placeholder">&#8853;</div>
            }
            <div class="order-game-title">@(item.Game?.Title ?? "UNKNOWN")</div>
            <div class="order-game-price">$@item.PriceAtPurchase.ToString("0.00")</div>
          </div>
        }
      </div>
    </div>
  }
</div>
