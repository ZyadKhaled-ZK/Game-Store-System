@model OrderDetailViewModel
@{
    ViewData["Title"] = "Order Details";
}

<style>
  .order-detail-page { max-width: 900px; margin: 0 auto; }
  .detail-card {
    background: var(--bg2);
    border: 1px solid var(--border-red);
    padding: 32px;
  }
  .detail-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    padding-bottom: 20px; border-bottom: 1px solid var(--border-red); margin-bottom: 24px;
  }
  .detail-order-id { font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); }
  .detail-order-date { font-family: var(--font-mono); font-size: 14px; color: var(--text); margin-top: 4px; }
  .detail-total { font-family: var(--font-display); font-size: 1.8rem; font-weight: 900; color: var(--gold); }
  .detail-section-title {
    font-family: var(--font-mono); font-size: 12px; color: var(--red); letter-spacing: 2px;
    text-transform: uppercase; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid rgba(230,57,70,0.15);
  }
  .detail-item {
    display: flex; align-items: center; gap: 16px;
    padding: 12px 0; border-bottom: 1px solid rgba(230,57,70,0.06);
  }
  .detail-item:last-child { border-bottom: none; }
  .detail-item-img { width: 64px; height: 40px; object-fit: cover; border: 1px solid var(--border-red); }
  .detail-item-img-placeholder {
    width: 64px; height: 40px; background: var(--bg3); border: 1px solid var(--border-red);
    display: flex; align-items: center; justify-content: center; color: var(--red); font-size: 16px;
  }
  .detail-item-title { font-family: var(--font-display); font-size: 1rem; color: white; flex: 1; }
  .detail-item-price { font-family: var(--font-mono); font-size: 0.9rem; color: var(--gold); }
</style>

<div class="order-detail-page">
  <div style="display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:16px; margin-bottom:32px;">
    <div>
      <div class="section-tag">Order Info</div>
      <h2 class="section-title glitch">ORDER DETAILS</h2>
    </div>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> BACK TO ORDERS</a>
  </div>

  @if (Model.IsError)
  {
    <div class="detail-card" style="text-align:center; padding:60px;">
      <div style="font-size:3rem; margin-bottom:16px; color:var(--red);">!</div>
      <h3 style="font-family:var(--font-display); color:white; margin-bottom:8px;">ORDER NOT FOUND</h3>
      <p style="font-family:var(--font-mono); color:var(--text-dim);">@Model.Message</p>
    </div>
  }
  else if (Model.Order != null)
  {
    <div class="detail-card">
      <div class="detail-header">
        <div>
          <div class="detail-order-id">ORDER #@Model.Order.Id.Substring(0, Math.Min(8, Model.Order.Id.Length)).ToUpper()</div>
          <div class="detail-order-date">@Model.Order.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC</div>
        </div>
        <div class="detail-total">$@Model.Order.TotalPrice.ToString("0.00")</div>
      </div>

      <div style="margin-bottom:24px;">
        <div class="detail-section-title">> GAMES IN THIS ORDER</div>
        @foreach (var item in Model.Order.OrderItems)
        {
          <div class="detail-item">
            @if (!string.IsNullOrEmpty(item.Game?.CoverImageUrl))
            {
              <img class="detail-item-img" src="@item.Game.CoverImageUrl" alt="@item.Game.Title" />
            }
            else if (item.Game?.ScreenshotUrls.Any() == true)
            {
              <img class="detail-item-img" src="@item.Game.ScreenshotUrls[0]" alt="@item.Game.Title" />
            }
            else
            {
              <div class="detail-item-img-placeholder">&#8853;</div>
            }
            <div class="detail-item-title">@(item.Game?.Title ?? "UNKNOWN GAME")</div>
            <div class="detail-item-price">$@item.PriceAtPurchase.ToString("0.00")</div>
          </div>
        }
      </div>

      <div style="padding-top:16px; border-top:1px solid var(--border-red); display:flex; justify-content:space-between; align-items:center;">
        <div style="font-family:var(--font-mono); font-size:12px; color:var(--text-dim);">
          @Model.Order.OrderItems.Count game(s) purchased
        </div>
        <div style="font-family:var(--font-display); font-size:1.4rem; font-weight:900; color:var(--gold);">
          TOTAL: $@Model.Order.TotalPrice.ToString("0.00")
        </div>
      </div>
    </div>
  }
</div>
