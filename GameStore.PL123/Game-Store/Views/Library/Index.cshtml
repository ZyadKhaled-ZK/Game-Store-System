@model LibraryViewModel
@{
    ViewData["Title"] = "My Library";
    var isLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString("UserId"));
    var currentRole = Model.CurrentUserRole ?? "";
    var isAdmin = currentRole == "ADMIN";
}

<style>
  .lib-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; margin-top: 24px; }
  .lib-card {
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); padding: 20px;
    display: flex; flex-direction: column; gap: 12px; border-radius: 12px; backdrop-filter: blur(8px);
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1); position: relative; overflow: hidden;
  }
  .lib-card:hover { border-color: rgba(230,57,70,0.4); box-shadow: 0 10px 30px rgba(0,0,0,0.6), 0 0 15px rgba(230,57,70,0.2); transform: translateY(-5px); }
  .lib-img { width: 100%; height: 160px; object-fit: cover; border-radius: 8px; border: 1px solid rgba(255,255,255,0.06); transition: transform 0.4s ease; }
  .lib-card:hover .lib-img { transform: scale(1.03); }
  .lib-img-placeholder { width: 100%; height: 160px; background: rgba(255,255,255,0.02); border-radius: 8px; border: 1px solid rgba(255,255,255,0.06); display: flex; align-items: center; justify-content: center; color: rgba(230,57,70,0.5); font-size: 2.5rem; }
  .lib-title { font-family: var(--font-display); font-weight: 700; color: white; font-size: 0.95rem; }
  .lib-dev { font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); }
  .lib-added { font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); }
  .empty-lib { text-align: center; padding: 80px; font-family: var(--font-mono); color: var(--text-dim); }
  .version-select { background: var(--bg3); border: 1px solid var(--border-red); color: var(--text); font-family: var(--font-mono); font-size: 11px; padding: 6px 8px; width: 100%; outline: none; cursor: pointer; }
  .version-select:hover { border-color: var(--red-dim); }
  .version-select:focus { border-color: var(--red); box-shadow: var(--glow-red); }
  @@media (max-width: 768px) {
    .empty-lib { padding: 40px 20px; }
    .lib-grid { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
    .lib-card { padding: 16px; }
    .section-title { font-size: 1.8rem !important; }
  }
  @@media (max-width: 576px) {
    .empty-lib { padding: 30px 16px; }
    .lib-grid { grid-template-columns: 1fr; gap: 12px; margin-top: 16px; }
    .lib-card { padding: 12px; }
    .lib-img, .lib-img-placeholder { height: 120px; }
    .lib-title { font-size: 0.85rem; }
    .page-header { flex-direction: column; align-items: stretch !important; }
    .page-header .btn { width: 100%; text-align: center; }
    .section-title { font-size: 1.4rem !important; }
    .page-header + div[style*="max-width:400px"] { max-width: 100% !important; }
  }
</style>

<div class="page-header" style="display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:16px; margin-bottom:32px;">
  <div>
    <div class="section-tag">Collection</div>
    <h2 class="section-title glitch">MY LIBRARY</h2>
  </div>
  <a href="/" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> BROWSE STORE</a>
</div>

<div style="font-family:var(--font-mono); font-size:12px; color:var(--text-dim); margin-bottom:12px;">
  [ <span id="libCount">@Model.LibraryGames.Count</span> TITLE(S) IN LIBRARY ]
</div>

@if (Model.AvailableCredit > 0)
{
  <div style="font-family:var(--font-mono); font-size:12px; color:var(--gold); border:1px solid rgba(255,183,3,0.3); padding:10px 16px; margin-bottom:20px; display:inline-block;">
    STORE CREDIT: $@Model.AvailableCredit.ToString("0.00") — auto-applied at checkout
  </div>
}

<div style="margin-bottom:20px; max-width:400px;">
  <input type="text" id="libSearch" class="gs-search" placeholder="Search your library..." oninput="filterLibrary()" style="width:100%;" />
</div>

@if (isLoggedIn && Model.LibraryGames.Any())
{
  <div class="lib-grid" id="libGrid">
    @foreach (var lg in Model.LibraryGames)
    {
      <div class="lib-card" data-title="@(lg.Game?.Title?.ToLower() ?? "")" data-dev="@(lg.Game?.Developer?.ToLower() ?? "")">
        @if (!string.IsNullOrEmpty(lg.Game?.CoverImageUrl))
        {
          <img src="@lg.Game.CoverImageUrl" alt="@lg.Game.Title" class="lib-img" loading="lazy"/>
        }
        else if (lg.Game?.ScreenshotUrls.Any() == true)
        {
          <img src="@lg.Game.ScreenshotUrls[0]" alt="@lg.Game.Title" class="lib-img" loading="lazy"/>
        }
        else
        {
          <div class="lib-img-placeholder">⊗</div>
        }
        @{
          var versions = Model.GameVersions.GetValueOrDefault(lg.GameId);
          var currentVer = versions?.FirstOrDefault(v => v.IsCurrent) ?? versions?.FirstOrDefault();
        }
        <div>
          <div class="lib-title">@(lg.Game?.Title ?? "Unknown")</div>
          <div class="lib-dev">@((lg.Game?.Developer ?? "Anon").ToUpper())</div>
          <div class="lib-added">ADDED: @lg.AddedAt.ToString("yyyy-MM-dd")</div>
          @if (currentVer != null)
          {
            <div style="font-family:var(--font-mono);font-size:10px;color:var(--gold);margin-top:4px;">
              v@(currentVer.VersionLabel)
              @if (currentVer.IsCurrent) { <span style="color:#4ade80;border:1px solid rgba(74,222,128,0.3);padding:1px 5px;font-size:9px;margin-left:4px;">CURRENT</span> }
            </div>
          }
        </div>
        @{
          var isPreRelease = lg.Game?.ReleaseDate > DateTime.UtcNow;
          var hasVersions = versions != null && versions.Count > 0;
          var canDownload = hasVersions || (!isPreRelease && lg.Game?.GameFileUrl != null);
        }
        @if (isPreRelease)
        {
          <div style="font-family:var(--font-mono);font-size:10px;color:var(--gold);margin-bottom:4px;">PRE-RELEASE — TESTING COPY</div>
          if (Model.PreviewableGameIds.Contains(lg.GameId))
          {
            var action = hasVersions ? "Download" : "PreviewDownload";
            <a asp-action="@action" asp-controller="Library" asp-route-id="@lg.GameId" class="btn btn-primary version-dl-btn" style="text-align:center; justify-content:center; padding:10px; font-size:12px; width:100%;">⬇ @(hasVersions ? "DOWNLOAD v" + currentVer?.VersionLabel : "PREVIEW DOWNLOAD")</a>
          }
          else
          {
            <div class="btn btn-secondary" style="text-align:center; justify-content:center; padding:10px; font-size:12px; width:100%; opacity:0.5; cursor:not-allowed;" disabled>COMING SOON</div>
          }
        }
        else if (canDownload)
        {
          if (versions != null && versions.Count > 1)
          {
            <select class="version-select" data-gameid="@lg.GameId" onchange="updateDownloadLink(this)">
              @foreach (var v in versions.OrderByDescending(v => v.UploadedAt))
              {
                <option value="@v.Id">v@(v.VersionLabel) @(v.IsCurrent ? "(CURRENT)" : "") — @v.FileName</option>
              }
            </select>
          }
          var dlVersionId = currentVer?.Id;
          <a asp-action="Download" asp-controller="Library" asp-route-id="@lg.GameId" asp-route-versionId="@dlVersionId" class="btn btn-primary version-dl-btn" style="text-align:center; justify-content:center; padding:10px; font-size:12px; width:100%;">⬇ DOWNLOAD @(currentVer != null ? "v" + currentVer.VersionLabel : "")</a>
        }
        else
        {
          <div class="btn btn-secondary" style="text-align:center; justify-content:center; padding:10px; font-size:12px; width:100%; opacity:0.5; cursor:not-allowed;" disabled>NO FILE</div>
        }
        <a asp-area="" asp-controller="Refunds" asp-action="Index" class="btn btn-secondary" style="text-align:center; justify-content:center; padding:6px; font-size:10px; width:100%; letter-spacing:1px;">↩ REQUEST REFUND</a>
      </div>
    }
  </div>
  <script>
    function filterLibrary() {
      const q = document.getElementById('libSearch').value.toLowerCase().trim();
      const cards = document.querySelectorAll('.lib-card');
      let count = 0;
      cards.forEach(c => {
        const match = !q || c.dataset.title.includes(q) || c.dataset.dev.includes(q);
        c.style.display = match ? '' : 'none';
        if (match) count++;
      });
      document.getElementById('libCount').textContent = count;
    }

    function updateDownloadLink(select) {
      var versionId = select.value;
      var gameId = select.dataset.gameid;
      var btn = select.parentElement.querySelector('.version-dl-btn');
      if (btn) {
        var label = select.options[select.selectedIndex].text.split(' — ')[0];
        btn.href = '/Library/Download/' + gameId + '?versionId=' + encodeURIComponent(versionId);
        btn.textContent = '\u2B07 DOWNLOAD ' + label;
      }
    }
  </script>
}
else
{
  <div class="empty-lib">
    <div style="font-size:3rem; margin-bottom:16px; color:var(--red);">📚</div>
    @if (isLoggedIn)
    {
      <h3 style="font-family:var(--font-display); color:white; margin-bottom:8px;">LIBRARY EMPTY</h3>
      <p>No titles owned yet. <a href="/" style="color:var(--gold);">BROWSE STORE →</a></p>
    }
    else
    {
      <h3 style="font-family:var(--font-display); color:white; margin-bottom:8px;">LOGIN REQUIRED</h3>
      <p><a href="/Auth/Login" style="color:var(--gold);">LOGIN</a> or <a href="/Auth/Register" style="color:var(--gold);">REGISTER</a> to see your library.</p>
    }
  </div>
}
