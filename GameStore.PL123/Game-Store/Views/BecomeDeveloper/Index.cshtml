@{
    ViewData["Title"] = "Become a Developer";
    var isLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString("UserId"));
    var isAdmin = ViewData["IsAdmin"] is true;
    var notLoggedIn = ViewData["NotLoggedIn"] is true;
    var noProfile = ViewData["NoProfile"] is true;
    var hasPending = ViewData["HasPendingApplication"] is true;
}

<style>
  @@media (max-width: 768px) {
    .bd-card { padding: 24px !important; }
    .section-title { font-size: 1.8rem !important; }
  }
  @@media (max-width: 576px) {
    .bd-card { padding: 16px !important; }
    .section-title { font-size: 1.4rem !important; }
    .bd-form-grid { grid-template-columns: 1fr !important; }
    .bd-card h3 { font-size: 15px !important; }
  }
</style>

<div class="row w-100 justify-content-center mt-2 mt-md-4 pt-1 pt-md-3">
  <div class="col-md-7">
    <div class="section-header text-center mb-3">
      <h2 class="section-title glitch">BECOME A DEVELOPER</h2>
      <div class="section-tag d-inline-flex">Publish your own games on the store</div>
    </div>

    @if (isAdmin)
    {
      <div class="bd-card" style="background:var(--bg2);border:1px solid var(--border-red);padding:40px;text-align:center;margin-top:20px;">
        <div style="font-size:40px;color:var(--red);opacity:0.3;margin-bottom:12px;"><i class="bi bi-shield-lock-fill"></i></div>
        <h3 style="font-family:var(--font-display);color:var(--red);font-size:18px;letter-spacing:2px;margin-bottom:12px;">ADMIN ACCESS DETECTED</h3>
        <p style="color:var(--text-dim);font-size:13px;margin-bottom:20px;">Administrators cannot become developers. Use a standard customer account if you wish to publish games.</p>
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-primary" style="background:var(--red);border-color:var(--red);color:#fff;">BACK TO ADMIN PANEL</a>
      </div>
    }
    else if (notLoggedIn)
    {
      <div class="bd-card" style="background:var(--bg2);border:1px solid var(--border-red);padding:40px;text-align:center;margin-top:20px;">
        <div style="font-size:40px;color:var(--gold);opacity:0.3;margin-bottom:12px;"><i class="bi bi-person-lock"></i></div>
        <h3 style="font-family:var(--font-display);color:var(--gold);font-size:18px;letter-spacing:2px;margin-bottom:12px;">SIGN IN REQUIRED</h3>
        <p style="color:var(--text-dim);font-size:13px;margin-bottom:20px;">You need to be logged in to register as a developer.</p>
        <a asp-controller="Auth" asp-action="Login" class="btn btn-primary">SIGN IN</a>
        <a asp-controller="Auth" asp-action="Register" class="btn btn-secondary" style="margin-left:10px;">REGISTER</a>
      </div>
    }
    else if (noProfile)
    {
      <div class="bd-card" style="background:var(--bg2);border:1px solid var(--border-red);padding:40px;text-align:center;margin-top:20px;">
        <div style="font-size:40px;color:var(--cyan);opacity:0.3;margin-bottom:12px;"><i class="bi bi-person-gear"></i></div>
        <h3 style="font-family:var(--font-display);color:var(--cyan);font-size:18px;letter-spacing:2px;margin-bottom:12px;">COMPLETE YOUR PROFILE</h3>
        <p style="color:var(--text-dim);font-size:13px;margin-bottom:20px;">Your account is set as a developer but you haven't created your studio profile yet.</p>
      </div>
    }
    else if (hasPending)
    {
      <div class="bd-card" style="background:var(--bg2);border:1px solid var(--border-gold);padding:40px;text-align:center;margin-top:20px;box-shadow:var(--glow-gold);">
        <div style="font-size:40px;color:var(--gold);opacity:0.3;margin-bottom:12px;"><i class="bi bi-hourglass-split"></i></div>
        <h3 style="font-family:var(--font-display);color:var(--gold);font-size:18px;letter-spacing:2px;margin-bottom:12px;">APPLICATION PENDING</h3>
        <p style="color:var(--text-dim);font-size:13px;margin-bottom:8px;">Your developer application has been submitted and is awaiting review by an administrator.</p>
        <p style="color:var(--text-dim);font-size:12px;">You will be notified once a decision has been made. This usually takes 1&ndash;2 business days.</p>
        <div style="margin-top:20px;">
          <a asp-controller="Home" asp-action="Index" class="btn btn-primary" style="border-color:var(--gold);color:var(--gold);background:transparent;">BACK TO STORE</a>
        </div>
      </div>
    }

    @if (!isAdmin && isLoggedIn && !notLoggedIn && !hasPending && !noProfile)
    {
      <div class="bd-card" style="background:var(--bg2);border:1px solid var(--border-red);padding:40px;box-shadow:var(--glow-red);margin-top:20px;">
        <div style="color:var(--red);border:1px solid var(--red);padding:5px 15px;display:inline-block;font-size:12px;margin-bottom:20px;font-family:var(--font-mono);letter-spacing:1px;">
          DEVELOPER REGISTRATION
        </div>

        <p style="color:var(--text-dim);font-size:13px;margin-bottom:24px;line-height:1.8;">
          As a registered developer you will be able to <span style="color:var(--gold);">publish games</span>,
          <span style="color:var(--gold);"> track sales and downloads</span>,
          and <span style="color:var(--gold);">manage your portfolio</span>
          directly from the Developer Portal.
        </p>

        <partial name="_Alert" />

        <form method="post" enctype="multipart/form-data">
          <div class="bd-form-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
            <div>
              <label style="color:var(--text-dim);font-family:var(--font-mono);font-size:12px;letter-spacing:1px;margin-bottom:4px;display:block;">Studio Name *</label>
              <input type="text" name="name" class="form-control" placeholder="Your studio or brand name" required maxlength="200" />
            </div>
            <div>
              <label style="color:var(--text-dim);font-family:var(--font-mono);font-size:12px;letter-spacing:1px;margin-bottom:4px;display:block;">Country</label>
              <input type="text" name="country" class="form-control" placeholder="e.g. Egypt" maxlength="100" />
            </div>
          </div>

          <div style="margin-bottom:16px;">
            <label style="color:var(--text-dim);font-family:var(--font-mono);font-size:12px;letter-spacing:1px;margin-bottom:4px;display:block;">Description</label>
            <textarea name="description" class="form-control" rows="4" placeholder="Tell us about your studio..." maxlength="2000" style="resize:vertical;"></textarea>
          </div>

          <div style="margin-bottom:16px;">
            <label style="color:var(--text-dim);font-family:var(--font-mono);font-size:12px;letter-spacing:1px;margin-bottom:4px;display:block;">Website</label>
            <input type="url" name="website" class="form-control" placeholder="https://your-studio.com" maxlength="500" />
          </div>

          <div style="margin-bottom:16px;">
            <label style="color:var(--text-dim);font-family:var(--font-mono);font-size:12px;letter-spacing:1px;margin-bottom:4px;display:block;">GitHub</label>
            <input type="url" name="githubUrl" class="form-control" placeholder="https://github.com/your-org" maxlength="500" />
          </div>

          <div style="margin-bottom:24px;">
            <label style="color:var(--text-dim);font-family:var(--font-mono);font-size:12px;letter-spacing:1px;margin-bottom:4px;display:block;">CV / Resume (PDF or Word)</label>
            <input type="file" name="cvFile" class="form-control" accept=".pdf,.doc,.docx" style="padding:8px;font-size:12px;" />
          </div>

          <button type="submit" class="btn btn-primary">ACTIVATE DEVELOPER ACCOUNT</button>
        </form>
      </div>

      <div class="text-center mt-3">
        <a asp-controller="Home" asp-action="Index" style="color:var(--text-dim);font-family:var(--font-mono);text-decoration:none;font-size:12px;transition:color 0.2s;"
           onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text-dim)'">
          &lt; BACK TO STORE
        </a>
      </div>
    }
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
