@model List<GameStore.PL.Models.Friends.FriendRequestViewModel>
@{
    ViewData["Title"] = "Friend Requests";
}

@section Styles {
<style>
.requests-page { max-width: 700px; margin: 0 auto; }
.page-header { margin-bottom: 30px; }
.glitch-text { font-family: var(--font-display); font-size: 32px; letter-spacing: 4px; }
.requests-list { display: grid; gap: 12px; }
.request-card { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; background: var(--bg3); border: 1px solid var(--border); transition: all 0.2s; }
.request-card:hover { border-color: var(--gold); }
.request-user-info { display: flex; align-items: center; gap: 14px; }
.request-username { font-family: var(--font-mono); font-size: 14px; }
.request-date { font-size: 11px; color: var(--text-dim); font-family: var(--font-mono); }
.request-actions { display: flex; gap: 8px; }
.btn-cyber { background: rgba(255,255,255,0.04); color: var(--text); border: 1px solid var(--border); padding: 8px 16px; font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 1px; cursor: pointer; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }
.btn-cyber:hover { border-color: var(--gold); color: var(--gold); background: rgba(245,197,66,0.06); }
.btn-cyber.btn-danger { border-color: var(--border-red); color: var(--red); }
.btn-cyber.btn-danger:hover { border-color: var(--red); background: rgba(230,57,70,0.1); }
.empty-state { text-align: center; padding: 80px 20px; border: 1px dashed var(--border); background: rgba(245,197,66,0.02); }
.empty-state i { font-size: 3rem; color: var(--gold); opacity: 0.4; margin-bottom: 16px; }
.empty-state p { font-family: var(--font-mono); font-size: 12px; color: var(--text-dim); margin-bottom: 16px; }
.avatar-large { width: 48px; height: 48px; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 20px; color: var(--red); flex-shrink: 0; }
</style>
}

@Html.AntiForgeryToken()

<div class="requests-page">
    <div class="page-header">
        <h1 class="glitch-text" data-text="REQUESTS">REQUESTS</h1>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-inbox fa-3x"></i>
            <p>No pending friend requests.</p>
            <a href="@Url.Action("Index", "Friends")" class="btn-cyber">Back to Friends</a>
        </div>
    }

    <div class="requests-list">
        @foreach (var req in Model)
        {
            <div class="request-card" data-id="@req.FriendshipId">
                <div class="request-user-info">
                    <div class="avatar-large">@req.Username[0]</div>
                    <div>
                        <div class="request-username">@req.Username</div>
                        <div class="request-date">Sent @req.SentAt.ToString("MMM dd, yyyy")</div>
                    </div>
                </div>
                <div class="request-actions">
                    <button class="btn-cyber accept-request" data-id="@req.FriendshipId">
                        <i class="fas fa-check"></i> Accept
                    </button>
                    <button class="btn-cyber btn-danger reject-request" data-id="@req.FriendshipId">
                        <i class="fas fa-times"></i> Reject
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.accept-request', function() {
            const id = $(this).data('id');
            const card = $(this).closest('.request-card');
            $.post('@Url.Action("AcceptRequest")', { friendshipId: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() }, function(data) {
                if (data.success) {
                    card.fadeOut(300, function() { $(this).remove(); });
                    showToast('Accepted', data.message, 'success');
                } else {
                    showToast('Error', data.message, 'error');
                }
            });
        });

        $(document).on('click', '.reject-request', function() {
            const id = $(this).data('id');
            const card = $(this).closest('.request-card');
            $.post('@Url.Action("RejectRequest")', { friendshipId: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() }, function(data) {
                if (data.success) {
                    card.fadeOut(300, function() { $(this).remove(); });
                    showToast('Rejected', data.message, 'info');
                } else {
                    showToast('Error', data.message, 'error');
                }
            });
        });
    </script>
}
