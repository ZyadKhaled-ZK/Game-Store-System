@model GameStore.PL.Models.Friends.FriendsIndexViewModel
@{
    ViewData["Title"] = "Social";
}

@section Styles {
<style>
:root {
  --sidebar-w: 340px;
}
.friends-app { display: flex; height: calc(100vh - 180px); border: 1px solid var(--border); background: var(--bg2); border-radius: 4px; overflow: hidden; }

/* ── Sidebar ── */
.friends-sidebar { width: var(--sidebar-w); border-right: 1px solid var(--border); display: flex; flex-direction: column; background: linear-gradient(180deg, var(--bg3) 0%, rgba(17,17,24,0.98) 100%); flex-shrink: 0; }
.sidebar-head { padding: 16px 18px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
.sidebar-head h2 { font-family: var(--font-display); font-size: 12px; letter-spacing: 2.5px; margin: 0; color: var(--red); }
.sidebar-head .total-badge { font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); background: rgba(255,255,255,0.03); padding: 3px 12px; border: 1px solid var(--border); border-radius: 2px; }
.sidebar-search { padding: 12px 18px; border-bottom: 1px solid var(--border); }
.sidebar-search input { width: 100%; background: rgba(7,7,9,0.6); border: 1px solid var(--border); color: var(--text); padding: 9px 14px; font-family: var(--font-mono); font-size: 12px; box-sizing:border-box; transition: border-color 0.2s, box-shadow 0.2s; }
.sidebar-search input:focus { border-color: var(--gold); outline: none; box-shadow: 0 0 12px rgba(245,197,66,0.08); }
.sidebar-search input::placeholder { color: var(--text-dim); opacity: 0.5; }
.search-results-sidebar { position: absolute; top: 100%; left: 0; right: 0; background: var(--bg2); border: 1px solid var(--border); border-top: none; z-index: 100; max-height: 280px; overflow-y: auto; box-shadow: 0 12px 40px rgba(0,0,0,0.5); }
.sidebar-scroll { flex: 1; overflow-y: auto; }
.sidebar-scroll::-webkit-scrollbar { width: 4px; }
.sidebar-scroll::-webkit-scrollbar-track { background: transparent; }
.sidebar-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

/* Section collapsible */
.section-toggle { display: flex; align-items: center; gap: 8px; padding: 12px 18px 10px; cursor: pointer; font-family: var(--font-mono); font-size: 9px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 2px; transition: all 0.2s; border-bottom: 1px solid rgba(255,255,255,0.03); user-select: none; }
.section-toggle:hover { color: var(--text); background: rgba(255,255,255,0.02); }
.section-toggle .arrow { font-size: 9px; transition: transform 0.25s; color: var(--text-dim); }
.section-toggle .arrow.open { transform: rotate(90deg); }
.section-toggle .sec-badge { margin-left: auto; background: var(--red); color: #fff; font-size: 8px; padding: 2px 8px; letter-spacing: 0; border-radius: 2px; }
.section-toggle .sec-badge.gold { background: rgba(245,197,66,0.15); color: var(--gold); border: 1px solid rgba(245,197,66,0.2); }
.section-body { overflow: hidden; transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1); }

/* Friend list item */
.fl-item { display: flex; align-items: center; gap: 12px; padding: 10px 18px; cursor: pointer; transition: all 0.18s; border-left: 3px solid transparent; text-decoration: none; color: var(--text); border-bottom: 1px solid rgba(255,255,255,0.02); }
.fl-item:hover { background: rgba(230,57,70,0.04); border-left-color: rgba(230,57,70,0.3); }
.fl-item.active { background: rgba(230,57,70,0.07); border-left-color: var(--red); }
.fl-item:last-child { border-bottom: none; }
.fl-avatar { position: relative; flex-shrink: 0; }
.fl-avatar .av { width: 40px; height: 40px; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 16px; color: var(--red); background: rgba(230,57,70,0.06); transition: border-color 0.2s, box-shadow 0.2s; }
.fl-item.active .fl-avatar .av { border-color: rgba(230,57,70,0.4); box-shadow: 0 0 16px rgba(230,57,70,0.08); }
.fl-avatar .dot { position: absolute; bottom: -1px; right: -1px; width: 12px; height: 12px; border: 2.5px solid var(--bg3); border-radius: 50%; transition: all 0.2s; }
.fl-avatar .dot.online { background: #4ade80; box-shadow: 0 0 8px rgba(74,222,128,0.5); }
.fl-avatar .dot.offline { background: var(--text-dim); }
.fl-info { flex: 1; min-width: 0; }
.fl-name { font-family: var(--font-mono); font-size: 13px; color: var(--text); transition: color 0.2s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.fl-item:hover .fl-name { color: rgba(255,255,255,0.9); }
.fl-preview { font-size: 10px; color: var(--text-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
.fl-meta { flex-shrink: 0; display: flex; align-items: center; gap: 4px; opacity: 0.7; transition: opacity 0.2s; }
.fl-item:hover .fl-meta, .fl-item.active .fl-meta { opacity: 1; }
.fl-time { font-size: 10px; color: var(--text-dim); font-family: var(--font-mono); }
.unread-dot { width: 8px; height: 8px; background: var(--cyan); border-radius: 50%; flex-shrink: 0; box-shadow: 0 0 6px rgba(0,229,255,0.4); }

/* Request list item */
.rl-item { display: flex; align-items: center; gap: 12px; padding: 10px 18px 10px 22px; border-bottom: 1px solid rgba(255,255,255,0.025); transition: background 0.15s; }
.rl-item:hover { background: rgba(245,197,66,0.02); }
.rl-item .av { width: 32px; height: 32px; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 12px; color: var(--gold); background: rgba(245,197,66,0.05); flex-shrink: 0; }
.rl-item .info { flex: 1; min-width: 0; }
.rl-item .info .name { font-family: var(--font-mono); font-size: 12px; }
.rl-item .info .date { font-size: 9px; color: var(--text-dim); margin-top: 2px; }
.rl-item .acts { display: flex; gap: 4px; flex-shrink: 0; }

/* Suggestion list item */
.sl-item { display: flex; align-items: center; gap: 12px; padding: 10px 18px 10px 22px; transition: background 0.15s; border-bottom: 1px solid rgba(255,255,255,0.015); }
.sl-item:hover { background: rgba(230,57,70,0.025); }
.sl-item:last-child { border-bottom: none; }
.sl-item .av { width: 32px; height: 32px; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 12px; color: var(--red); background: rgba(230,57,70,0.05); flex-shrink: 0; }
.sl-item .info { flex: 1; min-width: 0; }
.sl-item .info .name { font-family: var(--font-mono); font-size: 12px; color: var(--text); transition: color 0.2s; text-decoration: none; }
.sl-item .info .name:hover { color: var(--red); }

/* Mini cyber buttons for sidebar */
.btn-mini { width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.02); border: 1px solid var(--border); color: var(--text-dim); cursor: pointer; transition: all 0.18s; font-size: 10px; text-decoration: none; border-radius: 3px; }
.btn-mini:hover { background: rgba(255,255,255,0.04); transform: translateY(-1px); }
.btn-mini:active { transform: translateY(0); }
.btn-mini[title="View Profile"]:hover { border-color: var(--gold); color: var(--gold); box-shadow: 0 0 10px rgba(245,197,66,0.08); }
.btn-mini.danger:hover { border-color: var(--red); color: var(--red); background: rgba(230,57,70,0.08); box-shadow: 0 0 10px rgba(230,57,70,0.1); }
.btn-mini.add:hover { border-color: #4ade80; color: #4ade80; background: rgba(74,222,128,0.06); }
.btn-mini.chat-open:hover { border-color: var(--cyan); color: var(--cyan); background: rgba(0,229,255,0.06); box-shadow: 0 0 10px rgba(0,229,255,0.08); }

/* Empty sidebar area */
.sidebar-empty { padding: 48px 24px; text-align: center; font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); }
.sidebar-empty i { font-size: 2.2rem; opacity: 0.15; margin-bottom: 12px; display: block; color: var(--red); }

/* ── Main Chat Area ── */
.chat-main { flex: 1; display: flex; flex-direction: column; min-width: 0; background: var(--bg2); }
.chat-header { padding: 16px 22px; border-bottom: 1px solid var(--border); background: linear-gradient(180deg, rgba(17,17,24,0.95) 0%, var(--bg3) 100%); display: flex; align-items: center; gap: 14px; flex-shrink: 0; }
.chat-header .av { width: 40px; height: 40px; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 16px; color: var(--red); background: rgba(230,57,70,0.06); flex-shrink: 0; }
.chat-header .info { flex: 1; }
.chat-header .info .name { font-family: var(--font-mono); font-size: 14px; font-weight: 600; }
.chat-header .info .status { font-size: 11px; font-family: var(--font-mono); display: flex; align-items: center; gap: 5px; margin-top: 2px; }
.chat-header .info .status .ind { display: inline-block; width: 8px; height: 8px; border-radius: 50%; }
.chat-header .info .status .ind.online { background: #4ade80; box-shadow: 0 0 8px rgba(74,222,128,0.5); }
.chat-header .info .status .ind.offline { background: var(--text-dim); }
.chat-messages { flex: 1; overflow-y: auto; padding: 24px 22px; display: flex; flex-direction: column; gap: 12px; background: radial-gradient(ellipse at 50% 0%, rgba(230,57,70,0.02) 0%, transparent 70%); }
.chat-messages::-webkit-scrollbar { width: 5px; }
.chat-messages::-webkit-scrollbar-track { background: transparent; }
.chat-messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
.msg { display: flex; animation: msgSlide 0.25s cubic-bezier(0.4, 0, 0.2, 1); }
@@keyframes msgSlide { from { opacity: 0; transform: translateY(10px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
.msg.mine { justify-content: flex-end; }
.msg.theirs { justify-content: flex-start; }
.msg .bubble { max-width: 70%; padding: 12px 18px; background: rgba(255,255,255,0.03); border: 1px solid var(--border); position: relative; transition: border-color 0.2s, box-shadow 0.2s; border-radius: 4px; }
.msg .bubble:hover { border-color: rgba(245,197,66,0.25); box-shadow: 0 0 16px rgba(245,197,66,0.03); }
.msg.mine .bubble { background: linear-gradient(135deg, rgba(230,57,70,0.1), rgba(230,57,70,0.04)); border-color: var(--border-red); }
.msg.mine .bubble:hover { border-color: var(--red); box-shadow: 0 0 18px rgba(230,57,70,0.08); }
.msg .bubble .text { font-size: 13px; font-family: var(--font-mono); word-break: break-word; line-height: 1.6; color: var(--text); }
.msg .bubble .meta { display: flex; align-items: center; gap: 8px; margin-top: 6px; }
.msg .bubble .time { font-size: 9px; color: var(--text-dim); font-family: var(--font-mono); letter-spacing: 0.3px; }
.msg .bubble .receipt { font-size: 10px; transition: color 0.3s, opacity 0.3s; display: inline-flex; align-items: center; }
.msg .bubble .receipt.sending { color: var(--text-dim); opacity: 0.5; }
.msg .bubble .receipt.sent { color: var(--text-dim); opacity: 0.7; }
.msg .bubble .receipt.read { color: var(--cyan); opacity: 1; }
.msg .bubble .receipt.error { color: var(--red); opacity: 1; }
.chat-input-area { padding: 16px 22px; border-top: 1px solid var(--border); background: linear-gradient(0deg, rgba(17,17,24,0.95) 0%, var(--bg3) 100%); flex-shrink: 0; }
.chat-typing { padding: 4px 0 8px; font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); font-style: italic; min-height: 0; }
.chat-form { display: flex; gap: 8px; }
.chat-form input { flex: 1; background: rgba(7,7,9,0.6); border: 1px solid var(--border); color: var(--text); padding: 10px 14px; font-family: var(--font-mono); font-size: 12px; transition: border-color 0.2s; border-radius: 3px; }
.chat-form input:focus { border-color: var(--red); outline: none; box-shadow: 0 0 12px rgba(230,57,70,0.06); }
.chat-form .btn-send { padding: 10px 20px; background: rgba(230,57,70,0.08); border: 1px solid var(--border-red); color: var(--red); cursor: pointer; font-size: 14px; transition: all 0.2s; display: flex; align-items: center; border-radius: 3px; }
.chat-form .btn-send:hover { background: rgba(230,57,70,0.18); box-shadow: 0 0 16px rgba(230,57,70,0.12); transform: translateY(-1px); }
.chat-form .btn-send:active { transform: translateY(0); }

/* Empty chat state */
.chat-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--text-dim); font-family: var(--font-mono); text-align: center; padding: 48px; }
.chat-empty i { opacity: 0.12; margin-bottom: 16px; color: var(--red); font-size: 3rem; }
.chat-empty h3 { font-family: var(--font-display); font-size: 14px; letter-spacing: 2.5px; color: var(--text); margin: 0 0 8px; }
.chat-empty p { font-size: 11px; margin: 0; opacity: 0.6; }

/* Responsive */
@@media (max-width: 768px) {
  .friends-sidebar { width: 100%; }
  .chat-main { display: none; }
  .chat-main.show { display: flex; }
}
</style>
}

@Html.AntiForgeryToken()

<div class="friends-app" id="friendsApp">
  @* ── Sidebar ── *@
  <div class="friends-sidebar" id="friendsSidebar">
    <div class="sidebar-head">
      <h2><i class="fas fa-user-friends" style="margin-right:6px;font-size:12px;"></i> SOCIAL</h2>
      <span class="total-badge">@Model.Friends.Count friends</span>
    </div>
    <div class="sidebar-search" style="position:relative;">
      <input type="text" id="sidebarSearch" placeholder="Search users..." autocomplete="off" />
      <div id="sidebarSearchResults" class="search-results-sidebar" style="display:none;"></div>
    </div>
    <div class="sidebar-scroll">
      @* Pending Requests *@
      @if (Model.PendingRequests.Any())
      {
      <div class="section-toggle" data-target="pendingSection">
        <span class="arrow open">&rsaquo;</span>
        <span>Pending Requests</span>
        <span class="sec-badge">@Model.PendingRequests.Count</span>
      </div>
      <div class="section-body" id="pendingSection">
        @foreach (var req in Model.PendingRequests)
        {
        <div class="rl-item" data-id="@req.FriendshipId">
          <div class="av">@if (!string.IsNullOrEmpty(req.Avatar)) {<img src="@req.Avatar" style="width:30px;height:30px;object-fit:cover;" />} else {@req.Username[0]}</div>
          <div class="info">
            <div class="name">@req.Username</div>
            <div class="date">@req.SentAt.ToString("MMM dd")</div>
          </div>
          <div class="acts">
            <button class="btn-mini accept-request" data-id="@req.FriendshipId" title="Accept"><i class="fas fa-check"></i></button>
            <button class="btn-mini danger reject-request" data-id="@req.FriendshipId" title="Reject"><i class="fas fa-times"></i></button>
          </div>
        </div>
        }
      </div>
      }

      @* Suggestions *@
      @if (Model.Suggestions.Any())
      {
      <div class="section-toggle" data-target="suggestSection">
        <span class="arrow open">&rsaquo;</span>
        <span>Suggestions</span>
        <span class="sec-badge gold">@Model.Suggestions.Count</span>
      </div>
      <div class="section-body" id="suggestSection">
        @foreach (var sug in Model.Suggestions)
        {
        <div class="sl-item" data-userid="@sug.UserId" data-online="@(sug.IsOnline ? "true" : "false")">
          <div class="fl-avatar" style="flex-shrink:0;">
            <div class="av" style="width:30px;height:30px;">@if (!string.IsNullOrEmpty(sug.Avatar)) {<img src="@sug.Avatar" style="width:30px;height:30px;object-fit:cover;" />} else {@sug.Username[0]}</div>
            <span class="dot @(sug.IsOnline ? "online" : "offline")"></span>
          </div>
          <div class="info">
            <a href="@Url.Action("Index", "Profile", new { username = sug.Username })" style="color:inherit;text-decoration:none;" class="name">@sug.Username</a>
            <div class="fl-preview" style="font-size:10px;color:var(--text-dim);">@sug.MutualGamesCount @(sug.MutualGamesCount == 1 ? "mutual game" : "mutual games")</div>
          </div>
          <a href="@Url.Action("Index", "Profile", new { username = sug.Username })" class="btn-mini" title="View Profile"><i class="fas fa-user"></i></a>
          <button class="btn-mini add add-suggestion" data-username="@sug.Username" title="Add Friend"><i class="fas fa-user-plus"></i></button>
        </div>
        }
      </div>
      }

      @* Friends list *@
      <div class="section-toggle" data-target="friendsSection" style="border-top:1px solid var(--border);">
        <span class="arrow open">&rsaquo;</span>
        <span>Friends — <span id="onlineCount">@Model.Friends.Count(f => f.IsOnline)</span> online</span>
      </div>
      <div class="section-body" id="friendsSection">
        @if (!Model.Friends.Any())
        {
        <div class="sidebar-empty">
          <i class="fas fa-user-friends"></i>
          <p>No friends yet. Search for users above!</p>
        </div>
        }
        @foreach (var friend in Model.Friends)
        {
        <div class="fl-item friend-entry" data-userid="@friend.UserId" data-username="@friend.Username" data-friendshipid="@friend.FriendshipId" data-online="@(friend.IsOnline ? "true" : "false")">
          <div class="fl-avatar">
            <div class="av">@if (!string.IsNullOrEmpty(friend.Avatar)) {<img src="@friend.Avatar" style="width:38px;height:38px;object-fit:cover;display:block;" />} else {@friend.Username[0]}</div>
            <span class="dot @(friend.IsOnline ? "online" : "offline")"></span>
          </div>
          <div class="fl-info">
            <div class="fl-name">@friend.Username</div>
            <div class="fl-preview">@(friend.IsOnline ? "Online" : "Offline")</div>
          </div>
          <div class="fl-meta">
            <a href="@Url.Action("Index", "Profile", new { username = friend.Username })" class="btn-mini" title="View Profile"><i class="fas fa-user"></i></a>
            <button class="btn-mini chat-open open-chat" data-userid="@friend.UserId" data-username="@friend.Username" title="Chat"><i class="fas fa-comment"></i></button>
            <button class="btn-mini danger remove-friend" data-id="@friend.FriendshipId" title="Remove"><i class="fas fa-user-minus"></i></button>
          </div>
        </div>
        }
      </div>
    </div>
  </div>

  @* ── Main Chat Area ── *@
  <div class="chat-main" id="chatMain">
    <div class="chat-empty" id="chatEmptyState">
      <i class="fas fa-comments fa-4x"></i>
      <h3>Select a friend</h3>
      <p>Choose someone from the sidebar to start chatting</p>
    </div>

    <div id="chatActiveArea" style="display:none;flex-direction:column;height:100%;">
      <div class="chat-header">
        <div class="av" id="chatActiveAvatar">?</div>
        <div class="info">
          <div class="name" id="chatActiveName">—</div>
          <div class="status" id="chatActiveStatus">
            <span class="ind offline" id="chatActiveIndicator"></span>
            <span id="chatActiveStatusText">Offline</span>
          </div>
        </div>
      </div>
      <div class="chat-messages" id="chatMessages">
        <div class="chat-empty" style="padding:30px;">
          <i class="fas fa-comments fa-2x"></i>
          <p>Start chatting!</p>
        </div>
      </div>
      <div class="chat-input-area">
        <div class="chat-typing" id="chatTypingIndicator" style="display:none;">typing...</div>
        <form class="chat-form" id="chatForm">
          <input type="text" id="chatInput" placeholder="Type a message..." autocomplete="off" />
          <button type="submit" class="btn-send" title="Send"><i class="fas fa-paper-plane"></i></button>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
  // ── State ──
  let activeUserId = null;
  let activeUsername = null;
  const currentUserId = '@Context.Session.GetString("UserId")';
  let msgCounter = 0;
  let pendingMessages = [];

  // ── Section Toggle ──
  document.querySelectorAll('.section-toggle').forEach(function(toggle) {
    toggle.addEventListener('click', function() {
      const target = document.getElementById(this.dataset.target);
      const arrow = this.querySelector('.arrow');
      if (!target) return;
      const isOpen = target.style.maxHeight !== '0px' && target.style.maxHeight !== '';
      if (isOpen) {
        target.style.maxHeight = '0px';
        if (arrow) arrow.classList.remove('open');
      } else {
        target.style.maxHeight = target.scrollHeight + 'px';
        if (arrow) arrow.classList.add('open');
      }
    });
    const target = document.getElementById(toggle.dataset.target);
    if (target) { target.style.maxHeight = target.scrollHeight + 'px'; }
  });

  // ── Search ──
  let searchTimer;
  $('#sidebarSearch').on('input', function() {
    clearTimeout(searchTimer);
    const q = $(this).val().trim();
    if (q.length < 2) { $('#sidebarSearchResults').hide(); return; }
    searchTimer = setTimeout(() => {
      $.get('@Url.Action("Search")', { q }, function(data) {
        const results = data.results;
        if (results.length === 0) {
          $('#sidebarSearchResults').html('<div style="padding:14px;text-align:center;font-family:var(--font-mono);font-size:11px;color:var(--text-dim);">No users found</div>').show();
          return;
        }
        let html = '';
        results.forEach(function(u) {
          var eu = escapeHtml(u.username);
          var avHtml = u.avatar ? '<img src="' + u.avatar + '" style="width:38px;height:38px;object-fit:cover;display:block;" />' : eu[0];
          html += '<div class="fl-item" style="cursor:default;">' +
                    '<div class="fl-avatar"><div class="av">' + avHtml + '</div><span class="dot offline"></span></div>' +
                    '<div class="fl-info"><a href="/Profile/Index?username=' + encodeURIComponent(u.username) + '" style="color:inherit;text-decoration:none;" class="fl-name">' + eu + '</a></div>' +
                    '<a href="/Profile/Index?username=' + encodeURIComponent(u.username) + '" class="btn-mini" title="View Profile"><i class="fas fa-user"></i></a>' +
                    '<button class="btn-mini add add-search-friend" data-username="' + eu + '" title="Add"><i class="fas fa-user-plus"></i></button>' +
                  '</div>';
        });
        $('#sidebarSearchResults').html(html).show();
      });
    }, 300);
  });
  $(document).on('click', function(e) {
    if (!$(e.target).closest('.sidebar-search').length) $('#sidebarSearchResults').hide();
  });

  // ── Add friend (search + suggestions) ──
  $(document).on('click', '.add-search-friend, .add-suggestion', function() {
    const username = $(this).data('username');
    const btn = $(this);
    btn.prop('disabled', true).html('<i class="fas fa-spinner fa-pulse" style="font-size:10px;"></i>');
    $.post('@Url.Action("SendRequest")', {
      username,
      __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
    }, function(data) {
      if (data.success) {
        showToast('Friend request sent to ' + username, 'success');
        btn.closest('.sl-item, .fl-item').fadeOut(200);
      } else {
        showToast(data.message, 'error');
      }
    }).fail(() => showToast('Failed to send request', 'error'))
    .always(() => { if (btn.closest('.sl-item, .fl-item').length) btn.prop('disabled', false).html('<i class="fas fa-user-plus"></i>'); });
  });

  // ── Accept / Reject requests ──
  $(document).on('click', '.accept-request', function() {
    const id = $(this).data('id');
    const item = $(this).closest('.rl-item');
    $.post('@Url.Action("AcceptRequest")', {
      friendshipId: id,
      __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
    }, function(data) {
      if (data.success) {
        item.fadeOut(200, function() { $(this).remove(); });
        showToast(data.message, 'success');
        location.reload();
      } else showToast(data.message, 'error');
    });
  });
  $(document).on('click', '.reject-request', function() {
    const id = $(this).data('id');
    const item = $(this).closest('.rl-item');
    $.post('@Url.Action("RejectRequest")', {
      friendshipId: id,
      __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
    }, function(data) {
      if (data.success) {
        item.fadeOut(200, function() { $(this).remove(); });
        showToast(data.message, 'info');
      } else showToast(data.message, 'error');
    });
  });

  // ── Remove friend ──
  $(document).on('click', '.remove-friend', function() {
    if (!confirm('Remove this friend?')) return;
    const id = $(this).data('id');
    const entry = $(this).closest('.friend-entry');
    $.post('@Url.Action("RemoveFriend")', {
      friendshipId: id,
      __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
    }, function(data) {
      if (data.success) {
        entry.fadeOut(200, function() { $(this).remove(); });
        showToast(data.message, 'info');
        if ($('.friend-entry').length === 0) location.reload();
      } else showToast(data.message, 'error');
    });
  });

  // ── Open Chat ──
  function openChat(userId, username) {
    if (activeUserId === userId) return;
    activeUserId = userId;
    activeUsername = username;

    $('#chatEmptyState').hide();
    $('#chatActiveArea').css('display', 'flex');
    $('#chatActiveAvatar').text(username[0] || '?');
    $('#chatActiveName').text(username);

    // Read online status from sidebar entry (friend or suggestion)
    var entry = $('.friend-entry[data-userid="' + userId + '"]');
    if (!entry.length) entry = $('.sl-item[data-userid="' + userId + '"]');
    var isOnline = entry.length ? entry.data('online') === 'true' : false;
    $('#chatActiveIndicator').attr('class', 'ind ' + (isOnline ? 'online' : 'offline'));
    $('#chatActiveStatusText').text(isOnline ? 'Online' : 'Offline');

    $('#chatMessages').html('<div style="flex:1;display:flex;align-items:center;justify-content:center;color:var(--text-dim);padding:40px;"><i class="fas fa-spinner fa-pulse fa-2x"></i></div>');
    $('#chatTypingIndicator').hide();
    $('#chatForm')[0]?.reset();

    // Mark active in sidebar
    $('.friend-entry').removeClass('active');
    entry.addClass('active');

    loadMessages(userId);
  }

  function loadMessages(userId) {
    $.get('@Url.Action("GetMessages", "Chat")', { userId, page: 1 }, function(data) {
      const msgs = data.messages || [];
      const area = $('#chatMessages');
      area.empty();
      if (msgs.length === 0) {
        area.html('<div class="chat-empty" style="padding:30px;"><i class="fas fa-comments fa-2x"></i><p>Start chatting with ' + activeUsername + '!</p></div>');
      } else {
        msgs.forEach(function(m) { area.append(renderMsg(m)); });
      }
      scrollChat();
      if (window.chatConnection && window.chatConnection.state === 'Connected') {
        window.chatConnection.invoke('MarkRead', userId);
      }
    });
  }

  function renderMsg(m) {
    const isMine = m.senderId === currentUserId;
    const time = new Date(m.sentAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    let receiptHtml = '';
    if (isMine) {
      const status = m.msgStatus || (m.readAt ? 'read' : 'sent');
      if (status === 'sending') receiptHtml = '<span class="receipt sending"><i class="fas fa-clock"></i></span>';
      else if (status === 'sent') receiptHtml = '<span class="receipt sent"><i class="fas fa-check"></i></span>';
      else if (status === 'read') receiptHtml = '<span class="receipt read"><i class="fas fa-check-double"></i></span>';
      else if (status === 'error') receiptHtml = '<span class="receipt error"><i class="fas fa-exclamation-circle"></i></span>';
    }
    return '<div class="msg ' + (isMine ? 'mine' : 'theirs') + '" data-id="' + m.id + '">' +
      '<div class="bubble">' +
        '<div class="text">' + escapeHtml(m.content) + '</div>' +
        '<div class="meta">' +
          '<span class="time">' + time + '</span>' +
          receiptHtml +
        '</div>' +
      '</div>' +
    '</div>';
  }

  function appendMsg(msg) {
    const area = $('#chatMessages');
    area.find('.chat-empty').remove();
    area.append(renderMsg(msg));
    scrollChat();
  }

  function scrollChat() {
    const el = document.getElementById('chatMessages');
    if (el) el.scrollTop = el.scrollHeight;
  }

  function escapeHtml(text) {
    const d = document.createElement('div');
    d.textContent = text;
    return d.innerHTML;
  }

  // Sidebar friend click → open chat
  $(document).on('click', '.friend-entry', function(e) {
    if ($(e.target).closest('button').length) return;
    const userId = $(this).data('userid');
    const username = $(this).data('username');
    openChat(userId, username);
  });

  $(document).on('click', '.open-chat', function(e) {
    e.stopPropagation();
    openChat($(this).data('userid'), $(this).data('username'));
  });

  // ── Send message (optimistic UI) ──
  $('#chatForm').on('submit', function(e) {
    e.preventDefault();
    const input = $('#chatInput');
    const content = input.val().trim();
    if (!content || !activeUserId) return;

    const tempId = 'snd-' + (++msgCounter);
    pendingMessages.push(tempId);
    const now = new Date().toISOString();

    // Show instantly
    $('#chatMessages').find('.chat-empty').remove();
    $('#chatMessages').append(renderMsg({ id: tempId, senderId: currentUserId, content, sentAt: now, msgStatus: 'sending' }));
    scrollChat();
    input.val('');
    $('#chatTypingIndicator').hide();

    if (window.chatConnection && window.chatConnection.state === 'Connected') {
      window.chatConnection.invoke('SendMessage', activeUserId, content).catch(function(err) {
        // Mark as error
        $('.msg[data-id="' + tempId + '"] .receipt').attr('class', 'receipt error').html('<i class="fas fa-exclamation-circle"></i>');
        console.error('Send fail:', err);
      });
    } else {
      $('.msg[data-id="' + tempId + '"] .receipt').attr('class', 'receipt error').html('<i class="fas fa-exclamation-circle"></i>');
    }
  });

  // ── Typing indicator ──
  let typingTimer;
  $('#chatInput').on('input', function() {
    if (!window.chatConnection || !activeUserId) return;
    window.chatConnection.invoke('Typing', activeUserId, true);
    clearTimeout(typingTimer);
    typingTimer = setTimeout(function() {
      if (window.chatConnection) window.chatConnection.invoke('Typing', activeUserId, false);
    }, 2000);
  });

  // ── SignalR handlers (register directly, not waiting for event) ──
  function setupChatHandlers(conn) {
    if (!conn) return;

    conn.on('ReceiveMessage', function(msg) {
      if (msg.senderId === activeUserId) {
        appendMsg(msg);
        if (window.chatConnection) window.chatConnection.invoke('MarkRead', msg.senderId);
      }
    });

    conn.on('MessageSent', function(msg) {
      if (msg.receiverId === activeUserId) {
        var tempId = pendingMessages.shift();
        if (tempId) {
          var el = $('.msg[data-id="' + tempId + '"]');
          if (el.length) {
            el.attr('data-id', msg.id);
            el.find('.receipt').attr('class', 'receipt sent').html('<i class="fas fa-check"></i>');
          }
        }
      }
    });

    conn.on('MessagesRead', function(data) {
      if (data.byUserId === activeUserId) {
        $('#chatMessages .msg.mine .receipt')
          .attr('class', 'receipt read')
          .html('<i class="fas fa-check-double"></i>');
      }
    });

    conn.on('UserTyping', function(data) {
      if (data.userId === activeUserId) {
        $('#chatTypingIndicator').css('display', data.isTyping ? 'block' : 'none');
      }
    });

    function updateOnlineDot(userId, isOnline) {
      var cls = isOnline ? 'dot online' : 'dot offline';
      $('.friend-entry[data-userid="' + userId + '"]').find('.dot').attr('class', cls);
      $('.sl-item[data-userid="' + userId + '"]').find('.dot').attr('class', cls);
      if (userId === activeUserId) {
        $('#chatActiveIndicator').attr('class', 'ind ' + (isOnline ? 'online' : 'offline'));
        $('#chatActiveStatusText').text(isOnline ? 'Online' : 'Offline');
      }
    }

    conn.on('UserOnline', function(data) {
      updateOnlineDot(data.userId, true);
    });

    conn.on('UserOffline', function(data) {
      updateOnlineDot(data.userId, false);
    });
  }

  if (window.chatConnection) {
    setupChatHandlers(window.chatConnection);
  } else {
    document.addEventListener('chatConnectionReady', function() { setupChatHandlers(window.chatConnection); });
  }

  // Auto-open chat from profile quick-chat link
  var chatUserId = '@ViewBag.ChatUserId';
  if (chatUserId) {
    var entry = $('.friend-entry[data-userid="' + chatUserId + '"]');
    var name = entry.data('username');
    if (name) {
      openChat(chatUserId, name);
    } else {
      // Not a friend? Load anyway via a one-time lookup
      $.get('@Url.Action("Search")', { q: '' }).then(function() {
        openChat(chatUserId, chatUserId);
      });
    }
  }

  // Responsive: on mobile, show sidebar
  $(window).on('resize', function() {
    if ($(window).width() <= 768 && activeUserId) {
      // Could add a back button to sidebar
    }
  });
</script>
}
