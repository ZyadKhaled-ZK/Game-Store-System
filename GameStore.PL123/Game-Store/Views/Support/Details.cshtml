@model SupportTicket
@{
    ViewData["Title"] = "Ticket - " + Model.Subject;
    var userId = Context.Session.GetString("UserId");
    var isOwn = Model.UserId == userId;
}

<style>
    .td-container { max-width:700px; margin:0 auto; }
    .td-header { background:var(--bg2); border:1px solid var(--border); padding:24px; margin-bottom:20px; }
    .td-subject { font-family:var(--font-display); font-size:16px; letter-spacing:2px; color:var(--text); }
    .td-meta { font-family:var(--font-mono); font-size:10px; color:var(--text-dim); margin-top:8px; }
    .td-message { font-family:var(--font-mono); font-size:13px; color:var(--text); line-height:1.7; margin-top:16px; padding:16px; background:var(--bg3); border:1px solid rgba(255,255,255,0.04); }
    .td-reply { display:flex; gap:12px; padding:16px; margin-bottom:8px; background:var(--bg2); border:1px solid var(--border); }
    .td-reply-av { width:32px; height:32px; border:1px solid var(--border); display:flex; align-items:center; justify-content:center; font-family:var(--font-display); font-size:13px; flex-shrink:0; }
    .td-reply-body { flex:1; min-width:0; }
    .td-reply-name { font-family:var(--font-mono); font-size:11px; color:var(--cyan); }
    .td-reply-time { font-family:var(--font-mono); font-size:9px; color:var(--text-dim); margin-left:8px; }
    .td-reply-text { font-family:var(--font-mono); font-size:12px; color:var(--text); line-height:1.6; margin-top:4px; }
</style>

<div class="td-container mt-4 pt-4">

    @* Back link *@
    <a href="/Support/MyTickets" style="display:inline-flex;align-items:center;gap:6px;font-family:var(--font-mono);font-size:11px;color:var(--text-dim);text-decoration:none;margin-bottom:16px;transition:0.2s;"
       onmouseover="this.style.color='var(--cyan)'" onmouseout="this.style.color='var(--text-dim)'"><i class="fas fa-arrow-left"></i> BACK TO TICKETS</a>

    @* Header *@
    <div class="td-header">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;">
            <div>
                <div class="td-subject">@Model.Subject</div>
                <div class="td-meta">
                    Opened @Model.CreatedAt.ToString("MMM dd, yyyy  ·  HH:mm")
                    @if (Model.User != null)
                    {
                        <span> by @Model.User.Username</span>
                    }
                </div>
            </div>
            <div>
                @switch (Model.Status)
                {
                    case TicketStatus.Open:
                        <span style="color:var(--gold);font-family:var(--font-mono);font-size:10px;border:1px solid var(--gold);padding:3px 10px;">OPEN</span>
                        break;
                    case TicketStatus.InProgress:
                        <span style="color:var(--cyan);font-family:var(--font-mono);font-size:10px;border:1px solid var(--cyan);padding:3px 10px;">IN PROGRESS</span>
                        break;
                    case TicketStatus.Resolved:
                        <span style="color:#4ade80;font-family:var(--font-mono);font-size:10px;border:1px solid #4ade80;padding:3px 10px;">RESOLVED</span>
                        break;
                    case TicketStatus.Closed:
                        <span style="color:var(--text-dim);font-family:var(--font-mono);font-size:10px;border:1px solid rgba(255,255,255,0.08);padding:3px 10px;">CLOSED</span>
                        break;
                }
            </div>
        </div>

        <div class="td-message">@Model.Message</div>
    </div>

    @* Replies *@
    @if (Model.Replies.Any())
    {
        <div style="margin-bottom:20px;">
            @foreach (var reply in Model.Replies)
            {
                var isAdmin = reply.User?.Role == Role.ADMIN;
                <div class="td-reply" style="@(isAdmin ? "border-color:var(--gold);background:rgba(245,197,66,0.02);" : "")">
                    <div class="td-reply-av" style="@(isAdmin ? "border-color:var(--gold);color:var(--gold);" : "color:var(--cyan);")">
                        @if (reply.User != null && !string.IsNullOrEmpty(reply.User.AvatarUrl))
                        {
                            <img src="@reply.User.AvatarUrl" alt="" style="width:100%;height:100%;object-fit:cover;" />
                        }
                        else if (reply.User != null)
                        {
                            @reply.User.Username[0]
                        }
                        else
                        {
                            <i class="fas fa-user" style="font-size:12px;"></i>
                        }
                    </div>
                    <div class="td-reply-body">
                        <div>
                            <span class="td-reply-name" style="@(isAdmin ? "color:var(--gold);" : "")">@(reply.User?.Username ?? "Support Team")</span>
                            @if (isAdmin)
                            {
                                <span style="font-size:8px;color:var(--gold);border:1px solid var(--gold);padding:1px 5px;margin-left:4px;">STAFF</span>
                            }
                            <span class="td-reply-time">@reply.CreatedAt.ToString("MMM dd, yyyy  ·  HH:mm")</span>
                        </div>
                        <div class="td-reply-text">@reply.Message</div>
                    </div>
                </div>
            }
        </div>
    }

    @* Reply form *@
    @if (isOwn && Model.Status != TicketStatus.Closed)
    {
        <div style="background:var(--bg2);border:1px solid var(--border);padding:20px;">
            <div style="font-family:var(--font-mono);font-size:11px;color:var(--cyan);margin-bottom:12px;"><i class="fas fa-reply"></i> ADD REPLY</div>
            <form method="post" asp-action="Reply" asp-route-id="@Model.Id" id="replyForm">
                @Html.AntiForgeryToken()
                <textarea name="message" rows="3" maxlength="2000" placeholder="Type your reply..." style="width:100%;background:var(--bg3);border:1px solid rgba(255,255,255,0.06);color:var(--text);font-family:var(--font-mono);font-size:13px;padding:12px;resize:none;outline:none;transition:border 0.2s;" onfocus="this.style.borderColor='rgba(0,229,255,0.3)'" onblur="this.style.borderColor='rgba(255,255,255,0.06)'"></textarea>
                <div style="display:flex;justify-content:flex-end;margin-top:10px;">
                    <button type="submit" class="btn btn-primary" id="replySubmitBtn" style="padding:8px 20px;font-size:11px;">SEND REPLY</button>
                </div>
            </form>
        </div>
    }
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        $('#replyForm').on('submit', function(e) {
            e.preventDefault();
            var btn = $('#replySubmitBtn');
            var msg = $(this).find('textarea[name="message"]').val().trim();
            if (!msg) return;

            btn.prop('disabled', true).text('SENDING...');
            $.post('@Url.Action("Reply", "Support", new { id = Model.Id })', {
                message: msg,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            }, function(data) {
                if (data.success) {
                    var adminTag = '@(Model.UserId == userId ? "" : "")';
                    var html = '<div class="td-reply" style="border-color:var(--gold);background:rgba(245,197,66,0.02);">' +
                        '<div class="td-reply-av" style="border-color:var(--gold);color:var(--gold);">@Model.User?.Username?[0]</div>' +
                        '<div class="td-reply-body">' +
                            '<div><span class="td-reply-name" style="color:var(--gold);">@Model.User?.Username</span><span class="td-reply-time">' + data.createdAt + '</span></div>' +
                            '<div class="td-reply-text">' + $('<div>').text(msg).html() + '</div>' +
                        '</div></div>';
                    $('.td-reply').last().after(html);
                    $(this).find('textarea[name="message"]').val('');
                    showToast('Reply sent!', 'success');
                    btn.prop('disabled', false).text('SEND REPLY');
                } else {
                    showToast(data.message, 'error');
                    btn.prop('disabled', false).text('SEND REPLY');
                }
            }.bind(this)).fail(function() { showToast('Failed to send reply', 'error'); btn.prop('disabled', false).text('SEND REPLY'); });
        });
    </script>
}
