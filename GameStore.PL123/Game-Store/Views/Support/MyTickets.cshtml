@model List<SupportTicket>
@{
    ViewData["Title"] = "My Tickets";
    var page = (int)ViewData["Page"];
    var totalPages = (int)ViewData["TotalPages"];
}

<style>
    .tk-container { max-width:800px; margin:0 auto; }
    .tk-row { display:flex; align-items:center; padding:16px 20px; background:var(--bg2); border:1px solid var(--border); text-decoration:none; transition:0.2s; margin-bottom:8px; }
    .tk-row:hover { border-color:var(--cyan); transform:translateX(4px); }
    .tk-subject { flex:1; font-family:var(--font-mono); font-size:13px; color:var(--text); }
    .tk-date { font-family:var(--font-mono); font-size:10px; color:var(--text-dim); margin:0 16px; white-space:nowrap; }
    .tk-replies { font-family:var(--font-mono); font-size:10px; color:var(--text-dim); white-space:nowrap; margin-right:12px; }
    @@media (max-width: 768px) {
      .tk-row { padding: 12px 16px; flex-wrap: wrap; gap: 6px; }
      .section-title { font-size: 1.8rem !important; }
    }
    @@media (max-width: 576px) {
      .tk-row { flex-direction: column; padding: 12px; text-align: center; }
      .tk-date { margin: 4px 0; }
      .section-title { font-size: 1.4rem !important; }
      .section-header { flex-direction: column; gap: 12px; }
      .section-header .btn { width: 100%; text-align: center; }
      .tk-container > div[style*="display:flex;justify-content:center"] { flex-wrap: wrap; }
    }
</style>

<div class="tk-container mt-4 pt-4">
    <div class="section-header" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
        <h2 class="section-title glitch">MY TICKETS</h2>
        <a href="/Support" class="btn btn-secondary" style="padding:8px 18px;font-size:11px;text-decoration:none;">+ NEW TICKET</a>
    </div>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:60px;font-family:var(--font-mono);color:var(--text-dim);">
            <i class="fas fa-ticket-alt" style="font-size:2rem;opacity:0.2;display:block;margin-bottom:12px;"></i>
            No tickets yet.
            <div style="margin-top:16px;"><a href="/Support" class="btn btn-primary" style="padding:8px 20px;font-size:12px;">OPEN A TICKET</a></div>
        </div>
    }

    @foreach (var ticket in Model)
    {
        <a href="/Support/Details/@ticket.Id" class="tk-row">
            <div class="tk-subject">@ticket.Subject</div>
            <div class="tk-replies"><i class="fas fa-reply"></i> @ticket.Replies.Count</div>
            <div class="tk-date">@ticket.CreatedAt.ToString("MMM dd, yyyy")</div>
            <div>
                @switch (ticket.Status)
                {
                    case TicketStatus.Open:
                        <span style="color:var(--gold);font-family:var(--font-mono);font-size:10px;border:1px solid var(--gold);padding:2px 8px;">OPEN</span>
                        break;
                    case TicketStatus.InProgress:
                        <span style="color:var(--cyan);font-family:var(--font-mono);font-size:10px;border:1px solid var(--cyan);padding:2px 8px;">IN PROGRESS</span>
                        break;
                    case TicketStatus.Resolved:
                        <span style="color:#4ade80;font-family:var(--font-mono);font-size:10px;border:1px solid #4ade80;padding:2px 8px;">RESOLVED</span>
                        break;
                    case TicketStatus.Closed:
                        <span style="color:var(--text-dim);font-family:var(--font-mono);font-size:10px;border:1px solid rgba(255,255,255,0.08);padding:2px 8px;">CLOSED</span>
                        break;
                }
            </div>
        </a>
    }

    @if (totalPages > 1)
    {
        <div style="display:flex;justify-content:center;gap:8px;margin-top:24px;">
            @for (var i = 1; i <= totalPages; i++)
            {
                <a asp-action="MyTickets" asp-route-page="@i" style="padding:6px 14px;font-family:var(--font-mono);font-size:12px;color:@(i == page ? "var(--red)" : "var(--text-dim)");border:1px solid @(i == page ? "var(--red)" : "rgba(255,255,255,0.08)");text-decoration:none;transition:0.2s;"
                   onmouseover="this.style.borderColor='var(--red)';this.style.color='var(--red)'" onmouseout="this.style.borderColor='@(i == page ? "var(--red)" : "rgba(255,255,255,0.08)")';this.style.color='@(i == page ? "var(--red)" : "var(--text-dim)")'">@i</a>
            }
        </div>
    }
</div>
