@{
    var message = TempData["Message"]?.ToString() ?? ViewData["Message"]?.ToString() ?? "";
    var isError = (TempData["IsError"] as bool?) ?? (ViewData["IsError"] as bool?) ?? false;
}
@if (!string.IsNullOrEmpty(message))
{
    <div class="alert-box @(isError ? "alert-error" : "alert-success")">
        <span>@(isError ? "&#10007;" : "&#10003;") @Html.Raw(message)</span>
        <button type="button" class="alert-close" onclick="this.parentElement.remove();">&times;</button>
    </div>
    <script>(function(){ var e = document.currentScript; if(e && e.previousElementSibling) setTimeout(function(){ var el = e.previousElementSibling; el.style.transition='opacity 0.4s'; el.style.opacity='0'; setTimeout(function(){ el.remove(); }, 400); }, 4000); })();</script>
}
<style>
.alert-box { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; margin-bottom: 16px; font-family: var(--font-mono); font-size: 12px; animation: alertIn 0.3s ease; }
.alert-success { background: rgba(74,222,128,0.1); border: 1px solid #4ade80; color: #4ade80; }
.alert-error { background: rgba(230,57,70,0.1); border: 1px solid var(--red); color: var(--red); }
.alert-close { background: none; border: none; color: inherit; cursor: pointer; font-size: 18px; padding: 0 4px; opacity: 0.7; }
.alert-close:hover { opacity: 1; }
@Html.Raw("@keyframes alertIn { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }")
</style>
