<!DOCTYPE html>
<html lang="en"><!-- TECHNOLOGY: Bootstrap 5, jQuery, SignalR JS, Font Awesome, Google Fonts -->

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Game_Store</title>
    @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
    <meta name="csrf-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
    @await RenderSectionAsync("MetaTags", required: false)
    <meta name="description" content="Game Store - Browse, buy, and play indie games.">
    <meta property="og:url" content="https://game-store.runasp.net/">
    <meta property="og:type" content="website">
    <meta property="og:title" content="Game Store - Game_Store">
    <meta property="og:description" content="Game Store - Browse, buy, and play indie games.">
    <meta property="og:image" content="https://img.lightshot.app/NbGdBstGQImnsigg7JbtpQ.jpeg">
    <meta name="twitter:card" content="summary_large_image">
    <meta property="twitter:domain" content="game-store.runasp.net">
    <meta property="twitter:url" content="https://game-store.runasp.net/">
    <meta name="twitter:title" content="Game Store - Game_Store">
    <meta name="twitter:description" content="Game Store - Browse, buy, and play indie games.">
    <meta name="twitter:image" content="https://img.lightshot.app/NbGdBstGQImnsigg7JbtpQ.jpeg">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;500;700;900&family=Share+Tech+Mono&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha384-nRgPTkuX86pH8yjPJUAFuASXQSSl2/bBUiNV47vSYpKFxHJhbcrGnmlYpYJMeD7a" crossorigin="anonymous" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --gold: #f5c542;
            --gold-dim: #b8922e;
            --red: #e63946;
            --red-dim: #9b1d25;
            --bg: #070709;
            --bg2: #0d0d12;
            --bg3: #111118;
            --border: rgba(245, 197, 66, 0.18);
            --border-red: rgba(230, 57, 70, 0.22);
            --text: #e8e8f0;
            --text-dim: #7a7a99;
            --cyan: #00e5ff;
            --accent: #60a5fa;
            --glow-gold: 0 0 20px rgba(245, 197, 66, 0.4);
            --glow-red: 0 0 20px rgba(230, 57, 70, 0.4);
            --font-display: 'Orbitron', monospace;
            --font-ui: 'Rajdhani', sans-serif;
            --font-mono: 'Share Tech Mono', monospace;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        dl, ol, ul { margin-top: 0; margin-bottom: 0; }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-ui);
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 0, 0, 0.08) 2px,
                    rgba(0, 0, 0, 0.08) 4px);
            pointer-events: none;
            z-index: 9999;
        }

        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 9998;
            opacity: 0.6;
        }

        /* ── Subtle entrance fade ── */
        main { animation: pageIn 0.35s ease; }
        /* ── Focus glow pulse ── */
        input:focus, select:focus, textarea:focus, button:focus-visible, a:focus-visible {
          outline: none;
          box-shadow: 0 0 0 2px #070709, 0 0 14px 2px rgba(230,57,70,0.35);
          transition: box-shadow 0.2s;
        }

        /* ── Button subtle hover lift ── */
        .btn { transition: all 0.25s; position: relative; }
        .btn:hover { transform: translateY(-1px); }
        .btn:active { transform: translateY(0); }
        .btn.loading { pointer-events: none; opacity: 0.7; }
        .btn.loading::after { content: ''; display: inline-block; width: 12px; height: 12px; border: 2px solid transparent; border-top-color: currentColor; border-radius: 50%; animation: spin 0.6s linear infinite; margin-left: 8px; vertical-align: middle; }
        .btn.loading { pointer-events: none; opacity: 0.7; }
        .btn.loading::after { content: ''; display: inline-block; width: 12px; height: 12px; border: 2px solid transparent; border-top-color: currentColor; border-radius: 50%; animation: spin 0.6s linear infinite; margin-left: 8px; vertical-align: middle; }
        /* ── Card hover lift ── */
        .game-card, .wishlist-card, .hero-card { transition: all 0.3s; }
        .game-card:hover, .wishlist-card:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(0,0,0,0.4), var(--glow-red); }

        .star-rating { display: inline-flex; flex-direction: row-reverse; gap: 4px; }
        .star-rating input { display: none; }
        .star-rating label { font-size: 1.8rem; color: var(--text-dim); cursor: pointer; transition: color 0.2s; }
        .star-rating label:hover,
        .star-rating label:hover ~ label,
        .star-rating input:checked ~ label { color: var(--gold); text-shadow: 0 0 10px rgba(245,197,66,0.5); }

        .pwd-toggle { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text-dim); cursor: pointer; padding: 4px; font-size: 1.1rem; }
        .pwd-toggle:hover { color: var(--red); }

        /* ── Section title glitch on hover ── */
        .section-title, .glitch { position: relative; }
        .section-title:hover, .glitch:hover { animation: glitch 0.2s steps(2) infinite; }
        /* ── Table row subtle pulse on hover ── */
        .cyber-table tr { transition: background 0.2s; }
        .cyber-table tr:hover { background: rgba(230,57,70,0.04); }

        @Html.Raw("@keyframes navFadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }")
        @Html.Raw("@keyframes logoBreath { 0%, 100% { opacity: 1; } 50% { opacity: 0.8; } }")
        @Html.Raw("@keyframes bellSwing { 0%, 100% { transform: rotate(0); } 25% { transform: rotate(8deg); } 75% { transform: rotate(-8deg); } }")

      nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 40px; height: 72px; background: rgba(17, 17, 17, 0.85);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 1px 0 rgba(255,255,255,0.06), 0 4px 30px rgba(0,0,0,0.5);
        animation: navFadeIn 0.5s ease;
      }

      .nav-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; transition: transform 0.3s ease; }
      .nav-logo:hover { transform: scale(1.02); }
      .nav-logo img { animation: logoBreath 4s ease-in-out infinite; }
      .nav-logo-text { font-family: var(--font-display); font-size: 18px; font-weight: 900; color: #e0e0e0; letter-spacing: 2px; text-shadow: 0 0 10px rgba(0,0,0,0.5); }
      .nav-logo-text span { color: var(--red); text-shadow: 0 0 15px rgba(230,57,70,0.6); }

      .nav-links { display: flex; align-items: center; gap: 10px; list-style: none; }
      .nav-links li { display: flex; align-items: center; }
      .nav-links a {
        font-family: var(--font-mono); font-size: 13px; font-weight: 500; letter-spacing: 1px;
        text-transform: uppercase; color: #a0a0a0; text-decoration: none;
        padding: 8px 14px; transition: all 0.2s; border-radius: 6px; border: none;
        position: relative;
      }
      .nav-links a::after {
        content: ''; position: absolute; bottom: 2px; left: 50%;
        width: 0; height: 2px; background: var(--accent);
        transition: all 0.3s ease; transform: translateX(-50%); opacity: 0;
      }
      .nav-links a:hover {
        color: #ffffff; background: rgba(255,255,255,0.06);
        transform: translateY(-1px);
      }
      .nav-links a:hover::after {
        width: 60%; opacity: 1;
      }
      .nav-links a.active {
        color: var(--accent);
      }
      .nav-links a.active::after {
        width: 60%; opacity: 1; background: var(--accent);
      }

      .nav-toggle { display: none !important; }





        .btn {
            display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 10px 22px;
            font-family: var(--font-ui); font-size: 13px; font-weight: 600; letter-spacing: 1.5px;
            text-transform: uppercase; text-decoration: none; border: none; cursor: pointer;
            position: relative; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); border-radius: 8px;
            clip-path: none;
            overflow: hidden;
        }
        .btn::before {
            content: ''; position: absolute; top:0; left:-100%; width:100%; height:100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: all 0.5s ease; z-index: 1; pointer-events: none;
        }
        .btn:hover::before { left: 100%; }
        .btn-primary { background: linear-gradient(135deg, var(--red) 0%, var(--red-dim) 100%); color: white; box-shadow: 0 4px 15px rgba(230,57,70,0.3); }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(230,57,70,0.5); }
        .btn-secondary { background: rgba(255,255,255,0.04); color: var(--text-dim) !important; border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(4px); }
        .btn-secondary:hover { border-color: rgba(255,255,255,0.3); color: #fff !important; background: rgba(255,255,255,0.08); transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.3); }
        #notificationBell.hasNew i { animation: bellSwing 0.4s ease; }

        main {
            padding: 120px 40px 60px;
            flex: 1;
            position: relative;
            z-index: 10;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
        }

        @@media (max-width: 992px) {
            main { padding: 100px 24px 40px; }
            nav { padding: 0 20px; }
        }
        @@media (max-width: 768px) {
            .nav-links { flex-wrap: wrap; }
            .nav-links a { font-size: 12px; padding: 10px 14px; }
            main { padding: 90px 16px 32px; }
            nav { padding: 0 12px; }
            #notificationDropdown { width: calc(100vw - 24px) !important; right: -50px !important; }
        }
        @@media (max-width: 576px) {
            main { padding: 80px 12px 24px; }
            nav { padding: 0 8px; }
            .nav-logo-text { font-size: 13px; }
            .nav-logo img { height: 24px; }
        }

    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
     <nav>
        <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-logo">
          <img src="/images/logo.svg" alt="GameStore" height="28" style="filter:drop-shadow(0 0 6px rgba(230,57,70,0.5));" />
          <span class="nav-logo-text"><span>G</span>AME <span>S</span>TORE</span>
        </a>
        <button class="nav-toggle" aria-label="Toggle navigation"><span></span><span></span><span></span></button>
        <ul class="nav-links">
          <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
          @{ var role = Context.Session.GetString("Role"); var username = Context.Session.GetString("Username"); }
          @if (role != "DEVELOPER") { <li><a asp-area="" asp-controller="BecomeDeveloper" asp-action="Index">Developer Program</a></li> }
          @if (role == "ADMIN") { <li><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a></li> }
          @if (role == "DEVELOPER") { <li><a asp-area="Developer" asp-controller="Dashboard" asp-action="Index">Developer Portal</a></li> }
          @if (!string.IsNullOrEmpty(role))
          {
            <li><a asp-area="" asp-controller="Cart" asp-action="Index">Cart <span id="cartCount" class="badge" style="background:var(--red);color:white;font-size:10px;display:none;margin-left:4px;border-radius:0;">0</span></a></li>
            <li><a asp-area="" asp-controller="Wishlist" asp-action="Index">Wishlist</a></li>
            <li><a asp-area="" asp-controller="Library" asp-action="Index">Library</a></li>
            <li><a asp-area="" asp-controller="Friends" asp-action="Index"><i class="bi bi-people"></i> Social</a></li>
            <li><a asp-area="" asp-controller="Orders" asp-action="Index">Orders</a></li>
            <li><a asp-area="" asp-controller="Refunds" asp-action="Index">Refunds</a></li>
            <li style="display:flex;align-items:center;">
              <button id="notificationBell" style="position:relative;background:none;border:1px solid rgba(255,255,255,0.08);color:#a0a0a0;padding:6px 12px;cursor:pointer;font-size:16px;line-height:1;border-radius:6px;transition:all 0.2s;"
                 onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='#fff'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.color='#a0a0a0'">
                <i class="fas fa-bell"></i>
                <span id="notificationBadge" style="display:none;position:absolute;top:-6px;right:-6px;background:#888;color:#111;font-size:9px;padding:1px 6px;border-radius:0;min-width:18px;text-align:center;font-weight:700;">0</span>
              </button>
              <div id="notificationDropdown" style="display:none;position:absolute;top:100%;right:0;width:360px;background:rgba(26,26,26,0.95);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.1);z-index:2000;margin-top:12px;border-radius:12px;box-shadow:0 12px 40px rgba(0,0,0,0.6);transform-origin:top right;animation:navFadeIn 0.2s ease;">
                <div style="padding:14px 18px;border-bottom:1px solid rgba(255,255,255,0.06);font-family:var(--font-display);font-size:12px;font-weight:700;letter-spacing:2px;color:#fff;">NOTIFICATIONS</div>
                <div id="notificationList" style="max-height:360px;overflow-y:auto;">
                  <div class="notification-empty" style="padding:24px 16px;text-align:center;font-family:var(--font-mono);font-size:11px;color:#888;">
                    <i class="fas fa-check-circle" style="font-size:1.5rem;opacity:0.3;margin-bottom:8px;display:block;"></i>
                    No new notifications
                  </div>
                </div>
                <div style="border-top:1px solid rgba(255,255,255,0.06);padding:8px 16px;display:flex;gap:8px;">
                  <a href="#" onclick="document.getElementById('notificationDropdown').style.display='none';return false;" style="flex:1;text-align:center;font-family:var(--font-mono);font-size:10px;color:#888;text-decoration:none;padding:6px;border:1px solid rgba(255,255,255,0.06);border-radius:6px;transition:all 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='#fff'" onmouseout="this.style.borderColor='rgba(255,255,255,0.06)';this.style.color='#888'"><i class="fas fa-bell"></i> Close</a>
                  <a href="#" onclick="markAllAsRead();return false;" style="flex:1;text-align:center;font-family:var(--font-mono);font-size:10px;color:#888;text-decoration:none;padding:6px;border:1px solid rgba(255,255,255,0.06);border-radius:6px;transition:all 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='#fff'" onmouseout="this.style.borderColor='rgba(255,255,255,0.06)';this.style.color='#888'"><i class="fas fa-check-double"></i> Read All</a>
                  <a href="@Url.Action("Requests","Friends")" style="flex:1;text-align:center;font-family:var(--font-mono);font-size:10px;color:#888;text-decoration:none;padding:6px;border:1px solid rgba(255,255,255,0.06);border-radius:6px;transition:all 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='#fff'" onmouseout="this.style.borderColor='rgba(255,255,255,0.06)';this.style.color='#888'"><i class="fas fa-user-friends"></i> Requests</a>
                  <a href="@Url.Action("Index","Friends")" style="flex:1;text-align:center;font-family:var(--font-mono);font-size:10px;color:#888;text-decoration:none;padding:6px;border:1px solid rgba(255,255,255,0.06);border-radius:6px;transition:all 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='#fff'" onmouseout="this.style.borderColor='rgba(255,255,255,0.06)';this.style.color='#888'"><i class="fas fa-comment"></i> Social</a>
                </div>
              </div>
            </li>
            <li style="font-family:var(--font-mono);font-size:12px;color:#a0a0a0;">
              <a asp-area="" asp-controller="Profile" asp-action="Edit" style="color:#a0a0a0;text-decoration:none;transition:all 0.2s;display:flex;align-items:center;gap:6px;padding:4px 8px;border-radius:6px;"
                 onmouseover="this.style.color='#ffffff';this.style.background='rgba(255,255,255,0.06)'" onmouseout="this.style.color='#a0a0a0';this.style.background='transparent'"><span id="navAvatarContainer"><span id="navAvatarText" style="display:inline-block;width:28px;height:28px;border:1px solid rgba(255,255,255,0.08);display:inline-flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:12px;color:#e0e0e0;background:rgba(255,255,255,0.04);">@(username?.Substring(0,1)??"?")</span></span>[ @username ]@if (role == "ADMIN") {<span style="font-size:9px;color:#888;border:1px solid rgba(255,255,255,0.08);padding:1px 6px;margin-left:4px;">ADMIN</span>}@if (role == "DEVELOPER") {<span style="font-size:9px;color:#00e5ff;border:1px solid rgba(0,229,255,0.2);padding:1px 6px;margin-left:4px;">DEV</span>}</a>
            </li>
            <li><a asp-area="" asp-controller="Support" asp-action="MyTickets">Support</a></li>
            <li><a class="btn btn-secondary" style="padding:6px 12px;" asp-area="" asp-controller="Auth" asp-action="Logout">Logout</a></li>
          }
          else
          {
            <li><a class="btn btn-secondary" style="padding:6px 12px;" asp-area="" asp-controller="Auth" asp-action="Register">Register</a></li>
            <li><a class="btn btn-secondary" style="padding:6px 12px;" asp-area="" asp-controller="Auth" asp-action="Login">Login</a></li>
          }
        </ul>
     </nav>
    <partial name="_EmailConfirmationBanner" />
    <main>
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted mt-auto">
        <div class="container">
            &copy; 2026 - Game_Store - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a> - <a asp-area="" asp-controller="Support" asp-action="Index">Support Center</a>
        </div>
    </footer>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js" integrity="sha384-/taWmisziXYpcfnYsumSUmNaiMvG/fF/OJOUCLnqCIYTrpOZy7WbFF6FfIxwOrfL" crossorigin="anonymous"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
      (function() {
        var userId = '@Context.Session.GetString("UserId")';
        if (!userId) return;
        var connection = new signalR.HubConnectionBuilder()
          .withUrl("/hub/notifications")
          .withAutomaticReconnect()
          .build();
        connection.on("ReceiveNotification", function(data) {
          var type = data.type || 'info';
          if (typeof showToast === 'function') {
            var msg = data.senderName ? data.senderName + ': ' + (data.message || data.title) : (data.message || data.title);
            showToast(msg, type);
          }
          var bell = document.getElementById('notificationBell');
          if (bell) { bell.classList.add('hasNew'); setTimeout(function(){ bell.classList.remove('hasNew'); }, 500); }
        });

        // ── Mark all notifications as read ──
        window.markAllAsRead = function() {
          try {
            var meta = document.querySelector('meta[name="csrf-token"]');
            if (!meta) { console.error('CSRF meta tag not found'); return; }
            var token = meta.getAttribute('content');
            fetch('/Notifications/MarkAllAsRead', {
              method: 'POST',
              headers: { 'RequestVerificationToken': token }
            }).then(function(r) {
              if (r.ok) updateNotifications(); else console.error('MarkAllAsRead failed', r.status);
            }).catch(function(e) { console.error('MarkAllAsRead error', e); });
          } catch(e) { console.error('markAllAsRead exception', e); }
        };

        // ── Mark single notification as read (deletes it) ──
        window.markAsRead = function(id, url) {
          try {
            var meta = document.querySelector('meta[name="csrf-token"]');
            if (!meta) { console.error('CSRF meta tag not found'); return; }
            var token = meta.getAttribute('content');
            fetch('/Notifications/MarkAsRead', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
              },
              body: 'id=' + encodeURIComponent(id)
            }).then(function(r) {
              if (r.ok) {
                var item = document.querySelector('[data-notif-id="' + id + '"]');
                if (item) item.remove();
                updateNotifications();
                if (url) window.location.href = url;
              } else {
                console.error('markAsRead failed', r.status);
              }
            }).catch(function(e) { console.error('markAsRead error', e); });
          } catch(e) { console.error('markAsRead exception', e); }
        };

        // ── Notifications ──
        function updateNotifications() {
          var badge = document.getElementById('notificationBadge');
          var list = document.getElementById('notificationList');
          if (!badge || !list) return;

          var total = 0;
          var html = '';

          // Fetch friend data + system notifications in parallel
          Promise.all([
            fetch('/Friends/GetNotificationData').then(function(r) { return r.json(); }),
            fetch('/Notifications/GetRecent').then(function(r) { return r.json(); })
          ]).then(function(results) {
            var d = results[0];
            var notifData = results[1];

            total = (d.pendingRequests || 0) + (d.unreadMessages || 0);

            // Show friend requests
            if (d.requests && d.requests.length > 0) {
              html += '<div style="padding:6px 16px;border-bottom:1px solid var(--border);font-family:var(--font-mono);font-size:10px;color:var(--gold);letter-spacing:1px;">FRIEND REQUESTS</div>';
              d.requests.forEach(function(r) {
                var reqAv = r.avatar ? '<img src="' + r.avatar + '" style="width:32px;height:32px;object-fit:cover;" />' : '<span style="font-family:var(--font-display);font-size:13px;">' + r.username[0] + '</span>';
                html += '<div class="notif-item"' + (r.notifId ? ' data-notif-id="' + r.notifId + '"' : '') + ' style="display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:all 0.15s;"' +
                  ' onclick="' + (r.notifId ? "markAsRead('" + r.notifId + "', '/Friends/Requests')" : "window.location.href='/Friends/Requests'") + '"' +
                  ' onmouseover="this.style.backgroundColor=\'rgba(245,197,66,0.04)\';this.style.borderLeft=\'2px solid var(--gold)\';this.style.paddingLeft=\'14px\'"' +
                  ' onmouseout="this.style.backgroundColor=\'\';this.style.borderLeft=\'\';this.style.paddingLeft=\'16px\'">' +
                  '<div style="width:32px;height:32px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:13px;color:var(--gold);background:rgba(245,197,66,0.06);flex-shrink:0;">' + reqAv + '</div>' +
                '<div style="flex:1;min-width:0;">' +
                  '<div style="font-family:var(--font-mono);font-size:12px;">' + r.username + '</div>' +
                  '<div style="font-size:10px;color:var(--text-dim);font-family:var(--font-mono);">Sent you a friend request</div>' +
                '</div>' +
                '<div style="font-size:10px;color:var(--text-dim);font-family:var(--font-mono);flex-shrink:0;">' + r.sentAt + '</div>' +
              '</div>';
              });
            }

            // Show unread messages
            if (d.unreadMessages > 0) {
              total += d.unreadMessages;
              html += '<div style="padding:6px 16px;border-bottom:1px solid var(--border);font-family:var(--font-mono);font-size:10px;color:var(--cyan);letter-spacing:1px;">MESSAGES</div>';
              html += '<div class="notif-item" style="display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:all 0.15s;"' +
                ' onclick="markAllAsRead();window.location.href=\'/Friends\';"' +
                ' onmouseover="this.style.backgroundColor=\'rgba(0,229,255,0.04)\';this.style.borderLeft=\'2px solid var(--cyan)\';this.style.paddingLeft=\'14px\'"' +
                ' onmouseout="this.style.backgroundColor=\'\';this.style.borderLeft=\'\';this.style.paddingLeft=\'16px\'">' +
                '<div style="width:32px;height:32px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:13px;color:var(--cyan);background:rgba(0,255,255,0.05);flex-shrink:0;"><i class="fas fa-envelope" style="font-size:14px;"></i></div>' +
                '<div style="flex:1;min-width:0;">' +
                  '<div style="font-family:var(--font-mono);font-size:12px;">Unread Messages</div>' +
                  '<div style="font-size:10px;color:var(--text-dim);font-family:var(--font-mono);">' + d.unreadMessages + ' unread message' + (d.unreadMessages > 1 ? 's' : '') + '</div>' +
                '</div>' +
                '<span style="font-size:10px;color:var(--cyan);font-family:var(--font-mono);flex-shrink:0;">Open <i class="fas fa-arrow-right"></i></span>' +
              '</div>';
            }

            // Show system notifications
            if (notifData.notifications && notifData.notifications.length > 0) {
              if (html) html += '<div style="padding:6px 16px;border-bottom:1px solid var(--border);font-family:var(--font-mono);font-size:10px;color:var(--red);letter-spacing:1px;">SYSTEM</div>';
              notifData.notifications.forEach(function(n) {
                if (!n.isRead) total++;
                var iconMap = { success: 'fa-check-circle', error: 'fa-times-circle', warning: 'fa-exclamation-triangle', info: 'fa-info-circle' };
                var icon = iconMap[n.type] || 'fa-info-circle';
                var colorMap = { success: '#4ade80', error: 'var(--red)', warning: 'var(--gold)', info: 'var(--cyan)' };
                var bgMap = { success: 'rgba(74,222,128,0.06)', error: 'rgba(230,57,70,0.06)', warning: 'rgba(245,197,66,0.06)', info: 'rgba(0,229,255,0.06)' };
                html += '<div class="notif-item" data-notif-id="' + n.id + '" style="display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid var(--border);text-decoration:none;cursor:pointer;transition:all 0.15s;' + (n.isRead ? '' : 'background:rgba(230,57,70,0.03);') + '"' +
                  ' onclick="markAsRead(\'' + n.id + '\', \'' + (n.referenceUrl || '') + '\')"' +
                  ' onmouseover="this.style.backgroundColor=\'rgba(255,255,255,0.03)\';this.style.borderLeft=\'2px solid var(--red)\';this.style.paddingLeft=\'14px\'"' +
                  ' onmouseout="this.style.backgroundColor=\'\';this.style.borderLeft=\'\';this.style.paddingLeft=\'16px\'">' +
                  '<div style="width:28px;height:28px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:12px;color:' + (colorMap[n.type] || 'var(--text-dim)') + ';background:' + (bgMap[n.type] || 'rgba(255,255,255,0.02)') + ';flex-shrink:0;"><i class="fas ' + icon + '"></i></div>' +
                  '<div style="flex:1;min-width:0;">' +
                    '<div style="font-family:var(--font-mono);font-size:11px;' + (n.isRead ? '' : 'color:white;') + '">' + n.title + '</div>' +
                    '<div style="font-size:10px;color:var(--text-dim);font-family:var(--font-mono);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + n.message + '</div>' +
                    '<div style="font-size:9px;color:var(--text-dim);font-family:var(--font-mono);margin-top:2px;">' + n.createdAt + '</div>' +
                  '</div>' +
                '</div>';
              });
            }

            if (!html) {
              html = '<div class="notification-empty" style="padding:24px 16px;text-align:center;font-family:var(--font-mono);font-size:11px;color:var(--text-dim);">' +
                '<i class="fas fa-check-circle" style="font-size:1.5rem;opacity:0.3;margin-bottom:8px;display:block;"></i>' +
                'No new notifications</div>';
            }

            if (total > 0) { badge.textContent = total; badge.style.display = 'inline'; }
            else badge.style.display = 'none';
            list.innerHTML = html;
          }).catch(function(){});
        }

        // Bell toggle
        var bellBtn = document.getElementById('notificationBell');
        var bellDropdown = document.getElementById('notificationDropdown');
        if (bellBtn && bellDropdown) {
          bellBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            var isOpen = bellDropdown.style.display === 'block';
            bellDropdown.style.display = isOpen ? 'none' : 'block';
            if (!isOpen) updateNotifications();
          });
          document.addEventListener('click', function(e) {
            if (!bellBtn.contains(e.target) && !bellDropdown.contains(e.target)) {
              bellDropdown.style.display = 'none';
            }
          });
        }

        // Chat handlers
        connection.on("ReceiveMessage", function(msg) {
          if (typeof window.handleIncomingMessage === 'function') {
            window.handleIncomingMessage(msg);
          }
          if (typeof window.showToast === 'function') {
            showToast(msg.senderName + ': ' + msg.content, 'info');
          }
        });

        connection.on("ReceiveNotification", function(data) {
          updateNotifications();
        });

        connection.on("UserOnline", function(data) {
          if (typeof window.handleUserOnline === 'function') {
            window.handleUserOnline(data);
          }
        });

        connection.on("UserOffline", function(data) {
          if (typeof window.handleUserOffline === 'function') {
            window.handleUserOffline(data);
          }
        });

        connection.on("UserTyping", function(data) {
          if (typeof window.handleUserTyping === 'function') {
            window.handleUserTyping(data);
          }
        });

        connection.on("MessagesRead", function(data) {
          if (typeof window.handleMessagesRead === 'function') {
            window.handleMessagesRead(data);
          }
        });

        connection.on("MessageSent", function(msg) {
          if (typeof window.handleMessageSent === 'function') {
            window.handleMessageSent(msg);
          }
        });

        window.chatConnection = connection;

        connection.start().then(function() {
          connection.invoke("JoinUserGroup", userId).catch(function(){});
          updateNotifications();
        }).catch(function(){});

        setInterval(updateNotifications, 30000);

        // Trigger event for chat page
        document.dispatchEvent(new CustomEvent('chatConnectionReady'));
      })();
    </script>

    <div class="toast-container" id="toastContainer"></div>

    <style>
      .toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; }
      .toast { background: var(--bg2); border: 1px solid var(--border-red); padding: 16px 20px; display: flex; align-items: center; gap: 12px; animation: slideIn 0.3s ease; min-width: 280px; max-width: 400px; }
      @@media (max-width: 576px) { .toast-container { right: 12px !important; bottom: 12px !important; } .toast { min-width: unset !important; max-width: calc(100vw - 24px) !important; padding: 12px 16px; } }
      .toast.success { border-color: #4ade80; }
      .toast.error { border-color: var(--red); }
      .toast.warning { border-color: var(--gold); }
      .toast i { font-size: 1.2rem; }
      .toast.success i { color: #4ade80; }
      .toast.error i { color: var(--red); }
      .toast.warning i { color: var(--gold); }
      .toast-content { flex: 1; font-family: var(--font-mono); font-size: 12px; }
      .toast-close { background: none; border: none; color: var(--text-dim); cursor: pointer; padding: 4px; }
    </style>

    <script>
      // Toast notification system
      function showToast(message, type) {
        type = type || 'success';
        const container = document.getElementById('toastContainer');
        if (!container) return;
        const icons = { success: 'bi-check-circle-fill', error: 'bi-x-circle-fill', warning: 'bi-exclamation-triangle-fill' };
        const toast = document.createElement('div');
        toast.className = 'toast ' + type;
        toast.innerHTML = '<i class="bi ' + (icons[type] || icons.success) + '"></i>' +
          '<div class="toast-content">' + message + '</div>' +
          '<button class="toast-close" onclick="this.parentElement.remove()">&times;</button>';
        container.appendChild(toast);
        setTimeout(() => { if (toast.parentElement) { toast.style.opacity = '0'; toast.style.transform = 'translateX(100%)'; toast.style.transition = 'all 0.3s'; setTimeout(() => toast.remove(), 300); } }, 4000);
      }

      // Loading state on form submit
      document.querySelectorAll('form').forEach(function(f) {
        f.addEventListener('submit', function() {
          var btn = this.querySelector('.btn[type="submit"], button[type="submit"]');
          if (btn) {
            btn.classList.add('loading');
            setTimeout(function() { btn.classList.remove('loading'); }, 2000);
          }
        });
      });

      // Password visibility toggle
      window.togglePwd = function(btn) {
        var input = btn.parentElement.querySelector('input');
        if (!input) return;
        var type = input.type === 'password' ? 'text' : 'password';
        input.type = type;
        var icon = btn.querySelector('i');
        if (icon) icon.className = type === 'password' ? 'bi bi-eye-slash' : 'bi bi-eye';
      };

      // Navbar avatar
      function updateNavAvatar() {
        fetch('/Profile/GetAvatarUrl').then(function(r) { return r.json(); }).then(function(d) {
          var container = document.getElementById('navAvatarContainer');
          if (!container) return;
          if (d.url) {
            container.innerHTML = '<img src="' + d.url + '" style="width:28px;height:28px;object-fit:cover;border:1px solid var(--border);" />';
          } else {
            container.innerHTML = '<span style="display:inline-block;width:28px;height:28px;border:1px solid var(--border);display:inline-flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:12px;color:var(--red);background:rgba(230,57,70,0.06);">' + (d.initial || '?') + '</span>';
          }
        }).catch(function(){});
      }
      updateNavAvatar();

      // Cart count updater
      function updateCartCount() {
        fetch('/Cart/GetCount').then(function(r) { return r.json(); }).then(function(d) {
          var badge = document.getElementById('cartCount');
          if (!badge) return;
          if (d.count > 0) { badge.textContent = d.count; badge.style.display = 'inline'; }
          else badge.style.display = 'none';
        }).catch(function(){});
      }
      updateCartCount();

      // Ripple click effect on buttons
      document.querySelectorAll('.btn, .stat-link, .qa-card, .nav-links a').forEach(el => {
        el.classList.add('ripple');
        el.addEventListener('mousedown', function(e) {
          const rect = this.getBoundingClientRect();
          this.style.setProperty('--mx', (e.clientX - rect.left) + 'px');
          this.style.setProperty('--my', (e.clientY - rect.top) + 'px');
        });
      });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    <partial name="_ConfirmModal" />
</body>

</html>
