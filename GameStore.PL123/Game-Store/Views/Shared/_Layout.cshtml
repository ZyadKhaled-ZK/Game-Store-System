<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Game_Store</title>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;500;700;900&family=Share+Tech+Mono&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Game_Store.styles.css" asp-append-version="true" />
    <style>
        :root {
            --gold: #f5c542;
            --gold-dim: #b8922e;
            --red: #e63946;
            --red-dim: #9b1d25;
            --bg: #070709;
            --bg2: #0d0d12;
            --bg3: #111118;
            --border: rgba(245, 197, 66, 0.18);
            --border-red: rgba(230, 57, 70, 0.22);
            --text: #e8e8f0;
            --text-dim: #7a7a99;
            --glow-gold: 0 0 20px rgba(245, 197, 66, 0.4);
            --glow-red: 0 0 20px rgba(230, 57, 70, 0.4);
            --font-display: 'Orbitron', monospace;
            --font-ui: 'Rajdhani', sans-serif;
            --font-mono: 'Share Tech Mono', monospace;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-ui);
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 0, 0, 0.08) 2px,
                    rgba(0, 0, 0, 0.08) 4px);
            pointer-events: none;
            z-index: 9999;
        }

        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 9998;
            opacity: 0.6;
        }

        /* ── Subtle entrance fade ── */
        main { animation: pageIn 0.35s ease; }
        @Html.Raw("@keyframes pageIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }")

        /* ── Focus glow pulse ── */
        input:focus, select:focus, textarea:focus, button:focus-visible, a:focus-visible {
          outline: none;
          box-shadow: 0 0 0 2px #070709, 0 0 14px 2px rgba(230,57,70,0.35);
          transition: box-shadow 0.2s;
        }

        /* ── Button subtle hover lift ── */
        .btn { transition: all 0.25s; }
        .btn:hover { transform: translateY(-1px); }
        .btn:active { transform: translateY(0); }

        /* ── Card hover lift ── */
        .game-card, .wishlist-card, .hero-card { transition: all 0.3s; }
        .game-card:hover, .wishlist-card:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(0,0,0,0.4), var(--glow-red); }

        /* ── Section title glitch on hover ── */
        .section-title, .glitch { position: relative; }
        .section-title:hover, .glitch:hover { animation: glitch 0.2s steps(2) infinite; }
        @Html.Raw("@keyframes glitch { 0% { text-shadow: 1.5px 0 var(--gold), -1.5px 0 var(--red); } 33% { text-shadow: -1.5px 0 var(--gold), 1.5px 0 var(--red); } 66% { text-shadow: 1.5px 0 var(--red), -1.5px 0 var(--gold); } 100% { text-shadow: -1.5px 0 var(--red), 1.5px 0 var(--gold); } }")

        /* ── Table row subtle pulse on hover ── */
        .cyber-table tr { transition: background 0.2s; }
        .cyber-table tr:hover { background: rgba(230,57,70,0.04); }

        nav {
            position: fixed !important;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            height: 70px;
            background: rgba(7, 7, 9, 0.9) !important;
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-red) !important;
        }

        nav::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--red), transparent);
            opacity: 0.8;
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: white !important;
        }

        .nav-logo-icon {
            width: 36px;
            height: 36px;
            border: 1.5px solid var(--red);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--glow-red), inset 0 0 12px rgba(230, 57, 70, 0.15);
            font-family: var(--font-display);
            font-size: 14px;
            font-weight: 900;
            color: var(--red);
            animation: logoGlow 3s ease-in-out infinite;
        }

        @Html.Raw("@keyframes logoGlow { 0%, 100% { box-shadow: var(--glow-red), inset 0 0 12px rgba(230, 57, 70, 0.15); } 50% { box-shadow: 0 0 30px rgba(230, 57, 70, 0.6), inset 0 0 20px rgba(230, 57, 70, 0.25); } }")

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 14px;
            text-decoration: none;
            color: white !important;
            padding: 6px 16px 6px 12px;
            border: 1px solid rgba(230,57,70,0.2);
            background: linear-gradient(135deg, rgba(230,57,70,0.05) 0%, transparent 100%);
            transition: all 0.3s;
            clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
        }
        .navbar-brand:hover {
            border-color: var(--red);
            background: linear-gradient(135deg, rgba(230,57,70,0.12) 0%, transparent 100%);
            box-shadow: 0 0 20px rgba(230,57,70,0.15);
        }
        .brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }
        .brand-text .brand-game {
            font-family: var(--font-display);
            font-size: 11px;
            font-weight: 500;
            color: var(--text-dim);
            letter-spacing: 3px;
            text-transform: uppercase;
        }
        .brand-text .brand-store {
            font-family: var(--font-display);
            font-size: 20px;
            font-weight: 900;
            color: white;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(230,57,70,0.4);
            transition: text-shadow 0.3s;
        }
        .brand-text .brand-store span {
            color: var(--red);
        }
        .navbar-brand:hover .brand-store {
            text-shadow: 0 0 20px rgba(230,57,70,0.7);
        }

        .navbar-nav {
            display: flex;
            gap: 15px;
            list-style: none;
            flex-direction: row;
        }

        .nav-link {
            font-family: var(--font-mono);
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--text) !important;
            text-decoration: none;
            padding: 8px 16px !important;
            border: 1px solid transparent;
            transition: all 0.2s;
        }

        .nav-link:hover {
            color: var(--red) !important;
            border-color: var(--border-red);
            background: rgba(230, 57, 70, 0.05);
            text-shadow: var(--glow-red);
        }

        .btn {
            display: inline-flex; align-items: center; gap: 10px; padding: 12px 24px;
            font-family: var(--font-ui); font-size: 14px; font-weight: 700; letter-spacing: 2px;
            text-transform: uppercase; text-decoration: none; border: none; cursor: pointer;
            position: relative; transition: all 0.25s;
            clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
        }
        .btn-primary { background: linear-gradient(135deg, var(--red-dim), var(--red)); color: white; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: var(--glow-red); filter: brightness(1.2); color: white; }
        .btn-secondary { background: rgba(255,255,255,0.04); color: var(--text); border: 1px solid var(--border-red); clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%); }
        .btn-secondary:hover { border-color: var(--red); color: var(--red) !important; background: rgba(230,57,70,0.08); transform: translateY(-2px); }

        main {
            padding: 120px 40px 60px;
            flex: 1;
            position: relative;
            z-index: 10;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
        }



    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="/images/logo.svg" alt="GameStore" height="38" style="filter:drop-shadow(0 0 8px rgba(230,57,70,0.6));" />
                    <div class="brand-text">
                        <div class="brand-game">Game Store</div>
                        <div class="brand-store"><span>G</span>AME <span>S</span>TORE</div>
                    </div>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @{
                            var role = Context.Session.GetString("Role");
                            var username = Context.Session.GetString("Username");
                        }
                        @if (role == "ADMIN")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a>
                            </li>
                        }
                        @if (!string.IsNullOrEmpty(role))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Cart" asp-action="Index">Cart</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Wishlist" asp-action="Index">Wishlist</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Library" asp-action="Index">Library</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Orders" asp-action="Index">Orders</a>
                            </li>
                            <li class="nav-item" style="font-family:var(--font-mono);font-size:12px;color:var(--text-dim);align-self:center;">
                                <a asp-area="" asp-controller="Auth" asp-action="Profile" style="color:var(--text-dim);text-decoration:none;transition:color 0.2s;"
                                   onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text-dim)'">[ @username ]</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-secondary nav-link pt-2 pb-2" asp-area="" asp-controller="Auth" asp-action="Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-2">
                                <a class="btn btn-secondary nav-link pt-2 pb-2" asp-area="" asp-controller="Auth" asp-action="Register">Register</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-secondary nav-link pt-2 pb-2" asp-area="" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto">
        <div class="container">
            &copy; 2026 - Game_Store - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <div class="toast-container" id="toastContainer"></div>

    <style>
      .toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; }
      .toast { background: var(--bg2); border: 1px solid var(--border-red); padding: 16px 20px; display: flex; align-items: center; gap: 12px; animation: slideIn 0.3s ease; min-width: 280px; max-width: 400px; }
      .toast.success { border-color: #4ade80; }
      .toast.error { border-color: var(--red); }
      .toast.warning { border-color: var(--gold); }
      .toast i { font-size: 1.2rem; }
      .toast.success i { color: #4ade80; }
      .toast.error i { color: var(--red); }
      .toast.warning i { color: var(--gold); }
      .toast-content { flex: 1; font-family: var(--font-mono); font-size: 12px; }
      .toast-close { background: none; border: none; color: var(--text-dim); cursor: pointer; padding: 4px; }
      @Html.Raw("@keyframes slideIn { from { opacity: 0; transform: translateX(100%); } to { opacity: 1; transform: translateX(0); } }")
    </style>

    <script>
      // Toast notification system
      function showToast(message, type) {
        type = type || 'success';
        const container = document.getElementById('toastContainer');
        if (!container) return;
        const icons = { success: 'bi-check-circle-fill', error: 'bi-x-circle-fill', warning: 'bi-exclamation-triangle-fill' };
        const toast = document.createElement('div');
        toast.className = 'toast ' + type;
        toast.innerHTML = '<i class="bi ' + (icons[type] || icons.success) + '"></i>' +
          '<div class="toast-content">' + message + '</div>' +
          '<button class="toast-close" onclick="this.parentElement.remove()">&times;</button>';
        container.appendChild(toast);
        setTimeout(() => { if (toast.parentElement) { toast.style.opacity = '0'; toast.style.transform = 'translateX(100%)'; toast.style.transition = 'all 0.3s'; setTimeout(() => toast.remove(), 300); } }, 4000);
      }

      // Ripple click effect on buttons
      document.querySelectorAll('.btn, .stat-link, .qa-card, .nav-links a').forEach(el => {
        el.classList.add('ripple');
        el.addEventListener('mousedown', function(e) {
          const rect = this.getBoundingClientRect();
          this.style.setProperty('--mx', (e.clientX - rect.left) + 'px');
          this.style.setProperty('--my', (e.clientY - rect.top) + 'px');
        });
      });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
