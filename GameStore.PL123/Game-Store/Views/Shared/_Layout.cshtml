<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Game_Store</title>
    @await RenderSectionAsync("MetaTags", required: false)
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;500;700;900&family=Share+Tech+Mono&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha384-nRgPTkuX86pH8yjPJUAFuASXQSSl2/bBUiNV47vSYpKFxHJhbcrGnmlYpYJMeD7a" crossorigin="anonymous" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Game_Store.styles.css" asp-append-version="true" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js" integrity="sha384-/taWmisziXYpcfnYsumSUmNaiMvG/fF/OJOUCLnqCIYTrpOZy7WbFF6FfIxwOrfL" crossorigin="anonymous"></script>
    <style>
        :root {
            --gold: #f5c542;
            --gold-dim: #b8922e;
            --red: #e63946;
            --red-dim: #9b1d25;
            --bg: #070709;
            --bg2: #0d0d12;
            --bg3: #111118;
            --border: rgba(245, 197, 66, 0.18);
            --border-red: rgba(230, 57, 70, 0.22);
            --text: #e8e8f0;
            --text-dim: #7a7a99;
            --cyan: #00e5ff;
            --glow-gold: 0 0 20px rgba(245, 197, 66, 0.4);
            --glow-red: 0 0 20px rgba(230, 57, 70, 0.4);
            --font-display: 'Orbitron', monospace;
            --font-ui: 'Rajdhani', sans-serif;
            --font-mono: 'Share Tech Mono', monospace;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-ui);
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 0, 0, 0.08) 2px,
                    rgba(0, 0, 0, 0.08) 4px);
            pointer-events: none;
            z-index: 9999;
        }

        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 9998;
            opacity: 0.6;
        }

        /* ── Subtle entrance fade ── */
        main { animation: pageIn 0.35s ease; }
        @Html.Raw("@keyframes pageIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }")

        /* ── Focus glow pulse ── */
        input:focus, select:focus, textarea:focus, button:focus-visible, a:focus-visible {
          outline: none;
          box-shadow: 0 0 0 2px #070709, 0 0 14px 2px rgba(230,57,70,0.35);
          transition: box-shadow 0.2s;
        }

        /* ── Button subtle hover lift ── */
        .btn { transition: all 0.25s; position: relative; }
        .btn:hover { transform: translateY(-1px); }
        .btn:active { transform: translateY(0); }
        .btn.loading { pointer-events: none; opacity: 0.7; }
        .btn.loading::after { content: ''; display: inline-block; width: 12px; height: 12px; border: 2px solid transparent; border-top-color: currentColor; border-radius: 50%; animation: spin 0.6s linear infinite; margin-left: 8px; vertical-align: middle; }
        .btn.loading { pointer-events: none; opacity: 0.7; }
        .btn.loading::after { content: ''; display: inline-block; width: 12px; height: 12px; border: 2px solid transparent; border-top-color: currentColor; border-radius: 50%; animation: spin 0.6s linear infinite; margin-left: 8px; vertical-align: middle; }
        @Html.Raw("@keyframes spin { to { transform: rotate(360deg); } }")

        /* ── Card hover lift ── */
        .game-card, .wishlist-card, .hero-card { transition: all 0.3s; }
        .game-card:hover, .wishlist-card:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(0,0,0,0.4), var(--glow-red); }

        .star-rating { display: inline-flex; flex-direction: row-reverse; gap: 4px; }
        .star-rating input { display: none; }
        .star-rating label { font-size: 1.8rem; color: var(--text-dim); cursor: pointer; transition: color 0.2s; }
        .star-rating label:hover,
        .star-rating label:hover ~ label,
        .star-rating input:checked ~ label { color: var(--gold); text-shadow: 0 0 10px rgba(245,197,66,0.5); }

        .pwd-toggle { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text-dim); cursor: pointer; padding: 4px; font-size: 1.1rem; }
        .pwd-toggle:hover { color: var(--red); }

        /* ── Section title glitch on hover ── */
        .section-title, .glitch { position: relative; }
        .section-title:hover, .glitch:hover { animation: glitch 0.2s steps(2) infinite; }
        @Html.Raw("@keyframes glitch { 0% { text-shadow: 1.5px 0 var(--gold), -1.5px 0 var(--red); } 33% { text-shadow: -1.5px 0 var(--gold), 1.5px 0 var(--red); } 66% { text-shadow: 1.5px 0 var(--red), -1.5px 0 var(--gold); } 100% { text-shadow: -1.5px 0 var(--red), 1.5px 0 var(--gold); } }")
        @Html.Raw("@keyframes spin { to { transform: rotate(360deg); } }")

        /* ── Table row subtle pulse on hover ── */
        .cyber-table tr { transition: background 0.2s; }
        .cyber-table tr:hover { background: rgba(230,57,70,0.04); }

        nav {
            position: fixed !important;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            height: 70px;
            background: rgba(7, 7, 9, 0.9) !important;
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-red) !important;
        }

        nav::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--red), transparent);
            opacity: 0.8;
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: white !important;
        }

        .nav-logo-icon {
            width: 36px;
            height: 36px;
            border: 1.5px solid var(--red);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--glow-red), inset 0 0 12px rgba(230, 57, 70, 0.15);
            font-family: var(--font-display);
            font-size: 14px;
            font-weight: 900;
            color: var(--red);
            animation: logoGlow 3s ease-in-out infinite;
        }

        @Html.Raw("@keyframes logoGlow { 0%, 100% { box-shadow: var(--glow-red), inset 0 0 12px rgba(230, 57, 70, 0.15); } 50% { box-shadow: 0 0 30px rgba(230, 57, 70, 0.6), inset 0 0 20px rgba(230, 57, 70, 0.25); } }")

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 14px;
            text-decoration: none;
            color: white !important;
            padding: 6px 16px 6px 12px;
            border: 1px solid rgba(230,57,70,0.2);
            background: linear-gradient(135deg, rgba(230,57,70,0.05) 0%, transparent 100%);
            transition: all 0.3s;
            clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
        }
        .navbar-brand:hover {
            border-color: var(--red);
            background: linear-gradient(135deg, rgba(230,57,70,0.12) 0%, transparent 100%);
            box-shadow: 0 0 20px rgba(230,57,70,0.15);
        }
        .brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }
        .brand-text .brand-game {
            font-family: var(--font-display);
            font-size: 11px;
            font-weight: 500;
            color: var(--text-dim);
            letter-spacing: 3px;
            text-transform: uppercase;
        }
        .brand-text .brand-store {
            font-family: var(--font-display);
            font-size: 20px;
            font-weight: 900;
            color: white;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(230,57,70,0.4);
            transition: text-shadow 0.3s;
        }
        .brand-text .brand-store span {
            color: var(--red);
        }
        .navbar-brand:hover .brand-store {
            text-shadow: 0 0 20px rgba(230,57,70,0.7);
        }

        .navbar-nav {
            display: flex;
            gap: 15px;
            list-style: none;
            flex-direction: row;
        }

        .nav-link {
            font-family: var(--font-mono);
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--text) !important;
            text-decoration: none;
            padding: 8px 16px !important;
            border: 1px solid transparent;
            transition: all 0.2s;
        }

        .nav-link:hover {
            color: var(--red) !important;
            border-color: var(--border-red);
            background: rgba(230, 57, 70, 0.05);
            text-shadow: var(--glow-red);
        }

        .btn {
            display: inline-flex; align-items: center; gap: 10px; padding: 12px 24px;
            font-family: var(--font-ui); font-size: 14px; font-weight: 700; letter-spacing: 2px;
            text-transform: uppercase; text-decoration: none; border: none; cursor: pointer;
            position: relative; transition: all 0.25s;
            clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
        }
        .btn-primary { background: linear-gradient(135deg, var(--red-dim), var(--red)); color: white; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: var(--glow-red); filter: brightness(1.2); color: white; }
        .btn-secondary { background: rgba(255,255,255,0.04); color: var(--text); border: 1px solid var(--border-red); clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%); }
        .btn-secondary:hover { border-color: var(--red); color: var(--red) !important; background: rgba(230,57,70,0.08); transform: translateY(-2px); }

        main {
            padding: 120px 40px 60px;
            flex: 1;
            position: relative;
            z-index: 10;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
        }



    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="/images/logo.svg" alt="GameStore" height="38" style="filter:drop-shadow(0 0 8px rgba(230,57,70,0.6));" />
                    <div class="brand-text">
                        <div class="brand-game">Game Store</div>
                        <div class="brand-store"><span>G</span>AME <span>S</span>TORE</div>
                    </div>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @{
                            var role = Context.Session.GetString("Role");
                            var username = Context.Session.GetString("Username");
                        }
                        @if (role != "DEVELOPER")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="BecomeDeveloper" asp-action="Index">Developer Program</a>
                            </li>
                        }
                        @if (role == "ADMIN")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a>
                            </li>
                        }
                        @if (role == "DEVELOPER")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Developer" asp-controller="Dashboard" asp-action="Index">Developer Portal</a>
                            </li>
                        }
                        @if (!string.IsNullOrEmpty(role))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Cart" asp-action="Index">
                                    Cart <span id="cartCount" class="badge" style="background:var(--red);color:white;font-size:10px;display:none;margin-left:4px;border-radius:0;">0</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Wishlist" asp-action="Index">Wishlist</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Library" asp-action="Index">Library</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Friends" asp-action="Index"><i class="bi bi-people"></i> Social</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Orders" asp-action="Index">Orders</a>
                            </li>
                            <li class="nav-item position-relative" style="align-self:center;">
                                <button class="btn-cyber btn-sm" id="notificationBell" style="position:relative;background:none;border:1px solid var(--border);color:var(--text);padding:6px 12px;cursor:pointer;font-size:16px;line-height:1;">
                                    <i class="fas fa-bell"></i>
                                    <span id="notificationBadge" class="badge" style="display:none;position:absolute;top:-6px;right:-6px;background:var(--red);color:#fff;font-size:9px;padding:1px 6px;border-radius:0;min-width:18px;text-align:center;">0</span>
                                </button>
                                <div id="notificationDropdown" class="notification-dropdown" style="display:none;position:absolute;top:100%;right:0;width:340px;background:var(--bg2);border:1px solid var(--border);z-index:2000;margin-top:8px;">
                                    <div style="padding:12px 16px;border-bottom:1px solid var(--border);font-family:var(--font-display);font-size:12px;letter-spacing:2px;color:var(--red);">NOTIFICATIONS</div>
                                    <div id="notificationList" style="max-height:360px;overflow-y:auto;">
                                        <div class="notification-empty" style="padding:24px 16px;text-align:center;font-family:var(--font-mono);font-size:11px;color:var(--text-dim);">
                                            <i class="fas fa-check-circle" style="font-size:1.5rem;opacity:0.3;margin-bottom:8px;display:block;"></i>
                                            No new notifications
                                        </div>
                                    </div>
                                    <div style="border-top:1px solid var(--border);padding:8px 16px;display:flex;gap:8px;">
                                        <a href="@Url.Action("Requests","Friends")" class="btn-cyber btn-xs" style="flex:1;text-align:center;text-decoration:none;"><i class="fas fa-user-friends"></i> View Requests</a>
                                        <a href="@Url.Action("Index","Friends")" class="btn-cyber btn-xs" style="flex:1;text-align:center;text-decoration:none;"><i class="fas fa-comment"></i> Open Social</a>
                                    </div>
                                </div>
                            </li>
                            <li class="nav-item" style="font-family:var(--font-mono);font-size:12px;color:var(--text-dim);align-self:center;">
                                <a asp-area="" asp-controller="Auth" asp-action="Profile" style="color:var(--text-dim);text-decoration:none;transition:color 0.2s;display:flex;align-items:center;gap:6px;"
                                   onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text-dim)'"><span id="navAvatarContainer"><span id="navAvatarText" style="display:inline-block;width:28px;height:28px;border:1px solid var(--border);display:inline-flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:12px;color:var(--red);background:rgba(230,57,70,0.06);">@(username?.Substring(0,1)??"?")</span></span>[ @username ]@if (role == "ADMIN") {<span style="font-size:9px;color:var(--gold);border:1px solid var(--gold);padding:1px 6px;">ADMIN</span>}@if (role == "DEVELOPER") {<span style="font-size:9px;color:var(--cyan);border:1px solid var(--cyan);padding:1px 6px;">DEV</span>}</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-secondary nav-link pt-2 pb-2" asp-area="" asp-controller="Auth" asp-action="Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-2">
                                <a class="btn btn-secondary nav-link pt-2 pb-2" asp-area="" asp-controller="Auth" asp-action="Register">Register</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-secondary nav-link pt-2 pb-2" asp-area="" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto">
        <div class="container">
            &copy; 2026 - Game_Store - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
      (function() {
        var userId = '@Context.Session.GetString("UserId")';
        if (!userId) return;
        var connection = new signalR.HubConnectionBuilder()
          .withUrl("/hub/notifications")
          .withAutomaticReconnect()
          .build();
        connection.on("ReceiveNotification", function(data) {
          var type = data.type || 'info';
          if (typeof showToast === 'function') {
            showToast(data.message || data.title, type);
          }
        });

        // ── Notifications ──
        function updateNotifications() {
          fetch('/Friends/GetNotificationData').then(function(r) { return r.json(); }).then(function(d) {
            var badge = document.getElementById('notificationBadge');
            if (!badge) return;
            var total = (d.pendingRequests || 0) + (d.unreadMessages || 0);
            if (total > 0) { badge.textContent = total; badge.style.display = 'inline'; }
            else badge.style.display = 'none';

            var list = document.getElementById('notificationList');
            if (!list) return;
            var html = '';

            // Show friend requests
              if (d.requests && d.requests.length > 0) {
                d.requests.forEach(function(r) {
                  var reqAv = r.avatar ? '<img src="' + r.avatar + '" style="width:32px;height:32px;object-fit:cover;" />' : r.username[0];
                  html += '<div class="notif-item" style="display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border);">' +
                    '<div style="width:32px;height:32px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:13px;color:var(--gold);background:rgba(245,197,66,0.06);flex-shrink:0;">' + reqAv + '</div>' +
                  '<div style="flex:1;min-width:0;">' +
                    '<div style="font-family:var(--font-mono);font-size:12px;">' + r.username + '</div>' +
                    '<div style="font-size:10px;color:var(--text-dim);font-family:var(--font-mono);">Sent you a friend request</div>' +
                  '</div>' +
                  '<div style="font-size:10px;color:var(--text-dim);font-family:var(--font-mono);flex-shrink:0;">' + r.sentAt + '</div>' +
                '</div>';
              });
            }

            // Show unread messages
            if (d.unreadMessages > 0) {
              html += '<div class="notif-item" style="display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border);">' +
                '<div style="width:32px;height:32px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:13px;color:var(--cyan);background:rgba(0,255,255,0.05);flex-shrink:0;"><i class="fas fa-envelope" style="font-size:14px;"></i></div>' +
                '<div style="flex:1;min-width:0;">' +
                  '<div style="font-family:var(--font-mono);font-size:12px;">Unread Messages</div>' +
                  '<div style="font-size:10px;color:var(--text-dim);font-family:var(--font-mono);">' + d.unreadMessages + ' unread message' + (d.unreadMessages > 1 ? 's' : '') + '</div>' +
                '</div>' +
                '<a href="@Url.Action("Index","Friends")" style="font-size:10px;color:var(--cyan);font-family:var(--font-mono);text-decoration:none;flex-shrink:0;">Open <i class="fas fa-arrow-right"></i></a>' +
              '</div>';
            }

            if (!html) {
              html = '<div class="notification-empty" style="padding:24px 16px;text-align:center;font-family:var(--font-mono);font-size:11px;color:var(--text-dim);">' +
                '<i class="fas fa-check-circle" style="font-size:1.5rem;opacity:0.3;margin-bottom:8px;display:block;"></i>' +
                'No new notifications</div>';
            }
            list.innerHTML = html;
          }).catch(function(){});
        }

        // Bell toggle
        var bellBtn = document.getElementById('notificationBell');
        var bellDropdown = document.getElementById('notificationDropdown');
        if (bellBtn && bellDropdown) {
          bellBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            var isOpen = bellDropdown.style.display === 'block';
            bellDropdown.style.display = isOpen ? 'none' : 'block';
            if (!isOpen) updateNotifications();
          });
          document.addEventListener('click', function(e) {
            if (!bellBtn.contains(e.target) && !bellDropdown.contains(e.target)) {
              bellDropdown.style.display = 'none';
            }
          });
        }

        // Chat handlers
        connection.on("ReceiveMessage", function(msg) {
          if (typeof window.handleIncomingMessage === 'function') {
            window.handleIncomingMessage(msg);
          }
          if (typeof window.showToast === 'function') {
            showToast(msg.senderName + ': ' + msg.content, 'info');
          }
        });

        connection.on("ReceiveNotification", function(data) {
          updateNotifications();
        });

        connection.on("UserOnline", function(data) {
          if (typeof window.handleUserOnline === 'function') {
            window.handleUserOnline(data);
          }
        });

        connection.on("UserOffline", function(data) {
          if (typeof window.handleUserOffline === 'function') {
            window.handleUserOffline(data);
          }
        });

        connection.on("UserTyping", function(data) {
          if (typeof window.handleUserTyping === 'function') {
            window.handleUserTyping(data);
          }
        });

        connection.on("MessagesRead", function(data) {
          if (typeof window.handleMessagesRead === 'function') {
            window.handleMessagesRead(data);
          }
        });

        connection.on("MessageSent", function(msg) {
          if (typeof window.handleMessageSent === 'function') {
            window.handleMessageSent(msg);
          }
        });

        window.chatConnection = connection;

        connection.start().then(function() {
          connection.invoke("JoinUserGroup", userId).catch(function(){});
          updateNotifications();
        }).catch(function(){});

        setInterval(updateNotifications, 30000);

        // Trigger event for chat page
        $(document).trigger('chatConnectionReady');
      })();
    </script>

    <div class="toast-container" id="toastContainer"></div>

    <style>
      .toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; }
      .toast { background: var(--bg2); border: 1px solid var(--border-red); padding: 16px 20px; display: flex; align-items: center; gap: 12px; animation: slideIn 0.3s ease; min-width: 280px; max-width: 400px; }
      .toast.success { border-color: #4ade80; }
      .toast.error { border-color: var(--red); }
      .toast.warning { border-color: var(--gold); }
      .toast i { font-size: 1.2rem; }
      .toast.success i { color: #4ade80; }
      .toast.error i { color: var(--red); }
      .toast.warning i { color: var(--gold); }
      .toast-content { flex: 1; font-family: var(--font-mono); font-size: 12px; }
      .toast-close { background: none; border: none; color: var(--text-dim); cursor: pointer; padding: 4px; }
      @Html.Raw("@keyframes slideIn { from { opacity: 0; transform: translateX(100%); } to { opacity: 1; transform: translateX(0); } }")
    </style>

    <script>
      // Toast notification system
      function showToast(message, type) {
        type = type || 'success';
        const container = document.getElementById('toastContainer');
        if (!container) return;
        const icons = { success: 'bi-check-circle-fill', error: 'bi-x-circle-fill', warning: 'bi-exclamation-triangle-fill' };
        const toast = document.createElement('div');
        toast.className = 'toast ' + type;
        toast.innerHTML = '<i class="bi ' + (icons[type] || icons.success) + '"></i>' +
          '<div class="toast-content">' + message + '</div>' +
          '<button class="toast-close" onclick="this.parentElement.remove()">&times;</button>';
        container.appendChild(toast);
        setTimeout(() => { if (toast.parentElement) { toast.style.opacity = '0'; toast.style.transform = 'translateX(100%)'; toast.style.transition = 'all 0.3s'; setTimeout(() => toast.remove(), 300); } }, 4000);
      }

      // Loading state on form submit
      document.querySelectorAll('form').forEach(function(f) {
        f.addEventListener('submit', function() {
          var btn = this.querySelector('.btn[type="submit"], button[type="submit"]');
          if (btn) btn.classList.add('loading');
        });
      });

      // Password visibility toggle
      window.togglePwd = function(btn) {
        var input = btn.parentElement.querySelector('input');
        if (!input) return;
        var type = input.type === 'password' ? 'text' : 'password';
        input.type = type;
        var icon = btn.querySelector('i');
        if (icon) icon.className = type === 'password' ? 'bi bi-eye-slash' : 'bi bi-eye';
      };

      // Navbar avatar
      function updateNavAvatar() {
        fetch('/Auth/GetAvatarUrl').then(function(r) { return r.json(); }).then(function(d) {
          var container = document.getElementById('navAvatarContainer');
          if (!container) return;
          if (d.url) {
            container.innerHTML = '<img src="' + d.url + '" style="width:28px;height:28px;object-fit:cover;border:1px solid var(--border);" />';
          } else {
            container.innerHTML = '<span style="display:inline-block;width:28px;height:28px;border:1px solid var(--border);display:inline-flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:12px;color:var(--red);background:rgba(230,57,70,0.06);">' + (d.initial || '?') + '</span>';
          }
        }).catch(function(){});
      }
      updateNavAvatar();

      // Cart count updater
      function updateCartCount() {
        fetch('/Cart/GetCount').then(function(r) { return r.json(); }).then(function(d) {
          var badge = document.getElementById('cartCount');
          if (!badge) return;
          if (d.count > 0) { badge.textContent = d.count; badge.style.display = 'inline'; }
          else badge.style.display = 'none';
        }).catch(function(){});
      }
      updateCartCount();

      // Ripple click effect on buttons
      document.querySelectorAll('.btn, .stat-link, .qa-card, .nav-links a').forEach(el => {
        el.classList.add('ripple');
        el.addEventListener('mousedown', function(e) {
          const rect = this.getBoundingClientRect();
          this.style.setProperty('--mx', (e.clientX - rect.left) + 'px');
          this.style.setProperty('--my', (e.clientY - rect.top) + 'px');
        });
      });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    <partial name="_ConfirmModal" />
</body>

</html>
