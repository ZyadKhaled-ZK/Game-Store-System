@model CartViewModel
@{
    ViewData["Title"] = "Cart";
}

<style>
  .cart-table { width: 100%; border-collapse: separate; border-spacing: 0 8px; margin-top: 24px; }
  .cart-table th { font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); letter-spacing: 2px; padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.06); text-align: left; text-transform: uppercase; }
  .cart-table td { padding: 16px; vertical-align: middle; background: rgba(255,255,255,0.02); }
  .cart-table tr td:first-child { border-top-left-radius: 12px; border-bottom-left-radius: 12px; }
  .cart-table tr td:last-child { border-top-right-radius: 12px; border-bottom-right-radius: 12px; }
  .cart-table tr:hover td { background: rgba(255,255,255,0.05); transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: all 0.3s; border-color: rgba(230,57,70,0.3); }
  .cart-cover { width: 80px; height: 50px; object-fit: cover; border-radius: 6px; box-shadow: 0 2px 8px rgba(0,0,0,0.5); border: none; }
  .cart-cover-placeholder { width: 80px; height: 50px; background: rgba(255,255,255,0.04); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: var(--red); font-size: 18px; border: none; }
  .cart-total { font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; color: var(--gold); }
  .empty-cart { text-align: center; padding: 80px; font-family: var(--font-mono); color: var(--text-dim); }
  @@media (max-width: 768px) {
    .empty-cart { padding: 40px 20px; }
    .empty-cart h3 { font-size: 1.2rem; }
    .page-header h2 { font-size: 1.8rem !important; }
    .cart-table th, .cart-table td { padding: 8px 10px; font-size: 12px; }
  }
  @@media (max-width: 576px) {
    .empty-cart { padding: 30px 16px; }
    .page-header { flex-direction: column; align-items: stretch !important; }
    .page-header .btn { width: 100%; text-align: center; }
    .cart-table th { font-size: 9px; letter-spacing: 1px; }
    .cart-table td { padding: 6px 8px; font-size: 11px; }
    .cart-cover, .cart-cover-placeholder { width: 40px; height: 28px; }
    .cart-total { font-size: 1.2rem; }
    .page-header + div[style*="display:flex; justify-content:space-between; align-items:center; margin-top:32px"] { flex-direction: column; gap: 16px; padding: 16px !important; }
  }
</style>

<div class="page-header" style="display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:16px; margin-bottom:32px;">
  <div>
    <div class="section-tag">Shopping</div>
    <h2 class="section-title glitch">YOUR CART</h2>
  </div>
  <a href="/" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> CONTINUE BROWSING</a>
</div>

@{
    var isLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString("UserId"));
}

@{
    if (!string.IsNullOrEmpty(Model.Message)) { TempData["Message"] = Model.Message; TempData["IsError"] = Model.IsError; }
}
<partial name="_Alert" />

@if (isLoggedIn && Model.CartItems.Any())
{
  <div class="table-responsive">
  <table class="cart-table">
    <thead>
      <tr>
        <th>Game</th>
        <th>Title</th>
        <th>Price</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var item in Model.CartItems)
      {
        <tr>
          <td>
            @if (!string.IsNullOrEmpty(item.Game?.CoverImageUrl))
            {
              <img src="@item.Game.CoverImageUrl" alt="@item.Game.Title" class="cart-cover" loading="lazy" width="60" height="40"/>
            }
            else
            {
              <div class="cart-cover-placeholder"><i class="bi bi-play-fill"></i></div>
            }
          </td>
          <td style="font-family:var(--font-display); font-weight:700; color:white;">@(item.Game?.Title ?? "Unknown")</td>
          <td>
            @if (item.Game?.Price == 0)
            {
              <span style="color:var(--text-dim); font-style:italic;">FREE</span>
            }
            else
            {
              <span style="font-family:var(--font-display); font-weight:700; color:var(--gold);">$@(item.Game?.Price.ToString("N2") ?? "0.00")</span>
            }
          </td>
          <td>
            <form method="post" asp-action="Remove" asp-route-id="@item.Id">
              @Html.AntiForgeryToken()
              <button type="submit" class="btn btn-primary" style="padding:6px 12px; font-size:11px;">REMOVE</button>
            </form>
          </td>
        </tr>
      }
    </tbody>
  </table>
  </div>

  <div style="display:flex; justify-content:space-between; align-items:center; margin-top:32px; padding:24px 32px; background:var(--bg2); border:1px solid var(--border-red);">
    <div>
      <div style="font-family:var(--font-mono); font-size:12px; color:var(--text-dim); letter-spacing:1px;">TOTAL</div>
      <div class="cart-total">@(Model.TotalPrice == 0 ? "FREE" : "$" + Model.TotalPrice.ToString("N2"))</div>
    </div>
    @if (Model.TotalPrice == 0)
    {
      <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
          <input type="checkbox" id="freeConfirm" onchange="document.getElementById('claimBtn').disabled = !this.checked;" style="accent-color:var(--gold);width:18px;height:18px;">
          <span style="font-family:var(--font-mono);font-size:11px;color:var(--text-dim);">I confirm I want to add these free games to my library</span>
        </label>
        <form method="post" asp-action="Checkout">
          @Html.AntiForgeryToken()
          <button type="submit" id="claimBtn" class="btn btn-primary" style="padding:14px 36px;font-size:14px;" disabled>CLAIM FREE GAMES</button>
        </form>
      </div>
    }
    else
    {
      <form method="post" asp-action="Checkout"
        data-msg="Confirm purchase of @Model.CartItems.Count game(s) for $@Model.TotalPrice.ToString("N2")?"
        onsubmit="event.preventDefault(); showConfirmModal(this.dataset.msg, this)">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary" style="padding:14px 36px; font-size:14px;">PROCEED TO CHECKOUT</button>
      </form>
    }
  </div>
}
else
{
  <div class="empty-cart">
    <div style="font-size:3rem; margin-bottom:16px; color:var(--red);">🛒</div>
    @if (isLoggedIn)
    {
      <h3 style="font-family:var(--font-display); color:white; margin-bottom:8px;">YOUR CART IS EMPTY</h3>
      <p>No items in queue. <a href="/" style="color:var(--gold);">BROWSE GAMES →</a></p>
    }
    else
    {
      <h3 style="font-family:var(--font-display); color:white; margin-bottom:8px;">LOGIN REQUIRED</h3>
      <p><a href="/Auth/Login" style="color:var(--gold);">LOGIN</a> or <a href="/Auth/Register" style="color:var(--gold);">REGISTER</a> to start shopping.</p>
    }
  </div>
}
